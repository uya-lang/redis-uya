export fn test_command_set_get_del_exists() !void {
    reset_memory_stats_for_test();
    const router: CommandRouter = command_router_new();
    var engine: Engine = engine_new();

    var set_parsed: RespParseResult = try parse_resp2(&"*3\r\n$3\r\nSET\r\n$3\r\nkey\r\n$5\r\nvalue\r\n"[0: 33]);
    const set_command: Command = try command_executor_test_command(&router, &set_parsed);
    const set_reply: CommandReply = command_execute_at(&engine, &set_command, 1000u64);
    try assert_eq_i32(set_reply.typ as i32, CommandReplyType.reply_simple_string as i32);
    try assert_true(command_executor_test_slice_eq(set_reply.data, &"OK"[0: 2]));
    resp_value_free(&set_parsed.value);

    var get_parsed: RespParseResult = try parse_resp2(&"*2\r\n$3\r\nGET\r\n$3\r\nkey\r\n"[0: 22]);
    const get_command: Command = try command_executor_test_command(&router, &get_parsed);
    const get_reply: CommandReply = command_execute_at(&engine, &get_command, 1000u64);
    try assert_eq_i32(get_reply.typ as i32, CommandReplyType.reply_bulk_string as i32);
    try assert_true(command_executor_test_slice_eq(get_reply.data, &"value"[0: 5]));
    resp_value_free(&get_parsed.value);

    var incr_parsed: RespParseResult = try parse_resp2(&"*2\r\n$4\r\nINCR\r\n$7\r\ncounter\r\n"[0: 28]);
    const incr_command: Command = try command_executor_test_command(&router, &incr_parsed);
    const incr_reply: CommandReply = command_execute_at(&engine, &incr_command, 1000u64);
    try assert_eq_i32(incr_reply.typ as i32, CommandReplyType.reply_integer as i32);
    try assert_eq_i32(incr_reply.integer as i32, 1);
    resp_value_free(&incr_parsed.value);

    var incrby_parsed: RespParseResult = try parse_resp2(&"*3\r\n$6\r\nINCRBY\r\n$7\r\ncounter\r\n$1\r\n4\r\n"[0: 38]);
    const incrby_command: Command = try command_executor_test_command(&router, &incrby_parsed);
    const incrby_reply: CommandReply = command_execute_at(&engine, &incrby_command, 1000u64);
    try assert_eq_i32(incrby_reply.typ as i32, CommandReplyType.reply_integer as i32);
    try assert_eq_i32(incrby_reply.integer as i32, 5);
    resp_value_free(&incrby_parsed.value);

    var decr_parsed: RespParseResult = try parse_resp2(&"*2\r\n$4\r\nDECR\r\n$7\r\ncounter\r\n"[0: 28]);
    const decr_command: Command = try command_executor_test_command(&router, &decr_parsed);
    const decr_reply: CommandReply = command_execute_at(&engine, &decr_command, 1000u64);
    try assert_eq_i32(decr_reply.typ as i32, CommandReplyType.reply_integer as i32);
    try assert_eq_i32(decr_reply.integer as i32, 4);
    resp_value_free(&decr_parsed.value);

    var decrby_parsed: RespParseResult = try parse_resp2(&"*3\r\n$6\r\nDECRBY\r\n$7\r\ncounter\r\n$1\r\n2\r\n"[0: 38]);
    const decrby_command: Command = try command_executor_test_command(&router, &decrby_parsed);
    const decrby_reply: CommandReply = command_execute_at(&engine, &decrby_command, 1000u64);
    try assert_eq_i32(decrby_reply.typ as i32, CommandReplyType.reply_integer as i32);
    try assert_eq_i32(decrby_reply.integer as i32, 2);
    resp_value_free(&decrby_parsed.value);

    var setnx_parsed: RespParseResult = try parse_resp2(&"*3\r\n$5\r\nSETNX\r\n$6\r\nnx-key\r\n$5\r\nfirst\r\n"[0: 40]);
    const setnx_command: Command = try command_executor_test_command(&router, &setnx_parsed);
