extern "libc" fn printf(fmt: *byte, ...) i32;

export error AssertionFailed;

export fn assert_true(condition: bool) !void {
    if !condition {
        printf("assert_true failed\n" as *byte);
        return error.AssertionFailed;
    }
}

export fn assert_eq_i32(actual: i32, expected: i32) !void {
    if actual != expected {
        printf("assert_eq_i32 failed: actual=%d expected=%d\n" as *byte, actual, expected);
        return error.AssertionFailed;
    }
}

export fn assert_eq_u64(actual: u64, expected: u64) !void {
    if actual != expected {
        printf("assert_eq_u64 failed: actual=%lu expected=%lu\n" as *byte, actual, expected);
        return error.AssertionFailed;
    }
}
