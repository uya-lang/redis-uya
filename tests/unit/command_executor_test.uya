fn command_executor_test_slice_eq(a: &[byte], b: &[byte]) bool {
    if a.len != b.len { return false; }
    var i: usize = 0;
    while i < a.len {
        if a.ptr[i] != b.ptr[i] { return false; }
        i = i + 1;
    }
    return true;
}

fn command_executor_test_contains(haystack: &[byte], needle: &[byte]) bool {
    if needle.len == 0 {
        return true;
    }
    if haystack.len < needle.len {
        return false;
    }
    var start: usize = 0;
    while start + needle.len <= haystack.len {
        var matched: bool = true;
        var i: usize = 0;
        while i < needle.len {
            if haystack.ptr[start + i] != needle.ptr[i] {
                matched = false;
                break;
            }
            i = i + 1;
        }
        if matched {
            return true;
        }
        start = start + 1;
    }
    return false;
}

fn command_executor_test_fill_bytes(data: &[byte], ch: byte) void {
    var i: usize = 0;
    while i < data.len {
        data.ptr[i] = ch;
        i = i + 1;
    }
}

fn command_executor_test_key_missing_at(engine: &Engine, key: &[byte], now_ms: u64) bool {
    const found: &RedisObject = lookup_key_at(engine, key, now_ms) catch |err| {
        if err == error.EngineKeyNotFound {
            return true;
        }
        return false;
    };
    _ = found;
    return false;
}

fn command_executor_test_command(router: &CommandRouter, parsed: &RespParseResult) !Command {
    return command_from_resp(router, &parsed.value);
}

export fn test_command_ping_and_info() !void {
    reset_memory_stats_for_test();
    const router: CommandRouter = command_router_new();
    var engine: Engine = engine_new();

    var ping_parsed: RespParseResult = try parse_resp2(&"*1\r\n$4\r\nPING\r\n"[0: 14]);
    const ping_command: Command = try command_executor_test_command(&router, &ping_parsed);
    const ping_reply: CommandReply = command_execute_at(&engine, &ping_command, 1000u64);
    try assert_eq_i32(ping_reply.typ as i32, CommandReplyType.reply_simple_string as i32);
    try assert_true(command_executor_test_slice_eq(ping_reply.data, &"PONG"[0: 4]));
    resp_value_free(&ping_parsed.value);

    var ping_msg_parsed: RespParseResult = try parse_resp2(&"*2\r\n$4\r\nPING\r\n$2\r\nhi\r\n"[0: 22]);
    const ping_msg_command: Command = try command_executor_test_command(&router, &ping_msg_parsed);
    const ping_msg_reply: CommandReply = command_execute_at(&engine, &ping_msg_command, 1000u64);
    try assert_eq_i32(ping_msg_reply.typ as i32, CommandReplyType.reply_bulk_string as i32);
    try assert_true(command_executor_test_slice_eq(ping_msg_reply.data, &"hi"[0: 2]));
    resp_value_free(&ping_msg_parsed.value);

    engine_free(&engine);
    try assert_eq_i32(used_memory() as i32, 0);
}

export fn test_command_info_and_config() !void {
    reset_memory_stats_for_test();
    const router: CommandRouter = command_router_new();
    var engine: Engine = engine_new();
    var out: [byte: 512] = [];
    var runtime: CommandRuntimeInfo = command_runtime_default();
    runtime.config.port = 6380;
    runtime.active_clients = 2;
    runtime.maxclients = 8;
    runtime.served_clients = 5;
    runtime.cron_ticks = 9u64;
    runtime.start_ms = 1000u64;
    config_copy_bytes(runtime.replication_replid[0: 41], &"0123456789abcdef0123456789abcdef01234567"[0: 40]);
    runtime.replication_backlog_active = true;
    runtime.replication_master_offset = 128u64;
    runtime.replication_backlog_first_offset = 64u64;
    runtime.replication_backlog_histlen = 64;

    var set_parsed: RespParseResult = try parse_resp2(&"*3\r\n$3\r\nSET\r\n$3\r\nkey\r\n$5\r\nvalue\r\n"[0: 33]);
    const set_command: Command = try command_executor_test_command(&router, &set_parsed);
    _ = command_execute_with_runtime_at(&engine, &runtime, &set_command, 5000u64);
    resp_value_free(&set_parsed.value);

    var expire_parsed: RespParseResult = try parse_resp2(&"*3\r\n$6\r\nEXPIRE\r\n$3\r\nkey\r\n$1\r\n2\r\n"[0: 32]);
    const expire_command: Command = try command_executor_test_command(&router, &expire_parsed);
    _ = command_execute_with_runtime_at(&engine, &runtime, &expire_command, 5000u64);
    resp_value_free(&expire_parsed.value);

    var info_server_parsed: RespParseResult = try parse_resp2(&"*2\r\n$4\r\nINFO\r\n$6\r\nserver\r\n"[0: 26]);
    const info_server_command: Command = try command_executor_test_command(&router, &info_server_parsed);
    var info_server_reply: CommandReply = command_execute_with_runtime_at(&engine, &runtime, &info_server_command, 5000u64);
    try assert_eq_i32(info_server_reply.typ as i32, CommandReplyType.reply_bulk_string as i32);
    try assert_eq_i32(info_server_reply.data.len as i32, 100);
    try assert_true(command_executor_test_slice_eq(info_server_reply.data, &"# Server\r\nredis_uya_version:0.1.0-dev\r\nredis_mode:standalone\r\ntcp_port:6380\r\nuptime_in_seconds:4\r\n\r\n"[0: 100]));
    command_reply_cleanup(&info_server_reply);
    resp_value_free(&info_server_parsed.value);

    var info_memory_parsed: RespParseResult = try parse_resp2(&"*2\r\n$4\r\nINFO\r\n$6\r\nmemory\r\n"[0: 26]);
    const info_memory_command: Command = try command_executor_test_command(&router, &info_memory_parsed);
    var info_memory_reply: CommandReply = command_execute_with_runtime_at(&engine, &runtime, &info_memory_command, 5000u64);
    try assert_eq_i32(info_memory_reply.typ as i32, CommandReplyType.reply_bulk_string as i32);
    try assert_true(command_executor_test_contains(info_memory_reply.data, &"# Memory\r\n"[0: 10]));
    try assert_true(command_executor_test_contains(info_memory_reply.data, &"used_memory_peak:"[0: 17]));
    try assert_true(command_executor_test_contains(info_memory_reply.data, &"total_allocated:"[0: 16]));
    try assert_true(command_executor_test_contains(info_memory_reply.data, &"total_freed:"[0: 12]));
    try assert_true(command_executor_test_contains(info_memory_reply.data, &"allocator_total_allocations:"[0: 28]));
    try assert_true(command_executor_test_contains(info_memory_reply.data, &"allocator_active_allocations:"[0: 29]));
    try assert_true(command_executor_test_contains(info_memory_reply.data, &"allocator_slab_cached_blocks:"[0: 29]));
    try assert_true(command_executor_test_contains(info_memory_reply.data, &"allocator_slab_cached_bytes:"[0: 28]));
    try assert_true(command_executor_test_contains(info_memory_reply.data, &"allocator_slab_reuse_count:"[0: 27]));
    try assert_true(command_executor_test_contains(info_memory_reply.data, &"object_pool_cached_objects:"[0: 27]));
    try assert_true(command_executor_test_contains(info_memory_reply.data, &"object_pool_cached_list_nodes:"[0: 30]));
    try assert_true(command_executor_test_contains(info_memory_reply.data, &"object_pool_reuse_count:"[0: 24]));
    try assert_true(command_executor_test_contains(info_memory_reply.data, &"object_layout_size:"[0: 19]));
    try assert_true(command_executor_test_contains(info_memory_reply.data, &"list_node_layout_size:"[0: 22]));
    try assert_true(command_executor_test_contains(info_memory_reply.data, &"maxmemory_policy:noeviction\r\n"[0: 29]));
    command_reply_cleanup(&info_memory_reply);
    resp_value_free(&info_memory_parsed.value);

    var info_keyspace_parsed: RespParseResult = try parse_resp2(&"*2\r\n$4\r\nINFO\r\n$8\r\nkeyspace\r\n"[0: 28]);
    const info_keyspace_command: Command = try command_executor_test_command(&router, &info_keyspace_parsed);
    var info_keyspace_reply: CommandReply = command_execute_with_runtime_at(&engine, &runtime, &info_keyspace_command, 5000u64);
    try assert_eq_i32(info_keyspace_reply.typ as i32, CommandReplyType.reply_bulk_string as i32);
    try assert_eq_i32(info_keyspace_reply.data.len as i32, 46);
    try assert_true(command_executor_test_slice_eq(info_keyspace_reply.data, &"# Keyspace\r\ndb0:keys=1,expires=1,avg_ttl=0\r\n\r\n"[0: 46]));
    command_reply_cleanup(&info_keyspace_reply);
    resp_value_free(&info_keyspace_parsed.value);

    var info_repl_master_parsed: RespParseResult = try parse_resp2(&"*2\r\n$4\r\nINFO\r\n$11\r\nreplication\r\n"[0: 32]);
    const info_repl_master_command: Command = try command_executor_test_command(&router, &info_repl_master_parsed);
    var info_repl_master_reply: CommandReply = command_execute_with_runtime_at(&engine, &runtime, &info_repl_master_command, 5000u64);
    try assert_eq_i32(info_repl_master_reply.typ as i32, CommandReplyType.reply_bulk_string as i32);
    try assert_true(command_executor_test_contains(info_repl_master_reply.data, &"role:master\r\n"[0: 13]));
    command_reply_cleanup(&info_repl_master_reply);
    resp_value_free(&info_repl_master_parsed.value);

    var config_port_parsed: RespParseResult = try parse_resp2(&"*3\r\n$6\r\nCONFIG\r\n$3\r\nGET\r\n$4\r\nport\r\n"[0: 35]);
    const config_port_command: Command = try command_executor_test_command(&router, &config_port_parsed);
    var config_port_reply: CommandReply = command_execute_with_runtime_at(&engine, &runtime, &config_port_command, 5000u64);
    const config_port_len: usize = try connection_encode_reply(&config_port_reply, &out[0], 512);
    try assert_eq_i32(config_port_len as i32, 24);
    try assert_true(command_executor_test_slice_eq(out[0: config_port_len], &"*2\r\n$4\r\nport\r\n$4\r\n6380\r\n"[0: 24]));
    command_reply_cleanup(&config_port_reply);
    resp_value_free(&config_port_parsed.value);

    var config_append_parsed: RespParseResult = try parse_resp2(&"*3\r\n$6\r\nCONFIG\r\n$3\r\nGET\r\n$7\r\nappend*\r\n"[0: 38]);
    const config_append_command: Command = try command_executor_test_command(&router, &config_append_parsed);
    var config_append_reply: CommandReply = command_execute_with_runtime_at(&engine, &runtime, &config_append_command, 5000u64);
    const config_append_len: usize = try connection_encode_reply(&config_append_reply, &out[0], 512);
    try assert_eq_i32(config_append_len as i32, 46);
    try assert_true(command_executor_test_slice_eq(out[0: config_append_len], &"*2\r\n$14\r\nappendfilename\r\n$14\r\nappendonly.aof\r\n"[0: 46]));
    command_reply_cleanup(&config_append_reply);
    resp_value_free(&config_append_parsed.value);

    var config_max_parsed: RespParseResult = try parse_resp2(&"*3\r\n$6\r\nCONFIG\r\n$3\r\nGET\r\n$4\r\nmax*\r\n"[0: 35]);
    const config_max_command: Command = try command_executor_test_command(&router, &config_max_parsed);
    var config_max_reply: CommandReply = command_execute_with_runtime_at(&engine, &runtime, &config_max_command, 5000u64);
    const config_max_len: usize = try connection_encode_reply(&config_max_reply, &out[0], 512);
    try assert_true(command_executor_test_contains(out[0: config_max_len], &"$9\r\nmaxmemory\r\n$1\r\n0\r\n"[0: 22]));
    try assert_true(command_executor_test_contains(out[0: config_max_len], &"$10\r\nmaxclients\r\n$1\r\n8\r\n"[0: 24]));
    command_reply_cleanup(&config_max_reply);
    resp_value_free(&config_max_parsed.value);

    var config_databases_parsed: RespParseResult = try parse_resp2(&"*3\r\n$6\r\nCONFIG\r\n$3\r\nGET\r\n$9\r\ndatabases\r\n"[0: 40]);
    const config_databases_command: Command = try command_executor_test_command(&router, &config_databases_parsed);
    var config_databases_reply: CommandReply = command_execute_with_runtime_at(&engine, &runtime, &config_databases_command, 5000u64);
    const config_databases_len: usize = try connection_encode_reply(&config_databases_reply, &out[0], 512);
    try assert_true(command_executor_test_slice_eq(out[0: config_databases_len], &"*2\r\n$9\r\ndatabases\r\n$1\r\n1\r\n"[0: 26]));
    command_reply_cleanup(&config_databases_reply);
    resp_value_free(&config_databases_parsed.value);

    var config_help_parsed: RespParseResult = try parse_resp2(&"*2\r\n$6\r\nCONFIG\r\n$4\r\nHELP\r\n"[0: 26]);
    const config_help_command: Command = try command_executor_test_command(&router, &config_help_parsed);
    var config_help_reply: CommandReply = command_execute_with_runtime_at(&engine, &runtime, &config_help_command, 5000u64);
    const config_help_len: usize = try connection_encode_reply(&config_help_reply, &out[0], 512);
    try assert_true(command_executor_test_contains(out[0: config_help_len], &"$20\r\nCONFIG GET <pattern>\r\n"[0: 27]));
    command_reply_cleanup(&config_help_reply);
    resp_value_free(&config_help_parsed.value);

    var config_resetstat_parsed: RespParseResult = try parse_resp2(&"*2\r\n$6\r\nCONFIG\r\n$9\r\nRESETSTAT\r\n"[0: 31]);
    const config_resetstat_command: Command = try command_executor_test_command(&router, &config_resetstat_parsed);
    const config_resetstat_reply: CommandReply = command_execute_with_runtime_at(&engine, &runtime, &config_resetstat_command, 5000u64);
    try assert_eq_i32(config_resetstat_reply.typ as i32, CommandReplyType.reply_simple_string as i32);
    try assert_true(command_executor_test_slice_eq(config_resetstat_reply.data, &"OK"[0: 2]));
    resp_value_free(&config_resetstat_parsed.value);

    runtime.replication_role = ReplicationRole.role_replica;
    runtime.replication_state = ReplicationState.repl_state_configured;
    runtime.config.replicaof_host[0] = 49 as byte; // 1
    runtime.config.replicaof_host[1] = 50 as byte; // 2
    runtime.config.replicaof_host[2] = 55 as byte; // 7
    runtime.config.replicaof_host[3] = 46 as byte; // .
    runtime.config.replicaof_host[4] = 48 as byte; // 0
    runtime.config.replicaof_host[5] = 46 as byte; // .
    runtime.config.replicaof_host[6] = 48 as byte; // 0
    runtime.config.replicaof_host[7] = 46 as byte; // .
    runtime.config.replicaof_host[8] = 49 as byte; // 1
    runtime.config.replicaof_host[9] = 0 as byte;
    runtime.config.replicaof_port = 6381;
    runtime.config.masterauth[0] = 115 as byte; // s
    runtime.config.masterauth[1] = 101 as byte; // e
    runtime.config.masterauth[2] = 99 as byte;  // c
    runtime.config.masterauth[3] = 114 as byte; // r
    runtime.config.masterauth[4] = 101 as byte; // e
    runtime.config.masterauth[5] = 116 as byte; // t
    runtime.config.masterauth[6] = 0 as byte;

    var info_repl_replica_parsed: RespParseResult = try parse_resp2(&"*2\r\n$4\r\nINFO\r\n$11\r\nreplication\r\n"[0: 32]);
    const info_repl_replica_command: Command = try command_executor_test_command(&router, &info_repl_replica_parsed);
    var info_repl_replica_reply: CommandReply = command_execute_with_runtime_at(&engine, &runtime, &info_repl_replica_command, 5000u64);
    try assert_eq_i32(info_repl_replica_reply.typ as i32, CommandReplyType.reply_bulk_string as i32);
    try assert_true(command_executor_test_contains(info_repl_replica_reply.data, &"role:slave\r\n"[0: 12]));
    command_reply_cleanup(&info_repl_replica_reply);
    resp_value_free(&info_repl_replica_parsed.value);

    var config_replicaof_parsed: RespParseResult = try parse_resp2(&"*3\r\n$6\r\nCONFIG\r\n$3\r\nGET\r\n$9\r\nreplicaof\r\n"[0: 40]);
    const config_replicaof_command: Command = try command_executor_test_command(&router, &config_replicaof_parsed);
    var config_replicaof_reply: CommandReply = command_execute_with_runtime_at(&engine, &runtime, &config_replicaof_command, 5000u64);
    const config_replicaof_len: usize = try connection_encode_reply(&config_replicaof_reply, &out[0], 512);
    try assert_true(config_replicaof_len > 0);
    try assert_eq_i32(out[0] as i32, 42);
    command_reply_cleanup(&config_replicaof_reply);
    resp_value_free(&config_replicaof_parsed.value);

    var config_masterauth_parsed: RespParseResult = try parse_resp2(&"*3\r\n$6\r\nCONFIG\r\n$3\r\nGET\r\n$10\r\nmasterauth\r\n"[0: 42]);
    const config_masterauth_command: Command = try command_executor_test_command(&router, &config_masterauth_parsed);
    var config_masterauth_reply: CommandReply = command_execute_with_runtime_at(&engine, &runtime, &config_masterauth_command, 5000u64);
    const config_masterauth_len: usize = try connection_encode_reply(&config_masterauth_reply, &out[0], 512);
    try assert_true(config_masterauth_len > 0);
    try assert_eq_i32(out[0] as i32, 42);
    command_reply_cleanup(&config_masterauth_reply);
    resp_value_free(&config_masterauth_parsed.value);

    engine_free(&engine);
    try assert_eq_i32(used_memory() as i32, 0);
}

export fn test_command_cluster() !void {
    reset_memory_stats_for_test();
    const router: CommandRouter = command_router_new();
    var engine: Engine = engine_new();
    var runtime: CommandRuntimeInfo = command_runtime_default();
    runtime.config.port = 6380;
    config_copy_bytes(runtime.config.bind[0: 64], &"127.0.0.1"[0: 9]);

    var keyslot_parsed: RespParseResult = try parse_resp2(&"*3\r\n$7\r\nCLUSTER\r\n$7\r\nKEYSLOT\r\n$9\r\n123456789\r\n"[0: 45]);
    const keyslot_command: Command = try command_executor_test_command(&router, &keyslot_parsed);
    const keyslot_reply: CommandReply = command_execute_with_runtime_at(&engine, &runtime, &keyslot_command, 5000u64);
    try assert_eq_i32(keyslot_reply.typ as i32, CommandReplyType.reply_integer as i32);
    try assert_eq_i32(keyslot_reply.integer as i32, 12739);
    resp_value_free(&keyslot_parsed.value);

    var info_parsed: RespParseResult = try parse_resp2(&"*2\r\n$7\r\nCLUSTER\r\n$4\r\nINFO\r\n"[0: 27]);
    const info_command: Command = try command_executor_test_command(&router, &info_parsed);
    var info_reply: CommandReply = command_execute_with_runtime_at(&engine, &runtime, &info_command, 5000u64);
    try assert_eq_i32(info_reply.typ as i32, CommandReplyType.reply_bulk_string as i32);
    try assert_true(command_executor_test_contains(info_reply.data, &"cluster_enabled:1\r\n"[0: 19]));
    try assert_true(command_executor_test_contains(info_reply.data, &"cluster_slots_assigned:16384\r\n"[0: 30]));
    command_reply_cleanup(&info_reply);
    resp_value_free(&info_parsed.value);

    var nodes_parsed: RespParseResult = try parse_resp2(&"*2\r\n$7\r\nCLUSTER\r\n$5\r\nNODES\r\n"[0: 28]);
    const nodes_command: Command = try command_executor_test_command(&router, &nodes_parsed);
    var nodes_reply: CommandReply = command_execute_with_runtime_at(&engine, &runtime, &nodes_command, 5000u64);
    try assert_eq_i32(nodes_reply.typ as i32, CommandReplyType.reply_bulk_string as i32);
    try assert_true(command_executor_test_contains(nodes_reply.data, &"127.0.0.1:6380@16380"[0: 20]));
    try assert_true(command_executor_test_contains(nodes_reply.data, &"myself,master"[0: 13]));
    try assert_true(command_executor_test_contains(nodes_reply.data, &"0-16383\r\n"[0: 9]));
    command_reply_cleanup(&nodes_reply);
    resp_value_free(&nodes_parsed.value);

    var slots_parsed: RespParseResult = try parse_resp2(&"*2\r\n$7\r\nCLUSTER\r\n$5\r\nSLOTS\r\n"[0: 28]);
    const slots_command: Command = try command_executor_test_command(&router, &slots_parsed);
    var slots_reply: CommandReply = command_execute_with_runtime_at(&engine, &runtime, &slots_command, 5000u64);
    try assert_eq_i32(slots_reply.typ as i32, CommandReplyType.reply_raw_bytes as i32);
    try assert_true(command_executor_test_contains(slots_reply.data, &"*1\r\n*3\r\n:0\r\n:16383\r\n*3\r\n$9\r\n127.0.0.1\r\n:6380\r\n$40\r\n"[0: 51]));
    command_reply_cleanup(&slots_reply);
    resp_value_free(&slots_parsed.value);

    var help_parsed: RespParseResult = try parse_resp2(&"*2\r\n$7\r\nCLUSTER\r\n$4\r\nHELP\r\n"[0: 27]);
    const help_command: Command = try command_executor_test_command(&router, &help_parsed);
    var help_reply: CommandReply = command_execute_with_runtime_at(&engine, &runtime, &help_command, 5000u64);
    var out: [byte: 512] = [];
    const help_len: usize = try connection_encode_reply(&help_reply, &out[0], 512);
    try assert_true(command_executor_test_contains(out[0: help_len], &"$21\r\nCLUSTER KEYSLOT <key>\r\n"[0: 28]));
    command_reply_cleanup(&help_reply);
    resp_value_free(&help_parsed.value);

    var missing_parsed: RespParseResult = try parse_resp2(&"*2\r\n$7\r\nCLUSTER\r\n$7\r\nMISSING\r\n"[0: 30]);
    const missing_command: Command = try command_executor_test_command(&router, &missing_parsed);
    const missing_reply: CommandReply = command_execute_with_runtime_at(&engine, &runtime, &missing_command, 5000u64);
    try assert_eq_i32(missing_reply.typ as i32, CommandReplyType.reply_error as i32);
    try assert_true(command_executor_test_slice_eq(missing_reply.data, &"ERR unknown CLUSTER subcommand"[0: 30]));
    resp_value_free(&missing_parsed.value);

    engine_free(&engine);
    try assert_eq_i32(used_memory() as i32, 0);
}

export fn test_command_cluster_redirects() !void {
    reset_memory_stats_for_test();
    const router: CommandRouter = command_router_new();
    var engine: Engine = engine_new();
    var topology: ClusterTopology = cluster_topology_single_node(&"127.0.0.1"[0: 9], 6380);
    var runtime: CommandRuntimeInfo = command_runtime_default();
    runtime.cluster_topology = &topology;

    var remote_id: [byte: 40] = [
        97, 97, 97, 97, 97, 97, 97, 97,
        97, 97, 97, 97, 97, 97, 97, 97,
        97, 97, 97, 97, 97, 97, 97, 97,
        97, 97, 97, 97, 97, 97, 97, 97,
        97, 97, 97, 97, 97, 97, 97, 97,
    ];
    const remote: ClusterNode = cluster_node_new(
        remote_id[0: 40],
        &"127.0.0.2"[0: 9],
        7000,
        ClusterNodeRole.cluster_node_master,
        CLUSTER_NODE_FLAG_MASTER,
        1u64,
        true,
    );
    _ = try cluster_topology_add_node(&topology, &remote);

    var setslot_parsed: RespParseResult = try parse_resp2(&"*5\r\n$7\r\nCLUSTER\r\n$7\r\nSETSLOT\r\n$5\r\n12182\r\n$4\r\nNODE\r\n$40\r\naaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa\r\n"[0: 98]);
    const setslot_command: Command = try command_executor_test_command(&router, &setslot_parsed);
    const setslot_reply: CommandReply = command_execute_with_runtime_at(&engine, &runtime, &setslot_command, 5000u64);
    try assert_eq_i32(setslot_reply.typ as i32, CommandReplyType.reply_simple_string as i32);
    resp_value_free(&setslot_parsed.value);

    var moved_get_parsed: RespParseResult = try parse_resp2(&"*2\r\n$3\r\nGET\r\n$3\r\nfoo\r\n"[0: 22]);
    const moved_get_command: Command = try command_executor_test_command(&router, &moved_get_parsed);
    var moved_reply: CommandReply = command_execute_with_runtime_at(&engine, &runtime, &moved_get_command, 5000u64);
    try assert_eq_i32(moved_reply.typ as i32, CommandReplyType.reply_error as i32);
    try assert_true(command_executor_test_slice_eq(moved_reply.data, &"MOVED 12182 127.0.0.2:7000"[0: 26]));
    command_reply_cleanup(&moved_reply);
    resp_value_free(&moved_get_parsed.value);

    var migrating_parsed: RespParseResult = try parse_resp2(&"*5\r\n$7\r\nCLUSTER\r\n$7\r\nSETSLOT\r\n$4\r\n5061\r\n$9\r\nMIGRATING\r\n$40\r\naaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa\r\n"[0: 102]);
    const migrating_command: Command = try command_executor_test_command(&router, &migrating_parsed);
    const migrating_reply: CommandReply = command_execute_with_runtime_at(&engine, &runtime, &migrating_command, 5000u64);
    try assert_eq_i32(migrating_reply.typ as i32, CommandReplyType.reply_simple_string as i32);
    resp_value_free(&migrating_parsed.value);

    var ask_get_parsed: RespParseResult = try parse_resp2(&"*2\r\n$3\r\nGET\r\n$11\r\nfoo{bar}zap\r\n"[0: 31]);
    const ask_get_command: Command = try command_executor_test_command(&router, &ask_get_parsed);
    var ask_reply: CommandReply = command_execute_with_runtime_at(&engine, &runtime, &ask_get_command, 5000u64);
    try assert_eq_i32(ask_reply.typ as i32, CommandReplyType.reply_error as i32);
    try assert_true(command_executor_test_slice_eq(ask_reply.data, &"ASK 5061 127.0.0.2:7000"[0: 23]));
    command_reply_cleanup(&ask_reply);
    resp_value_free(&ask_get_parsed.value);

    var stable_parsed: RespParseResult = try parse_resp2(&"*4\r\n$7\r\nCLUSTER\r\n$7\r\nSETSLOT\r\n$4\r\n5061\r\n$6\r\nSTABLE\r\n"[0: 52]);
    const stable_command: Command = try command_executor_test_command(&router, &stable_parsed);
    const stable_reply: CommandReply = command_execute_with_runtime_at(&engine, &runtime, &stable_command, 5000u64);
    try assert_eq_i32(stable_reply.typ as i32, CommandReplyType.reply_simple_string as i32);
    resp_value_free(&stable_parsed.value);

    var local_after_stable_parsed: RespParseResult = try parse_resp2(&"*2\r\n$3\r\nGET\r\n$11\r\nfoo{bar}zap\r\n"[0: 31]);
    const local_after_stable_command: Command = try command_executor_test_command(&router, &local_after_stable_parsed);
    const local_after_stable_reply: CommandReply = command_execute_with_runtime_at(&engine, &runtime, &local_after_stable_command, 5000u64);
    try assert_eq_i32(local_after_stable_reply.typ as i32, CommandReplyType.reply_null_bulk as i32);
    resp_value_free(&local_after_stable_parsed.value);

    engine_free(&engine);
    try assert_eq_i32(used_memory() as i32, 0);
}

export fn test_command_replicaof() !void {
    reset_memory_stats_for_test();
    const router: CommandRouter = command_router_new();
    var engine: Engine = engine_new();
    var runtime: CommandRuntimeInfo = command_runtime_default();

    var replica_parsed: RespParseResult = try parse_resp2(&"*3\r\n$9\r\nREPLICAOF\r\n$9\r\n127.0.0.1\r\n$4\r\n6381\r\n"[0: 44]);
    const replica_command: Command = try command_executor_test_command(&router, &replica_parsed);
    const replica_reply: CommandReply = command_execute_with_runtime_at(&engine, &runtime, &replica_command, 1000u64);
    try assert_eq_i32(replica_reply.typ as i32, CommandReplyType.reply_simple_string as i32);
    try assert_eq_i32(replica_reply.request_replicaof as i32, 1);
    try assert_eq_i32(replica_reply.replicaof_promote as i32, 0);
    resp_value_free(&replica_parsed.value);

    var promote_parsed: RespParseResult = try parse_resp2(&"*3\r\n$9\r\nREPLICAOF\r\n$2\r\nNO\r\n$3\r\nONE\r\n"[0: 36]);
    const promote_command: Command = try command_executor_test_command(&router, &promote_parsed);
    const promote_reply: CommandReply = command_execute_with_runtime_at(&engine, &runtime, &promote_command, 1000u64);
    try assert_eq_i32(promote_reply.typ as i32, CommandReplyType.reply_simple_string as i32);
    try assert_eq_i32(promote_reply.request_replicaof as i32, 1);
    try assert_eq_i32(promote_reply.replicaof_promote as i32, 1);
    resp_value_free(&promote_parsed.value);

    var bad_port_parsed: RespParseResult = try parse_resp2(&"*3\r\n$9\r\nREPLICAOF\r\n$9\r\n127.0.0.1\r\n$4\r\nnope\r\n"[0: 44]);
    const bad_port_command: Command = try command_executor_test_command(&router, &bad_port_parsed);
    const bad_port_reply: CommandReply = command_execute_with_runtime_at(&engine, &runtime, &bad_port_command, 1000u64);
    try assert_eq_i32(bad_port_reply.typ as i32, CommandReplyType.reply_error as i32);
    resp_value_free(&bad_port_parsed.value);

    engine_free(&engine);
    try assert_eq_i32(used_memory() as i32, 0);
}

export fn test_command_psync() !void {
    reset_memory_stats_for_test();
    const router: CommandRouter = command_router_new();
    var engine: Engine = engine_new();
    var runtime: CommandRuntimeInfo = command_runtime_default();
    config_copy_bytes(runtime.replication_replid[0: 41], &"0123456789abcdef0123456789abcdef01234567"[0: 40]);
    runtime.replication_backlog_active = true;
    runtime.replication_master_offset = 128u64;
    runtime.replication_backlog_first_offset = 64u64;
    runtime.replication_backlog_histlen = 64;

    var full_parsed: RespParseResult = try parse_resp2(&"*3\r\n$5\r\nPSYNC\r\n$1\r\n?\r\n$2\r\n-1\r\n"[0: 30]);
    const full_command: Command = try command_executor_test_command(&router, &full_parsed);
    const full_reply: CommandReply = command_execute_with_runtime_at(&engine, &runtime, &full_command, 1000u64);
    try assert_eq_i32(full_reply.typ as i32, CommandReplyType.reply_simple_string as i32);
    try assert_true(command_executor_test_contains(full_reply.data, &"FULLRESYNC"[0: 10]));
    try assert_true(command_executor_test_contains(full_reply.data, &"0123456789abcdef0123456789abcdef01234567"[0: 40]));
    try assert_true(command_executor_test_contains(full_reply.data, &" 128"[0: 4]));
    command_reply_cleanup(&full_reply);
    resp_value_free(&full_parsed.value);

    var continue_parsed: RespParseResult = try parse_resp2(&"*3\r\n$5\r\nPSYNC\r\n$40\r\n0123456789abcdef0123456789abcdef01234567\r\n$2\r\n64\r\n"[0: 70]);
    const continue_command: Command = try command_executor_test_command(&router, &continue_parsed);
    const continue_reply: CommandReply = command_execute_with_runtime_at(&engine, &runtime, &continue_command, 1000u64);
    try assert_eq_i32(continue_reply.typ as i32, CommandReplyType.reply_simple_string as i32);
    try assert_true(command_executor_test_slice_eq(continue_reply.data, &"CONTINUE"[0: 8]));
    resp_value_free(&continue_parsed.value);

    var stale_parsed: RespParseResult = try parse_resp2(&"*3\r\n$5\r\nPSYNC\r\n$40\r\n0123456789abcdef0123456789abcdef01234567\r\n$2\r\n10\r\n"[0: 70]);
    const stale_command: Command = try command_executor_test_command(&router, &stale_parsed);
    const stale_reply: CommandReply = command_execute_with_runtime_at(&engine, &runtime, &stale_command, 1000u64);
    try assert_eq_i32(stale_reply.typ as i32, CommandReplyType.reply_simple_string as i32);
    try assert_true(command_executor_test_contains(stale_reply.data, &"FULLRESYNC"[0: 10]));
    try assert_true(command_executor_test_contains(stale_reply.data, &"0123456789abcdef0123456789abcdef01234567"[0: 40]));
    try assert_true(command_executor_test_contains(stale_reply.data, &" 128"[0: 4]));
    command_reply_cleanup(&stale_reply);
    resp_value_free(&stale_parsed.value);

    runtime.replication_role = ReplicationRole.role_replica;
    var bad_role_parsed: RespParseResult = try parse_resp2(&"*3\r\n$5\r\nPSYNC\r\n$1\r\n?\r\n$2\r\n-1\r\n"[0: 30]);
    const bad_role_command: Command = try command_executor_test_command(&router, &bad_role_parsed);
    const bad_role_reply: CommandReply = command_execute_with_runtime_at(&engine, &runtime, &bad_role_command, 1000u64);
    try assert_eq_i32(bad_role_reply.typ as i32, CommandReplyType.reply_error as i32);
    resp_value_free(&bad_role_parsed.value);

    engine_free(&engine);
    try assert_eq_i32(used_memory() as i32, 0);
}

export fn test_command_save_rdb() !void {
    reset_memory_stats_for_test();
    const path: &const byte = "build/test-command-save.rdb";
    _ = unlink(path);

    const router: CommandRouter = command_router_new();
    var engine: Engine = engine_new();
    var runtime: CommandRuntimeInfo = command_runtime_default();
    runtime.config.dir[0] = 98 as byte;   // b
    runtime.config.dir[1] = 117 as byte;  // u
    runtime.config.dir[2] = 105 as byte;  // i
    runtime.config.dir[3] = 108 as byte;  // l
    runtime.config.dir[4] = 100 as byte;  // d
    runtime.config.dir[5] = 47 as byte;   // /
    runtime.config.dir[6] = 0 as byte;
    runtime.config.dbfilename[0] = 116 as byte;  // t
    runtime.config.dbfilename[1] = 101 as byte;  // e
    runtime.config.dbfilename[2] = 115 as byte;  // s
    runtime.config.dbfilename[3] = 116 as byte;  // t
    runtime.config.dbfilename[4] = 45 as byte;   // -
    runtime.config.dbfilename[5] = 99 as byte;   // c
    runtime.config.dbfilename[6] = 111 as byte;  // o
    runtime.config.dbfilename[7] = 109 as byte;  // m
    runtime.config.dbfilename[8] = 109 as byte;  // m
    runtime.config.dbfilename[9] = 97 as byte;   // a
    runtime.config.dbfilename[10] = 110 as byte; // n
    runtime.config.dbfilename[11] = 100 as byte; // d
    runtime.config.dbfilename[12] = 45 as byte;  // -
    runtime.config.dbfilename[13] = 115 as byte; // s
    runtime.config.dbfilename[14] = 97 as byte;  // a
    runtime.config.dbfilename[15] = 118 as byte; // v
    runtime.config.dbfilename[16] = 101 as byte; // e
    runtime.config.dbfilename[17] = 46 as byte;  // .
    runtime.config.dbfilename[18] = 114 as byte; // r
    runtime.config.dbfilename[19] = 100 as byte; // d
    runtime.config.dbfilename[20] = 98 as byte;  // b
    runtime.config.dbfilename[21] = 0 as byte;

    var set_parsed: RespParseResult = try parse_resp2(&"*3\r\n$3\r\nSET\r\n$3\r\nkey\r\n$5\r\nvalue\r\n"[0: 33]);
    const set_command: Command = try command_executor_test_command(&router, &set_parsed);
    _ = command_execute_with_runtime_at(&engine, &runtime, &set_command, 1000u64);
    resp_value_free(&set_parsed.value);

    var save_parsed: RespParseResult = try parse_resp2(&"*1\r\n$4\r\nSAVE\r\n"[0: 14]);
    const save_command: Command = try command_executor_test_command(&router, &save_parsed);
    const save_reply: CommandReply = command_execute_with_runtime_at(&engine, &runtime, &save_command, 1000u64);
    try assert_eq_i32(save_reply.typ as i32, CommandReplyType.reply_simple_string as i32);
    try assert_true(command_executor_test_slice_eq(save_reply.data, &"OK"[0: 2]));
    resp_value_free(&save_parsed.value);
    engine_free(&engine);

    var replay_engine: Engine = engine_new();
    try rdb_load_file_at(path, &replay_engine, 1000u64);
    const found: &RedisObject = try lookup_key_at(&replay_engine, &"key"[0: 3], 1000u64);
    try assert_true(command_executor_test_slice_eq(found.value.buf[0: found.value.len], &"value"[0: 5]));
    engine_free(&replay_engine);

    _ = unlink(path);
    try assert_eq_i32(used_memory() as i32, 0);
}

export fn test_command_bgsave() !void {
    reset_memory_stats_for_test();
    const router: CommandRouter = command_router_new();
    var engine: Engine = engine_new();
    var runtime: CommandRuntimeInfo = command_runtime_default();

    runtime.config.dir[0] = 98 as byte;   // b
    runtime.config.dir[1] = 117 as byte;  // u
    runtime.config.dir[2] = 105 as byte;  // i
    runtime.config.dir[3] = 108 as byte;  // l
    runtime.config.dir[4] = 100 as byte;  // d
    runtime.config.dir[5] = 47 as byte;   // /
    runtime.config.dir[6] = 0 as byte;
    runtime.config.dbfilename[0] = 99 as byte;   // c
    runtime.config.dbfilename[1] = 111 as byte;  // o
    runtime.config.dbfilename[2] = 109 as byte;  // m
    runtime.config.dbfilename[3] = 109 as byte;  // m
    runtime.config.dbfilename[4] = 97 as byte;   // a
    runtime.config.dbfilename[5] = 110 as byte;  // n
    runtime.config.dbfilename[6] = 100 as byte;  // d
    runtime.config.dbfilename[7] = 45 as byte;   // -
    runtime.config.dbfilename[8] = 98 as byte;   // b
    runtime.config.dbfilename[9] = 103 as byte;  // g
    runtime.config.dbfilename[10] = 115 as byte; // s
    runtime.config.dbfilename[11] = 97 as byte;  // a
    runtime.config.dbfilename[12] = 118 as byte; // v
    runtime.config.dbfilename[13] = 101 as byte; // e
    runtime.config.dbfilename[14] = 46 as byte;  // .
    runtime.config.dbfilename[15] = 114 as byte; // r
    runtime.config.dbfilename[16] = 100 as byte; // d
    runtime.config.dbfilename[17] = 98 as byte;  // b
    runtime.config.dbfilename[18] = 0 as byte;

    var set_parsed: RespParseResult = try parse_resp2(&"*3\r\n$3\r\nSET\r\n$3\r\nkey\r\n$5\r\nvalue\r\n"[0: 33]);
    const set_command: Command = try command_executor_test_command(&router, &set_parsed);
    _ = command_execute_with_runtime_at(&engine, &runtime, &set_command, 1000u64);
    resp_value_free(&set_parsed.value);

    var parsed: RespParseResult = try parse_resp2(&"*1\r\n$6\r\nBGSAVE\r\n"[0: 16]);
    const command: Command = try command_executor_test_command(&router, &parsed);
    const reply: CommandReply = command_execute_with_runtime_at(&engine, &runtime, &command, 1000u64);
    try assert_eq_i32(reply.typ as i32, CommandReplyType.reply_simple_string as i32);
    try assert_true(command_executor_test_slice_eq(reply.data, &"Background saving scheduled"[0: 27]));
    try assert_eq_i32(reply.request_bgsave as i32, 1);
    resp_value_free(&parsed.value);

    runtime.bgsave_requested = true;
    var repeat_parsed: RespParseResult = try parse_resp2(&"*1\r\n$6\r\nBGSAVE\r\n"[0: 16]);
    const repeat_command: Command = try command_executor_test_command(&router, &repeat_parsed);
    const repeat_reply: CommandReply = command_execute_with_runtime_at(&engine, &runtime, &repeat_command, 1000u64);
    try assert_eq_i32(repeat_reply.typ as i32, CommandReplyType.reply_error as i32);
    resp_value_free(&repeat_parsed.value);

    engine_free(&engine);
    try assert_eq_i32(used_memory() as i32, 0);
}

