// util/time.uya - time helpers.

use std.time.now_ms;

export fn now_ms_safe() u64 {
    const value: u64 = now_ms() catch {
        return 0 as u64;
    };
    return value;
}

export fn now_s() u64 {
    return now_ms_safe() / (1000 as u64);
}

export fn now_us() u64 {
    return now_ms_safe() * (1000 as u64);
}
