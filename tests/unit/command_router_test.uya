use src.memory.allocator.reset_memory_stats_for_test;

fn command_router_slice_eq(a: &[byte], b: &[byte]) bool {
    if a.len != b.len { return false; }
    var i: usize = 0;
    while i < a.len {
        if a.ptr[i] != b.ptr[i] { return false; }
        i = i + 1;
    }
    return true;
}

export fn test_command_router_lookup_and_case() !void {
    const router: CommandRouter = command_router_new();
    try assert_eq_i32(command_router_count(&router) as i32, 55);

    const ping: CommandInfo = try command_router_lookup(&router, &"PING"[0: 4]);
    try assert_eq_i32(ping.cmd_type as i32, CommandType.command_ping as i32);
    try assert_eq_i32(ping.arity, -1);

    const echo: CommandInfo = try command_router_lookup(&router, &"ECHO"[0: 4]);
    try assert_eq_i32(echo.cmd_type as i32, CommandType.command_echo as i32);
    try assert_eq_i32(echo.arity, 2);

    const hello: CommandInfo = try command_router_lookup(&router, &"HELLO"[0: 5]);
    try assert_eq_i32(hello.cmd_type as i32, CommandType.command_hello as i32);
    try assert_eq_i32(hello.arity, -1);

    const subscribe: CommandInfo = try command_router_lookup(&router, &"SUBSCRIBE"[0: 9]);
    try assert_eq_i32(subscribe.cmd_type as i32, CommandType.command_subscribe as i32);
    try assert_eq_i32(subscribe.arity, -2);

    const unsubscribe: CommandInfo = try command_router_lookup(&router, &"UNSUBSCRIBE"[0: 11]);
    try assert_eq_i32(unsubscribe.cmd_type as i32, CommandType.command_unsubscribe as i32);
    try assert_eq_i32(unsubscribe.arity, -1);

    const publish: CommandInfo = try command_router_lookup(&router, &"PUBLISH"[0: 7]);
