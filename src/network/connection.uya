export fn connection_process_input_with_runtime_with_aof_and_rewrite_and_transaction_zero_copy_close_at(
    engine: &Engine,
    runtime: &CommandRuntimeInfo,
    router: &CommandRouter,
    aof: &AofWriter,
    rewrite_buf: &Sds,
    backlog: &ReplicationBacklog,
    tx: &ConnectionTransaction,
    input: &[byte],
    out: &byte,
    out_cap: usize,
    now_ms: u64,
    replicaof_requested: &bool,
    replicaof_promote: &bool,
    replicaof_host: &[byte],
    replicaof_port: &i32,
    bgsave_requested: &bool,
    rewrite_requested: &bool,
    rewrite_failed: &bool,
    close_after_out: &bool,
) !ConnectionProcessResult {
    const result_value: !ConnectionProcessResult = connection_process_input_with_runtime_with_aof_and_rewrite_and_transaction_internal_at(engine, runtime, router, aof, rewrite_buf, backlog, tx, input, out, out_cap, now_ms, replicaof_requested, replicaof_promote, replicaof_host, replicaof_port, bgsave_requested, rewrite_requested, rewrite_failed, true);
    const result: ConnectionProcessResult = result_value catch |err| {
        return err;
    };
    *close_after_out = result.close_after;
    return ConnectionProcessResult{
        response_len: result.response_len,
        response_head_len: result.response_head_len,
        zero_copy_body: result.zero_copy_body,
        zero_copy_tail_len: result.zero_copy_tail_len,
        consumed: result.consumed,
        close_after: result.close_after,
        request_replicaof: result.request_replicaof,
        replicaof_promote: result.replicaof_promote,
        request_bgsave: result.request_bgsave,
        request_aof_rewrite: result.request_aof_rewrite,
    };
}

fn connection_process_input_with_runtime_with_aof_and_rewrite_and_transaction_internal_at(
    engine: &Engine,
    runtime: &CommandRuntimeInfo,
    router: &CommandRouter,
    aof: &AofWriter,
    rewrite_buf: &Sds,
    backlog: &ReplicationBacklog,
    tx: &ConnectionTransaction,
    input: &[byte],
    out: &byte,
    out_cap: usize,
    now_ms: u64,
    replicaof_requested: &bool,
    replicaof_promote: &bool,
    replicaof_host: &[byte],
    replicaof_port: &i32,
    bgsave_requested: &bool,
    rewrite_requested: &bool,
    rewrite_failed: &bool,
    zero_copy_bulk: bool,
) !ConnectionProcessResult {
    const parsed_result: !RespParseResult = connection_parse_input_for_protocol(tx, input);
    const parsed: RespParseResult = parsed_result catch |err| {
        if err == error.RespIncomplete {
            return error.ConnectionIncomplete;
        }
        const reply: CommandReply = connection_error_reply(&"ERR protocol error"[0: 18]);
        const n: usize = try connection_encode_reply_with_protocol(&reply, out, out_cap, tx.protocol_version);
        return ConnectionProcessResult{ response_len: n, consumed: input.len, close_after: true, request_replicaof: false, replicaof_promote: false, request_bgsave: false, request_aof_rewrite: false };
    };

    const command_result: !Command = command_from_resp(router, &parsed.value);
    const command: Command = command_result catch |err| {
        var reply: CommandReply = connection_error_reply(&"ERR invalid request"[0: 19]);
        if err == error.CommandUnknown {
            reply = connection_error_reply(&"ERR unknown command"[0: 19]);
        }
        if err == error.CommandWrongArity {
            reply = connection_error_reply(&"ERR wrong number of arguments"[0: 29]);
        }
        const n: usize = try connection_encode_reply_with_protocol(&reply, out, out_cap, tx.protocol_version);
        resp_value_free(&parsed.value);
        return ConnectionProcessResult{ response_len: n, consumed: parsed.consumed, close_after: false, request_replicaof: false, replicaof_promote: false, request_bgsave: false, request_aof_rewrite: false };
    };

    if tx.active {
        if command.info.cmd_type == CommandType.command_multi {
            const nested_reply: CommandReply = connection_error_reply(&"ERR MULTI calls can not be nested"[0: 33]);
            const nested_n: usize = try connection_encode_reply_with_protocol(&nested_reply, out, out_cap, tx.protocol_version);
            resp_value_free(&parsed.value);
            return ConnectionProcessResult{ response_len: nested_n, consumed: parsed.consumed, close_after: false, request_replicaof: false, replicaof_promote: false, request_bgsave: false, request_aof_rewrite: false };
        }
        if command.info.cmd_type == CommandType.command_watch {
            const watch_reply: CommandReply = connection_error_reply(&"ERR WATCH inside MULTI is not allowed"[0: 37]);
            const watch_n: usize = try connection_encode_reply_with_protocol(&watch_reply, out, out_cap, tx.protocol_version);
            resp_value_free(&parsed.value);
            return ConnectionProcessResult{ response_len: watch_n, consumed: parsed.consumed, close_after: false, request_replicaof: false, replicaof_promote: false, request_bgsave: false, request_aof_rewrite: false };
        }
        if command.info.cmd_type == CommandType.command_unwatch {
            const unwatch_reply: CommandReply = connection_error_reply(&"ERR UNWATCH inside MULTI is not allowed"[0: 39]);
            const unwatch_n: usize = try connection_encode_reply_with_protocol(&unwatch_reply, out, out_cap, tx.protocol_version);
            resp_value_free(&parsed.value);
            return ConnectionProcessResult{ response_len: unwatch_n, consumed: parsed.consumed, close_after: false, request_replicaof: false, replicaof_promote: false, request_bgsave: false, request_aof_rewrite: false };
        }
        if command.info.cmd_type == CommandType.command_hello {
            const hello_reply: CommandReply = connection_error_reply(&"ERR HELLO inside MULTI is not allowed"[0: 37]);
            const hello_n: usize = try connection_encode_reply_with_protocol(&hello_reply, out, out_cap, tx.protocol_version);
            resp_value_free(&parsed.value);
            return ConnectionProcessResult{ response_len: hello_n, consumed: parsed.consumed, close_after: false, request_replicaof: false, replicaof_promote: false, request_bgsave: false, request_aof_rewrite: false };
        }
        if command.info.cmd_type == CommandType.command_client {
            const client_tx_reply: CommandReply = connection_error_reply(&"ERR CLIENT command inside MULTI is not allowed"[0: 46]);
            const client_tx_n: usize = try connection_encode_reply_with_protocol(&client_tx_reply, out, out_cap, tx.protocol_version);
            resp_value_free(&parsed.value);
            return ConnectionProcessResult{ response_len: client_tx_n, consumed: parsed.consumed, close_after: false, request_replicaof: false, replicaof_promote: false, request_bgsave: false, request_aof_rewrite: false };
        }
        if command.info.cmd_type == CommandType.command_subscribe || command.info.cmd_type == CommandType.command_unsubscribe || command.info.cmd_type == CommandType.command_publish {
            const pubsub_tx_reply: CommandReply = connection_error_reply(&"ERR pubsub command inside MULTI is not allowed"[0: 46]);
            const pubsub_tx_n: usize = try connection_encode_reply_with_protocol(&pubsub_tx_reply, out, out_cap, tx.protocol_version);
            resp_value_free(&parsed.value);
            return ConnectionProcessResult{ response_len: pubsub_tx_n, consumed: parsed.consumed, close_after: false, request_replicaof: false, replicaof_promote: false, request_bgsave: false, request_aof_rewrite: false };
        }
        if command.info.cmd_type == CommandType.command_discard {
            connection_transaction_reset(tx);
            const discard_reply: CommandReply = connection_make_reply(CommandReplyType.reply_simple_string, &"OK"[0: 2], 0);
            const discard_n: usize = try connection_encode_reply_with_protocol(&discard_reply, out, out_cap, tx.protocol_version);
            resp_value_free(&parsed.value);
            return ConnectionProcessResult{ response_len: discard_n, consumed: parsed.consumed, close_after: false, request_replicaof: false, replicaof_promote: false, request_bgsave: false, request_aof_rewrite: false };
        }
        if command.info.cmd_type == CommandType.command_exec {
            if !connection_transaction_watches_match(tx, engine) {
                var aborted_reply: CommandReply = connection_raw_reply_owned(&"*-1\r\n"[0: 5]);
                connection_transaction_reset(tx);
                const aborted_n: usize = try connection_encode_reply_with_protocol(&aborted_reply, out, out_cap, tx.protocol_version);
                command_reply_cleanup(&aborted_reply);
                resp_value_free(&parsed.value);
                return ConnectionProcessResult{ response_len: aborted_n, consumed: parsed.consumed, close_after: false, request_replicaof: false, replicaof_promote: false, request_bgsave: false, request_aof_rewrite: false };
            }
            var exec_close_after: bool = false;
            var exec_replicaof_requested: bool = false;
            var exec_replicaof_promote: bool = false;
            var exec_replicaof_host: [byte: 64] = [];
            var exec_replicaof_port: i32 = 0;
            var exec_bgsave_requested: bool = false;
            var exec_rewrite_requested: bool = false;
            var exec_reply: CommandReply = connection_transaction_execute_at(
                engine,
                runtime,
                router,
                aof,
                rewrite_buf,
                backlog,
                tx,
                now_ms,
                &exec_close_after,
                &exec_replicaof_requested,
                &exec_replicaof_promote,
                exec_replicaof_host[0: 64],
                &exec_replicaof_port,
                &exec_bgsave_requested,
                &exec_rewrite_requested,
                rewrite_failed,
                tx.protocol_version,
            );
            connection_transaction_reset(tx);
            const exec_n: usize = try connection_encode_reply_with_protocol(&exec_reply, out, out_cap, tx.protocol_version);
            command_reply_cleanup(&exec_reply);
            resp_value_free(&parsed.value);
            return ConnectionProcessResult{
                response_len: exec_n,
                consumed: parsed.consumed,
                close_after: exec_close_after,
                request_replicaof: exec_replicaof_requested,
                replicaof_promote: exec_replicaof_promote,
                request_bgsave: exec_bgsave_requested,
                request_aof_rewrite: exec_rewrite_requested,
            };
        }

        _ = connection_transaction_queue_command(tx, input[0: parsed.consumed]) catch {
            const oom_reply: CommandReply = connection_error_reply(&"ERR out of memory"[0: 17]);
            const oom_n: usize = try connection_encode_reply_with_protocol(&oom_reply, out, out_cap, tx.protocol_version);
            resp_value_free(&parsed.value);
            return ConnectionProcessResult{ response_len: oom_n, consumed: parsed.consumed, close_after: false, request_replicaof: false, replicaof_promote: false, request_bgsave: false, request_aof_rewrite: false };
        };
        const queued_reply: CommandReply = connection_make_reply(CommandReplyType.reply_simple_string, &"QUEUED"[0: 6], 0);
        const queued_n: usize = try connection_encode_reply_with_protocol(&queued_reply, out, out_cap, tx.protocol_version);
        resp_value_free(&parsed.value);
        return ConnectionProcessResult{ response_len: queued_n, consumed: parsed.consumed, close_after: false, request_replicaof: false, replicaof_promote: false, request_bgsave: false, request_aof_rewrite: false };
    }

    if command.info.cmd_type == CommandType.command_hello {
        const hello_reply: CommandReply = connection_handle_hello(tx, &command);
        const hello_n: usize = try connection_encode_reply_with_protocol(&hello_reply, out, out_cap, tx.protocol_version);
        resp_value_free(&parsed.value);
        return ConnectionProcessResult{ response_len: hello_n, consumed: parsed.consumed, close_after: false, request_replicaof: false, replicaof_promote: false, request_bgsave: false, request_aof_rewrite: false };
    }
    if command.info.cmd_type == CommandType.command_client {
        var client_reply: CommandReply = connection_handle_client(tx, &command);
        const client_n: usize = try connection_encode_reply_with_protocol(&client_reply, out, out_cap, tx.protocol_version);
        command_reply_cleanup(&client_reply);
        resp_value_free(&parsed.value);
        return ConnectionProcessResult{ response_len: client_n, consumed: parsed.consumed, close_after: false, request_replicaof: false, replicaof_promote: false, request_bgsave: false, request_aof_rewrite: false };
    }
    if command.info.cmd_type == CommandType.command_subscribe {
        var subscribe_reply: CommandReply = connection_handle_subscribe(tx, &command);
        const subscribe_n: usize = try connection_encode_reply_with_protocol(&subscribe_reply, out, out_cap, tx.protocol_version);
        command_reply_cleanup(&subscribe_reply);
        resp_value_free(&parsed.value);
        return ConnectionProcessResult{ response_len: subscribe_n, consumed: parsed.consumed, close_after: false, request_replicaof: false, replicaof_promote: false, request_bgsave: false, request_aof_rewrite: false };
    }
    if command.info.cmd_type == CommandType.command_unsubscribe {
        var unsubscribe_reply: CommandReply = connection_handle_unsubscribe(tx, &command);
        const unsubscribe_n: usize = try connection_encode_reply_with_protocol(&unsubscribe_reply, out, out_cap, tx.protocol_version);
        command_reply_cleanup(&unsubscribe_reply);
        resp_value_free(&parsed.value);
        return ConnectionProcessResult{ response_len: unsubscribe_n, consumed: parsed.consumed, close_after: false, request_replicaof: false, replicaof_promote: false, request_bgsave: false, request_aof_rewrite: false };
    }
    if command.info.cmd_type == CommandType.command_publish {
        const publish_reply: CommandReply = connection_handle_publish(&command);
        const publish_n: usize = try connection_encode_reply_with_protocol(&publish_reply, out, out_cap, tx.protocol_version);
        resp_value_free(&parsed.value);
        return ConnectionProcessResult{ response_len: publish_n, consumed: parsed.consumed, close_after: false, request_replicaof: false, replicaof_promote: false, request_bgsave: false, request_aof_rewrite: false };
    }
    if command.info.cmd_type == CommandType.command_multi {
        connection_transaction_clear_queue(tx);
        tx.active = true;
        const multi_reply: CommandReply = connection_make_reply(CommandReplyType.reply_simple_string, &"OK"[0: 2], 0);
        const multi_n: usize = try connection_encode_reply_with_protocol(&multi_reply, out, out_cap, tx.protocol_version);
        resp_value_free(&parsed.value);
        return ConnectionProcessResult{ response_len: multi_n, consumed: parsed.consumed, close_after: false, request_replicaof: false, replicaof_promote: false, request_bgsave: false, request_aof_rewrite: false };
    }
    if command.info.cmd_type == CommandType.command_watch {
        var watch_index: usize = 1;
        while watch_index < command.argc {
            const key: &[byte] = command_arg_data(&command, watch_index) catch {
                const watch_wrong_arity: CommandReply = connection_error_reply(&"ERR wrong number of arguments"[0: 29]);
                const watch_wrong_n: usize = try connection_encode_reply_with_protocol(&watch_wrong_arity, out, out_cap, tx.protocol_version);
                resp_value_free(&parsed.value);
                return ConnectionProcessResult{ response_len: watch_wrong_n, consumed: parsed.consumed, close_after: false, request_replicaof: false, replicaof_promote: false, request_bgsave: false, request_aof_rewrite: false };
            };
            _ = connection_transaction_watch_key(tx, engine, key) catch {
                const watch_oom: CommandReply = connection_error_reply(&"ERR out of memory"[0: 17]);
                const watch_oom_n: usize = try connection_encode_reply_with_protocol(&watch_oom, out, out_cap, tx.protocol_version);
                resp_value_free(&parsed.value);
                return ConnectionProcessResult{ response_len: watch_oom_n, consumed: parsed.consumed, close_after: false, request_replicaof: false, replicaof_promote: false, request_bgsave: false, request_aof_rewrite: false };
            };
            watch_index = watch_index + 1;
        }
        const watch_ok: CommandReply = connection_make_reply(CommandReplyType.reply_simple_string, &"OK"[0: 2], 0);
        const watch_ok_n: usize = try connection_encode_reply_with_protocol(&watch_ok, out, out_cap, tx.protocol_version);
        resp_value_free(&parsed.value);
        return ConnectionProcessResult{ response_len: watch_ok_n, consumed: parsed.consumed, close_after: false, request_replicaof: false, replicaof_promote: false, request_bgsave: false, request_aof_rewrite: false };
    }
    if command.info.cmd_type == CommandType.command_unwatch {
        connection_transaction_clear_watches(tx);
        const unwatch_ok: CommandReply = connection_make_reply(CommandReplyType.reply_simple_string, &"OK"[0: 2], 0);
        const unwatch_ok_n: usize = try connection_encode_reply_with_protocol(&unwatch_ok, out, out_cap, tx.protocol_version);
        resp_value_free(&parsed.value);
        return ConnectionProcessResult{ response_len: unwatch_ok_n, consumed: parsed.consumed, close_after: false, request_replicaof: false, replicaof_promote: false, request_bgsave: false, request_aof_rewrite: false };
    }
    if command.info.cmd_type == CommandType.command_exec {
        const exec_without_multi: CommandReply = connection_error_reply(&"ERR EXEC without MULTI"[0: 22]);
        const exec_without_multi_n: usize = try connection_encode_reply_with_protocol(&exec_without_multi, out, out_cap, tx.protocol_version);
        resp_value_free(&parsed.value);
        return ConnectionProcessResult{ response_len: exec_without_multi_n, consumed: parsed.consumed, close_after: false, request_replicaof: false, replicaof_promote: false, request_bgsave: false, request_aof_rewrite: false };
    }
    if command.info.cmd_type == CommandType.command_discard {
        const discard_without_multi: CommandReply = connection_error_reply(&"ERR DISCARD without MULTI"[0: 25]);
        const discard_without_multi_n: usize = try connection_encode_reply_with_protocol(&discard_without_multi, out, out_cap, tx.protocol_version);
        resp_value_free(&parsed.value);
        return ConnectionProcessResult{ response_len: discard_without_multi_n, consumed: parsed.consumed, close_after: false, request_replicaof: false, replicaof_promote: false, request_bgsave: false, request_aof_rewrite: false };
    }

    var reply: CommandReply = command_execute_with_runtime_at(engine, runtime, &command, now_ms);
    if aof != null && connection_should_append_aof(&command, &reply) {
        _ = aof_append_command_at(aof, &command, input[0: parsed.consumed], now_ms) catch {
            const aof_reply: CommandReply = connection_error_reply(&"ERR AOF append failed"[0: 21]);
            const aof_n: usize = try connection_encode_reply_with_protocol(&aof_reply, out, out_cap, tx.protocol_version);
            command_reply_cleanup(&reply);
            resp_value_free(&parsed.value);
            return ConnectionProcessResult{ response_len: aof_n, consumed: parsed.consumed, close_after: false, request_replicaof: false, replicaof_promote: false, request_bgsave: false, request_aof_rewrite: false };
        };
        if rewrite_buf != null && runtime.aof_rewrite_in_progress {
            _ = aof_append_command_to_sds_at(rewrite_buf, &command, input[0: parsed.consumed], now_ms) catch {
                if rewrite_failed != null {
                    *rewrite_failed = true;
                }
            };
        }
        if backlog != null && runtime.replication_role == ReplicationRole.role_master {
            _ = replication_backlog_append_command_at(backlog, &command, input[0: parsed.consumed], now_ms) catch {};
        }
    }
    const request_replicaof: bool = reply.request_replicaof;
    const promote_replicaof: bool = reply.replicaof_promote;
    if request_replicaof {
        *replicaof_requested = true;
        *replicaof_promote = promote_replicaof;
        *replicaof_port = reply.replicaof_port;
        connection_copy_replica_host(replicaof_host, reply.replicaof_host);
    }
    const request_bgsave: bool = reply.request_bgsave;
    const request_aof_rewrite: bool = reply.request_aof_rewrite;
    if request_bgsave && bgsave_requested != null {
        *bgsave_requested = true;
    }
    if request_aof_rewrite && rewrite_requested != null {
        *rewrite_requested = true;
    }
    var n: usize = 0;
    var psync_reply: CommandReply = connection_make_reply(CommandReplyType.reply_simple_string, connection_reply_empty_slice(), 0);
    var use_psync_reply: bool = false;
    if command.info.cmd_type == CommandType.command_psync && reply.typ == CommandReplyType.reply_simple_string {
        if reply.data.len >= 10 && reply.data.ptr[0] == 70 as byte {
            psync_reply = connection_build_fullresync_reply(engine, reply.data, now_ms);
            use_psync_reply = true;
        } else if reply.data.len == 8 && reply.data.ptr[0] == 67 as byte && backlog != null {
            psync_reply = connection_build_continue_reply(backlog, reply.integer as u64);
            use_psync_reply = true;
        }
    }
    if use_psync_reply {
        n = try connection_encode_reply_with_protocol(&psync_reply, out, out_cap, tx.protocol_version);
    } else {
        if zero_copy_bulk && command.info.cmd_type == CommandType.command_get && reply.typ == CommandReplyType.reply_bulk_string && reply.data.len >= CONNECTION_ZERO_COPY_BULK_MIN {
            n = try connection_encode_bulk_header(out, out_cap, reply.data.len);
            const body: &[byte] = reply.data;
            command_reply_cleanup(&reply);
            const should_close_zero_copy: bool = command.info.cmd_type == CommandType.command_quit;
            resp_value_free(&parsed.value);
            return connection_zero_copy_process_result(n, body, 2, parsed.consumed, should_close_zero_copy, request_replicaof, promote_replicaof, request_bgsave, request_aof_rewrite);
        }
        n = try connection_encode_reply_with_protocol(&reply, out, out_cap, tx.protocol_version);
    }
    command_reply_cleanup(&reply);
    if use_psync_reply {
        command_reply_cleanup(&psync_reply);
    }
    const should_close: bool = command.info.cmd_type == CommandType.command_quit;
    resp_value_free(&parsed.value);
    return ConnectionProcessResult{
        response_len: n,
        consumed: parsed.consumed,
        close_after: should_close,
        request_replicaof: request_replicaof,
        replicaof_promote: promote_replicaof,
        request_bgsave: request_bgsave,
        request_aof_rewrite: request_aof_rewrite,
    };
}

export fn connection_empty_reply() CommandReply {
    return connection_make_reply(CommandReplyType.reply_bulk_string, connection_reply_empty_slice(), 0);
}

export fn connection_shift_buffer(base: &byte, filled: &usize, consumed: usize) void {
    if consumed >= *filled {
        *filled = 0;
        return;
    }

    const remaining: usize = *filled - consumed;
    var i: usize = 0;
    while i < remaining {
        base[i] = base[consumed + i];
        i = i + 1;
    }
    *filled = remaining;
}

fn connection_send_all(fd: i32, base: &byte, total: usize) !void {
    var written: usize = 0;
    while written < total {
        const ptr: *const byte = @ptr_from_usize(@usize_from_ptr(base as &void) + written) as *const byte;
        const n: isize = sys_send(fd, ptr, total - written, 0) catch {
            return error.ConnectionIoFailed;
        };
        if n <= 0 {
            return error.ConnectionIoFailed;
        }
        written = written + (n as usize);
    }
}

fn connection_send_progress_nonblocking(fd: i32, base: &byte, total: usize, start: usize) !ConnectionSendProgress {
    var written: usize = start;
    while written < total {
        const ptr: *const byte = @ptr_from_usize(@usize_from_ptr(base as &void) + written) as *const byte;
        const n_result: !isize = sys_send(fd, ptr, total - written, 0);
        const n: isize = n_result catch |err| {
            const eid: i32 = @error_id(err) as i32;
            if eid == EAGAIN || eid == EWOULDBLOCK {
                return ConnectionSendProgress{ next_offset: written, blocked: true };
            }
            if eid == EINTR {
                continue;
            }
            return error.ConnectionIoFailed;
        };
        if n <= 0 {
            return error.ConnectionIoFailed;
        }
        written = written + (n as usize);
    }
    return ConnectionSendProgress{ next_offset: written, blocked: false };
}

fn connection_send_zero_copy_bulk_all(fd: i32, head: &byte, head_len: usize, body: &[byte], tail_len: usize) !void {
    var head_sent: usize = 0;
    var body_sent: usize = 0;
    var tail_sent: usize = 0;
    const tail: &[byte] = &"\r\n"[0: 2];
    while head_sent < head_len || body_sent < body.len || tail_sent < tail_len {
        var iov: [IOVec: 3] = [];
        var iovcnt: i32 = 0;
        if head_sent < head_len {
            iov[iovcnt as usize] = IOVec{
                iov_base: @ptr_from_usize(@usize_from_ptr(head as &void) + head_sent) as *const byte,
                iov_len: head_len - head_sent,
            };
            iovcnt = iovcnt + 1;
        }
        if body_sent < body.len {
            iov[iovcnt as usize] = IOVec{
                iov_base: @ptr_from_usize(@usize_from_ptr(body.ptr as &void) + body_sent) as *const byte,
                iov_len: body.len - body_sent,
            };
            iovcnt = iovcnt + 1;
        }
        if tail_sent < tail_len {
            iov[iovcnt as usize] = IOVec{
                iov_base: @ptr_from_usize(@usize_from_ptr(tail.ptr as &void) + tail_sent) as *const byte,
                iov_len: tail_len - tail_sent,
            };
            iovcnt = iovcnt + 1;
        }

        const wr: isize = sys_writev(fd, &iov[0], iovcnt) catch {
            return error.ConnectionIoFailed;
        };
        if wr <= 0 {
            return error.ConnectionIoFailed;
        }

        var advanced: usize = wr as usize;
        if head_sent < head_len {
            const head_remaining: usize = head_len - head_sent;
            if advanced >= head_remaining {
                head_sent = head_len;
                advanced = advanced - head_remaining;
            } else {
                head_sent = head_sent + advanced;
                advanced = 0;
            }
        }
        if advanced > 0 && body_sent < body.len {
            const body_remaining: usize = body.len - body_sent;
            if advanced >= body_remaining {
                body_sent = body.len;
                advanced = advanced - body_remaining;
            } else {
                body_sent = body_sent + advanced;
                advanced = 0;
            }
        }
        if advanced > 0 && tail_sent < tail_len {
            tail_sent = tail_sent + advanced;
        }
    }
}

fn connection_send_zero_copy_bulk_nonblocking(fd: i32, head: &byte, head_len: usize, body: &[byte], tail_len: usize) !ConnectionSendProgress {
    const total: usize = head_len + body.len + tail_len;
    const tail: &[byte] = &"\r\n"[0: 2];
    while true {
        var iov: [IOVec: 3] = [];
        var iovcnt: i32 = 0;
        if head_len > 0 {
            iov[iovcnt as usize] = IOVec{ iov_base: head as *const byte, iov_len: head_len };
            iovcnt = iovcnt + 1;
        }
        if body.len > 0 {
            iov[iovcnt as usize] = IOVec{ iov_base: body.ptr as *const byte, iov_len: body.len };
            iovcnt = iovcnt + 1;
        }
        if tail_len > 0 {
            iov[iovcnt as usize] = IOVec{ iov_base: tail.ptr as *const byte, iov_len: tail_len };
            iovcnt = iovcnt + 1;
        }
        const n_result: !isize = sys_writev(fd, &iov[0], iovcnt);
        const n: isize = n_result catch |err| {
            const eid: i32 = @error_id(err) as i32;
            if eid == EAGAIN || eid == EWOULDBLOCK {
                return ConnectionSendProgress{ next_offset: 0, blocked: true };
            }
            if eid == EINTR {
                continue;
            }
            return error.ConnectionIoFailed;
        };
        if n <= 0 {
            return error.ConnectionIoFailed;
        }
        const sent: usize = n as usize;
        if sent >= total {
            return ConnectionSendProgress{ next_offset: total, blocked: false };
        }
        return ConnectionSendProgress{ next_offset: sent, blocked: true };
    }
}

fn connection_store_pending_output(
    pending: &byte,
    pending_cap: usize,
    pending_len: &usize,
    pending_sent: &usize,
    data: &byte,
    total: usize,
    sent: usize,
) !void {
    if sent >= total {
        *pending_len = 0;
        *pending_sent = 0;
        return;
    }

    const remaining: usize = total - sent;
    if remaining > pending_cap {
        return error.ConnectionOutputTooSmall;
    }

    var i: usize = 0;
    while i < remaining {
        pending[i] = data[sent + i];
        i = i + 1;
    }
    *pending_len = remaining;
    *pending_sent = 0;
}

fn connection_store_zero_copy_pending(
    pending: &byte,
    pending_cap: usize,
    pending_len: &usize,
    pending_sent: &usize,
    head: &byte,
    head_len: usize,
    body: &[byte],
    tail_len: usize,
    sent: usize,
) !void {
    const total: usize = head_len + body.len + tail_len;
    if sent >= total {
        *pending_len = 0;
        *pending_sent = 0;
        return;
    }

    const remaining: usize = total - sent;
    if remaining > pending_cap {
        return error.ConnectionOutputTooSmall;
    }

    var copied: usize = 0;
    var offset: usize = sent;
    if offset < head_len {
        var h: usize = offset;
        while h < head_len {
            pending[copied] = head[h];
            copied = copied + 1;
            h = h + 1;
        }
        offset = head_len;
    }
    offset = offset - head_len;
    if offset < body.len {
        var b: usize = offset;
        while b < body.len {
            pending[copied] = body.ptr[b];
            copied = copied + 1;
            b = b + 1;
        }
        offset = body.len;
    }
    offset = offset - body.len;
    if offset < tail_len {
        const tail: &[byte] = &"\r\n"[0: 2];
        var t: usize = offset;
        while t < tail_len {
            pending[copied] = tail.ptr[t];
            copied = copied + 1;
            t = t + 1;
        }
    }
    *pending_len = copied;
    *pending_sent = 0;
}

fn connection_flush_pending_output(
    fd: i32,
    pending: &byte,
    pending_len: &usize,
    pending_sent: &usize,
) !bool {
    if *pending_sent >= *pending_len {
        *pending_len = 0;
        *pending_sent = 0;
        return true;
    }

    const progress: ConnectionSendProgress = try connection_send_progress_nonblocking(fd, pending, *pending_len, *pending_sent);
    *pending_sent = progress.next_offset;
    if progress.blocked {
        return false;
    }
    *pending_len = 0;
    *pending_sent = 0;
    return true;
}

fn connection_send_all_nonblocking(fd: i32, base: &byte, total: usize) !void {
    const progress: ConnectionSendProgress = try connection_send_progress_nonblocking(fd, base, total, 0);
    if progress.blocked {
        return error.ConnectionWouldBlock;
    }
}

fn connection_recv_available(fd: i32, base: &byte, cap: usize, filled: &usize) !bool {
    while true {
        if *filled >= cap {
            return error.ConnectionInputTooLarge;
        }

        const dst: *byte = @ptr_from_usize(@usize_from_ptr(base as &void) + *filled) as *byte;
        const n_result: !isize = sys_recv(fd, dst, cap - *filled, 0);
        const n: isize = n_result catch |err| {
            const eid: i32 = @error_id(err) as i32;
            if eid == EAGAIN || eid == EWOULDBLOCK {
                return true;
            }
            if eid == EINTR {
                continue;
            }
            return error.ConnectionIoFailed;
        };
        if n == 0 {
            return false;
        }
        if n < 0 {
            return error.ConnectionIoFailed;
        }
        *filled = *filled + (n as usize);
    }
}

export fn connection_handle_fd_nonblocking_with_aof(
    engine: &Engine,
    router: &CommandRouter,
    aof: &AofWriter,
    backlog: &ReplicationBacklog,
    tx: &ConnectionTransaction,
    fd: i32,
    input: &byte,
    input_cap: usize,
    filled: &usize,
    pending: &byte,
    pending_cap: usize,
    pending_len: &usize,
    pending_sent: &usize,
    close_after_write: &bool,
    replicaof_requested: &bool,
    replicaof_promote: &bool,
    replicaof_host: &[byte],
    replicaof_port: &i32,
    bgsave_requested: &bool,
    rewrite_requested: &bool,
    output: &byte,
    output_cap: usize,
) !bool {
    var runtime: CommandRuntimeInfo = command_runtime_default();
    return connection_handle_fd_nonblocking_with_runtime_with_aof(engine, &runtime, router, aof, null as &Sds, backlog, tx, fd, input, input_cap, filled, pending, pending_cap, pending_len, pending_sent, close_after_write, replicaof_requested, replicaof_promote, replicaof_host, replicaof_port, bgsave_requested, rewrite_requested, null as &bool, output, output_cap);
}

export fn connection_handle_fd_nonblocking_with_runtime_with_aof(
    engine: &Engine,
    runtime: &CommandRuntimeInfo,
    router: &CommandRouter,
    aof: &AofWriter,
    rewrite_buf: &Sds,
    backlog: &ReplicationBacklog,
    tx: &ConnectionTransaction,
    fd: i32,
    input: &byte,
    input_cap: usize,
    filled: &usize,
    pending: &byte,
    pending_cap: usize,
    pending_len: &usize,
    pending_sent: &usize,
    close_after_write: &bool,
    replicaof_requested: &bool,
    replicaof_promote: &bool,
    replicaof_host: &[byte],
    replicaof_port: &i32,
    bgsave_requested: &bool,
    rewrite_requested: &bool,
    rewrite_failed: &bool,
    output: &byte,
    output_cap: usize,
) !bool {
    tx.client_fd = fd;
    const pending_flushed: bool = try connection_flush_pending_output(fd, pending, pending_len, pending_sent);
    if !pending_flushed {
        return true;
    }
    if *close_after_write {
        *close_after_write = false;
        return false;
    }

    const open: bool = try connection_recv_available(fd, input, input_cap, filled);
    if !open {
        return false;
    }

    var close_after: bool = false;
    var can_continue: bool = true;
    while can_continue && *filled > 0 && *pending_len == 0 {
        var incomplete: bool = false;
        const result_value: !ConnectionProcessResult = connection_process_input_with_runtime_with_aof_and_rewrite_and_transaction_internal_at(
            engine,
            runtime,
            router,
            aof,
            rewrite_buf,
            backlog,
            tx,
            input[0: *filled],
            output,
            output_cap,
            now_ms_safe(),
            replicaof_requested,
            replicaof_promote,
            replicaof_host,
            replicaof_port,
            bgsave_requested,
            rewrite_requested,
            rewrite_failed,
            true,
        );
        const result: ConnectionProcessResult = result_value catch |err| {
            if err == error.ConnectionIncomplete {
                incomplete = true;
                can_continue = false;
            } else {
                return err;
            }
                ConnectionProcessResult{ response_len: 0, consumed: 0, close_after: false, request_replicaof: false, replicaof_promote: false, request_bgsave: false, request_aof_rewrite: false };
        };

        if !incomplete {
            if result.request_replicaof {
                *replicaof_requested = true;
                *replicaof_promote = result.replicaof_promote;
            }
            if result.request_bgsave {
                *bgsave_requested = true;
            }
            if result.request_aof_rewrite {
                *rewrite_requested = true;
            }
            var progress: ConnectionSendProgress = ConnectionSendProgress{ next_offset: 0, blocked: false };
            if result.zero_copy_body.len > 0 {
                progress = try connection_send_zero_copy_bulk_nonblocking(fd, output, result.response_head_len, result.zero_copy_body, result.zero_copy_tail_len);
            } else {
                progress = try connection_send_progress_nonblocking(fd, output, result.response_len, 0);
            }
            connection_shift_buffer(input, filled, result.consumed);
            if progress.blocked {
                if result.zero_copy_body.len > 0 {
                    try connection_store_zero_copy_pending(pending, pending_cap, pending_len, pending_sent, output, result.response_head_len, result.zero_copy_body, result.zero_copy_tail_len, progress.next_offset);
                } else {
                    try connection_store_pending_output(pending, pending_cap, pending_len, pending_sent, output, result.response_len, progress.next_offset);
                }
                *close_after_write = result.close_after;
                can_continue = false;
            } else {
                close_after = result.close_after;
                if close_after {
                    can_continue = false;
                }
            }
        }
    }

    return !close_after;
}

export fn connection_handle_fd_nonblocking(
    engine: &Engine,
    router: &CommandRouter,
    fd: i32,
    input: &byte,
    input_cap: usize,
    filled: &usize,
    pending: &byte,
    pending_cap: usize,
    pending_len: &usize,
    pending_sent: &usize,
    close_after_write: &bool,
    output: &byte,
    output_cap: usize,
) !bool {
    var replicaof_requested: bool = false;
    var replicaof_promote: bool = false;
    var replicaof_host: [byte: 64] = [];
    var replicaof_port: i32 = 0;
    var bgsave_requested: bool = false;
    var rewrite_requested: bool = false;
    var tx: ConnectionTransaction = connection_transaction_new();
    defer {
        connection_transaction_reset(&tx);
    }
    return connection_handle_fd_nonblocking_with_aof(engine, router, null as &AofWriter, null as &ReplicationBacklog, &tx, fd, input, input_cap, filled, pending, pending_cap, pending_len, pending_sent, close_after_write, &replicaof_requested, &replicaof_promote, replicaof_host[0: 64], &replicaof_port, &bgsave_requested, &rewrite_requested, output, output_cap);
}

export fn connection_handle_fd(engine: &Engine, router: &CommandRouter, fd: i32) !void {
    try connection_handle_fd_with_aof(engine, router, null as &AofWriter, fd);
}

export fn connection_handle_fd_with_aof(engine: &Engine, router: &CommandRouter, aof: &AofWriter, fd: i32) !void {
    var input: [byte: 8192] = [];
    var output: [byte: 8192] = [];
    var filled: usize = 0;
    var close_after: bool = false;
    var tx: ConnectionTransaction = connection_transaction_new();
    tx.client_fd = fd;
    defer {
        connection_transaction_reset(&tx);
    }

    while !close_after {
        if filled >= 8192 {
            return error.ConnectionInputTooLarge;
        }

        const n: isize = sys_recv(fd, &input[filled] as *byte, 8192 - filled, 0) catch {
            return error.ConnectionIoFailed;
        };
        if n <= 0 {
            return;
        }
        filled = filled + (n as usize);

        var can_continue: bool = true;
        while can_continue && filled > 0 {
            var incomplete: bool = false;
            var runtime: CommandRuntimeInfo = command_runtime_default();
            var replicaof_requested: bool = false;
            var replicaof_promote: bool = false;
            var replicaof_host: [byte: 64] = [];
            var replicaof_port: i32 = 0;
            var bgsave_requested: bool = false;
            var rewrite_requested: bool = false;
            const result_aof_value: !ConnectionProcessResult = connection_process_input_with_runtime_with_aof_and_rewrite_and_transaction_internal_at(
                engine,
                &runtime,
                router,
                aof,
                null as &Sds,
                null as &ReplicationBacklog,
                &tx,
                input[0: filled],
                &output[0],
                8192,
                now_ms_safe(),
                &replicaof_requested,
                &replicaof_promote,
                replicaof_host[0: 64],
                &replicaof_port,
                &bgsave_requested,
                &rewrite_requested,
                null as &bool,
                true,
            );
            const result: ConnectionProcessResult = result_aof_value catch |err| {
                if err == error.ConnectionIncomplete {
                    incomplete = true;
                    can_continue = false;
                } else {
                    return error.ConnectionIoFailed;
                }
                ConnectionProcessResult{ response_len: 0, consumed: 0, close_after: false, request_replicaof: false, replicaof_promote: false, request_bgsave: false, request_aof_rewrite: false };
            };

            if !incomplete {
                if result.zero_copy_body.len > 0 {
                    try connection_send_zero_copy_bulk_all(fd, &output[0], result.response_head_len, result.zero_copy_body, result.zero_copy_tail_len);
                } else {
                    try connection_send_all(fd, &output[0], result.response_len);
                }
                connection_shift_buffer(&input[0], &filled, result.consumed);
                close_after = result.close_after;
                if close_after {
                    can_continue = false;
                }
            }
        }
    }
}
