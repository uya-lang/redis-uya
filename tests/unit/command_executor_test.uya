    resp_value_free(&hset_update_parsed.value);

    var hget_missing_parsed: RespParseResult = try parse_resp2(&"*3\r\n$4\r\nHGET\r\n$4\r\nhash\r\n$7\r\nmissing\r\n"[0: 37]);
