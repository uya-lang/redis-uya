fn network_connection_slice_eq(a: &[byte], b: &[byte]) bool {
    if a.len != b.len { return false; }
    var i: usize = 0;
    while i < a.len {
        if a.ptr[i] != b.ptr[i] { return false; }
        i = i + 1;
    }
    return true;
}

fn network_connection_contains(haystack: &[byte], needle: &[byte]) bool {
    if needle.len == 0 {
        return true;
    }
    if haystack.len < needle.len {
        return false;
    }
    var start: usize = 0;
    while start + needle.len <= haystack.len {
        var matched: bool = true;
        var i: usize = 0;
        while i < needle.len {
            if haystack.ptr[start + i] != needle.ptr[i] {
                matched = false;
                break;
            }
            i = i + 1;
        }
        if matched {
            return true;
        }
        start = start + 1;
    }
    return false;
}

fn network_connection_reply(typ: CommandReplyType, data: &[byte], integer: i64) CommandReply {
    return CommandReply{
        typ: typ,
        data: data,
        integer: integer,
    };
}

export fn test_connection_encode_resp_replies() !void {
    var out: [byte: 128] = [];

    const simple: CommandReply = network_connection_reply(CommandReplyType.reply_simple_string, &"OK"[0: 2], 0);
    const simple_len: usize = try connection_encode_reply(&simple, &out[0], 128);
    try assert_true(network_connection_slice_eq(out[0: simple_len], &"+OK\r\n"[0: 5]));

    const integer: CommandReply = network_connection_reply(CommandReplyType.reply_integer, (null as &byte)[0: 0], -2);
    const integer_len: usize = try connection_encode_reply(&integer, &out[0], 128);
    try assert_true(network_connection_slice_eq(out[0: integer_len], &":-2\r\n"[0: 5]));

    const bulk: CommandReply = network_connection_reply(CommandReplyType.reply_bulk_string, &"value"[0: 5], 0);
    const bulk_len: usize = try connection_encode_reply(&bulk, &out[0], 128);
    try assert_true(network_connection_slice_eq(out[0: bulk_len], &"$5\r\nvalue\r\n"[0: 11]));

    const null_bulk: CommandReply = network_connection_reply(CommandReplyType.reply_null_bulk, (null as &byte)[0: 0], 0);
    const null_len: usize = try connection_encode_reply(&null_bulk, &out[0], 128);
    try assert_true(network_connection_slice_eq(out[0: null_len], &"$-1\r\n"[0: 5]));
}

export fn test_connection_process_ping_set_get_quit() !void {
    reset_memory_stats_for_test();
    const router: CommandRouter = command_router_new();
    var engine: Engine = engine_new();
    var out: [byte: 256] = [];

    const ping: ConnectionProcessResult = try connection_process_input_at(&engine, &router, &"*1\r\n$4\r\nPING\r\n"[0: 14], &out[0], 256, 1000u64);
    try assert_true(network_connection_slice_eq(out[0: ping.response_len], &"+PONG\r\n"[0: 7]));
    try assert_eq_i32(ping.close_after as i32, 0);

    const set_result: ConnectionProcessResult = try connection_process_input_at(&engine, &router, &"*3\r\n$3\r\nSET\r\n$3\r\nkey\r\n$5\r\nvalue\r\n"[0: 33], &out[0], 256, 1000u64);
    try assert_true(network_connection_slice_eq(out[0: set_result.response_len], &"+OK\r\n"[0: 5]));

    const get_result: ConnectionProcessResult = try connection_process_input_at(&engine, &router, &"*2\r\n$3\r\nGET\r\n$3\r\nkey\r\n"[0: 22], &out[0], 256, 1000u64);
    try assert_true(network_connection_slice_eq(out[0: get_result.response_len], &"$5\r\nvalue\r\n"[0: 11]));

    const echo_result: ConnectionProcessResult = try connection_process_input_at(&engine, &router, &"*2\r\n$4\r\nECHO\r\n$2\r\nhi\r\n"[0: 22], &out[0], 256, 1000u64);
    try assert_true(network_connection_slice_eq(out[0: echo_result.response_len], &"$2\r\nhi\r\n"[0: 8]));

    const type_result: ConnectionProcessResult = try connection_process_input_at(&engine, &router, &"*2\r\n$4\r\nTYPE\r\n$3\r\nkey\r\n"[0: 23], &out[0], 256, 1000u64);
    try assert_true(network_connection_slice_eq(out[0: type_result.response_len], &"+string\r\n"[0: 9]));

    const dbsize_result: ConnectionProcessResult = try connection_process_input_at(&engine, &router, &"*1\r\n$6\r\nDBSIZE\r\n"[0: 16], &out[0], 256, 1000u64);
    try assert_true(network_connection_slice_eq(out[0: dbsize_result.response_len], &":1\r\n"[0: 4]));

    const pexpire_result: ConnectionProcessResult = try connection_process_input_at(&engine, &router, &"*3\r\n$7\r\nPEXPIRE\r\n$3\r\nkey\r\n$4\r\n1500\r\n"[0: 36], &out[0], 256, 1000u64);
    try assert_true(network_connection_slice_eq(out[0: pexpire_result.response_len], &":1\r\n"[0: 4]));

    const pttl_result: ConnectionProcessResult = try connection_process_input_at(&engine, &router, &"*2\r\n$4\r\nPTTL\r\n$3\r\nkey\r\n"[0: 23], &out[0], 256, 1000u64);
    try assert_true(network_connection_slice_eq(out[0: pttl_result.response_len], &":1500\r\n"[0: 7]));

    const persist_result: ConnectionProcessResult = try connection_process_input_at(&engine, &router, &"*2\r\n$7\r\nPERSIST\r\n$3\r\nkey\r\n"[0: 26], &out[0], 256, 1000u64);
    try assert_true(network_connection_slice_eq(out[0: persist_result.response_len], &":1\r\n"[0: 4]));

    const persisted_pttl_result: ConnectionProcessResult = try connection_process_input_at(&engine, &router, &"*2\r\n$4\r\nPTTL\r\n$3\r\nkey\r\n"[0: 23], &out[0], 256, 1000u64);
    try assert_true(network_connection_slice_eq(out[0: persisted_pttl_result.response_len], &":-1\r\n"[0: 5]));

    const bgsave_result: ConnectionProcessResult = try connection_process_input_at(&engine, &router, &"*1\r\n$6\r\nBGSAVE\r\n"[0: 16], &out[0], 256, 1000u64);
    try assert_true(network_connection_slice_eq(out[0: bgsave_result.response_len], &"+Background saving scheduled\r\n"[0: 30]));
    try assert_eq_i32(bgsave_result.request_bgsave as i32, 1);

    const hset_result: ConnectionProcessResult = try connection_process_input_at(&engine, &router, &"*4\r\n$4\r\nHSET\r\n$4\r\nhash\r\n$5\r\nfield\r\n$5\r\nvalue\r\n"[0: 46], &out[0], 256, 1000u64);
    try assert_true(network_connection_slice_eq(out[0: hset_result.response_len], &":1\r\n"[0: 4]));

    const hget_result: ConnectionProcessResult = try connection_process_input_at(&engine, &router, &"*3\r\n$4\r\nHGET\r\n$4\r\nhash\r\n$5\r\nfield\r\n"[0: 35], &out[0], 256, 1000u64);
    try assert_true(network_connection_slice_eq(out[0: hget_result.response_len], &"$5\r\nvalue\r\n"[0: 11]));

    const lpush_result: ConnectionProcessResult = try connection_process_input_at(&engine, &router, &"*5\r\n$5\r\nLPUSH\r\n$4\r\nlist\r\n$1\r\na\r\n$1\r\nb\r\n$1\r\nc\r\n"[0: 47], &out[0], 256, 1000u64);
    try assert_true(network_connection_slice_eq(out[0: lpush_result.response_len], &":3\r\n"[0: 4]));

    const lrange_result: ConnectionProcessResult = try connection_process_input_at(&engine, &router, &"*4\r\n$6\r\nLRANGE\r\n$4\r\nlist\r\n$1\r\n0\r\n$2\r\n-1\r\n"[0: 41], &out[0], 256, 1000u64);
    try assert_true(network_connection_slice_eq(out[0: lrange_result.response_len], &"*3\r\n$1\r\nc\r\n$1\r\nb\r\n$1\r\na\r\n"[0: 25]));

    const lpop_result: ConnectionProcessResult = try connection_process_input_at(&engine, &router, &"*2\r\n$4\r\nLPOP\r\n$4\r\nlist\r\n"[0: 24], &out[0], 256, 1000u64);
    try assert_true(network_connection_slice_eq(out[0: lpop_result.response_len], &"$1\r\nc\r\n"[0: 7]));

    const sadd_result: ConnectionProcessResult = try connection_process_input_at(&engine, &router, &"*4\r\n$4\r\nSADD\r\n$3\r\nset\r\n$1\r\na\r\n$1\r\nb\r\n"[0: 37], &out[0], 256, 1000u64);
    try assert_true(network_connection_slice_eq(out[0: sadd_result.response_len], &":2\r\n"[0: 4]));

    const smembers_result: ConnectionProcessResult = try connection_process_input_at(&engine, &router, &"*2\r\n$8\r\nSMEMBERS\r\n$3\r\nset\r\n"[0: 27], &out[0], 256, 1000u64);
    try assert_true(out[0] == 42 as byte);

    const zadd_result: ConnectionProcessResult = try connection_process_input_at(&engine, &router, &"*6\r\n$4\r\nZADD\r\n$4\r\nzset\r\n$1\r\n2\r\n$1\r\nb\r\n$1\r\n1\r\n$1\r\na\r\n"[0: 52], &out[0], 256, 1000u64);
    try assert_true(network_connection_slice_eq(out[0: zadd_result.response_len], &":2\r\n"[0: 4]));

    const zrange_result: ConnectionProcessResult = try connection_process_input_at(&engine, &router, &"*4\r\n$6\r\nZRANGE\r\n$4\r\nzset\r\n$1\r\n0\r\n$2\r\n-1\r\n"[0: 41], &out[0], 256, 1000u64);
    try assert_true(network_connection_slice_eq(out[0: zrange_result.response_len], &"*2\r\n$1\r\na\r\n$1\r\nb\r\n"[0: 18]));

    const zrem_result: ConnectionProcessResult = try connection_process_input_at(&engine, &router, &"*3\r\n$4\r\nZREM\r\n$4\r\nzset\r\n$1\r\na\r\n"[0: 31], &out[0], 256, 1000u64);
    try assert_true(network_connection_slice_eq(out[0: zrem_result.response_len], &":1\r\n"[0: 4]));

    const zrange_tail_result: ConnectionProcessResult = try connection_process_input_at(&engine, &router, &"*4\r\n$6\r\nZRANGE\r\n$4\r\nzset\r\n$1\r\n0\r\n$2\r\n-1\r\n"[0: 41], &out[0], 256, 1000u64);
    try assert_true(network_connection_slice_eq(out[0: zrange_tail_result.response_len], &"*1\r\n$1\r\nb\r\n"[0: 11]));

    const scan_result: ConnectionProcessResult = try connection_process_input_at(&engine, &router, &"*4\r\n$4\r\nSCAN\r\n$1\r\n0\r\n$5\r\nCOUNT\r\n$1\r\n3\r\n"[0: 39], &out[0], 256, 1000u64);
    try assert_true(network_connection_slice_eq(out[0: scan_result.response_len], &"*2\r\n$1\r\n3\r\n*3\r\n$4\r\nhash\r\n$3\r\nkey\r\n$4\r\nlist\r\n"[0: 44]));

    const scan_tail_result: ConnectionProcessResult = try connection_process_input_at(&engine, &router, &"*4\r\n$4\r\nSCAN\r\n$1\r\n3\r\n$5\r\nCOUNT\r\n$1\r\n3\r\n"[0: 39], &out[0], 256, 1000u64);
    try assert_true(network_connection_slice_eq(out[0: scan_tail_result.response_len], &"*2\r\n$1\r\n0\r\n*2\r\n$3\r\nset\r\n$4\r\nzset\r\n"[0: 34]));

    const info_result: ConnectionProcessResult = try connection_process_input_at(&engine, &router, &"*2\r\n$4\r\nINFO\r\n$6\r\nserver\r\n"[0: 26], &out[0], 256, 1000u64);
    try assert_eq_i32(info_result.response_len as i32, 108);
    try assert_true(network_connection_slice_eq(out[0: info_result.response_len], &"$100\r\n# Server\r\nredis_uya_version:0.1.0-dev\r\nredis_mode:standalone\r\ntcp_port:6379\r\nuptime_in_seconds:0\r\n\r\n\r\n"[0: 108]));

    const replicaof_result: ConnectionProcessResult = try connection_process_input_at(&engine, &router, &"*3\r\n$9\r\nREPLICAOF\r\n$9\r\n127.0.0.1\r\n$4\r\n6381\r\n"[0: 44], &out[0], 256, 1000u64);
    try assert_true(network_connection_slice_eq(out[0: replicaof_result.response_len], &"+OK\r\n"[0: 5]));
    try assert_eq_i32(replicaof_result.request_replicaof as i32, 1);
    try assert_eq_i32(replicaof_result.replicaof_promote as i32, 0);

    const config_result: ConnectionProcessResult = try connection_process_input_at(&engine, &router, &"*3\r\n$6\r\nCONFIG\r\n$3\r\nGET\r\n$4\r\nport\r\n"[0: 35], &out[0], 256, 1000u64);
    try assert_eq_i32(config_result.response_len as i32, 24);
    try assert_true(network_connection_slice_eq(out[0: config_result.response_len], &"*2\r\n$4\r\nport\r\n$4\r\n6379\r\n"[0: 24]));

    const rewrite_result: ConnectionProcessResult = try connection_process_input_at(&engine, &router, &"*1\r\n$12\r\nBGREWRITEAOF\r\n"[0: 23], &out[0], 256, 1000u64);
    try assert_true(network_connection_slice_eq(out[0: rewrite_result.response_len], &"+Background AOF rewrite scheduled\r\n"[0: 35]));
    try assert_eq_i32(rewrite_result.request_aof_rewrite as i32, 1);

    const quit: ConnectionProcessResult = try connection_process_input_at(&engine, &router, &"*1\r\n$4\r\nQUIT\r\n"[0: 14], &out[0], 256, 1000u64);
    try assert_true(network_connection_slice_eq(out[0: quit.response_len], &"+OK\r\n"[0: 5]));
    try assert_eq_i32(quit.close_after as i32, 1);

    engine_free(&engine);
    try assert_eq_i32(used_memory() as i32, 0);
}

export fn test_connection_zero_copy_get_reply_metadata() !void {
    reset_memory_stats_for_test();
    const router: CommandRouter = command_router_new();
    var engine: Engine = engine_new();
    var out: [byte: 256] = [];
    const value: &[byte] = &"abcdefghijklmnopqrstuvwxyzABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789ABCDEFGH"[0: 70];

    const set_result: ConnectionProcessResult = try connection_process_input_at(&engine, &router, &"*3\r\n$3\r\nSET\r\n$3\r\nkey\r\n$70\r\nabcdefghijklmnopqrstuvwxyzABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789ABCDEFGH\r\n"[0: 99], &out[0], 256, 1000u64);
    try assert_true(network_connection_slice_eq(out[0: set_result.response_len], &"+OK\r\n"[0: 5]));

    const get_result: ConnectionProcessResult = try connection_process_input_zero_copy_for_test_at(&engine, &router, &"*2\r\n$3\r\nGET\r\n$3\r\nkey\r\n"[0: 22], &out[0], 256, 1000u64);
    try assert_eq_i32(get_result.response_len as i32, 77);
    try assert_eq_i32(get_result.response_head_len as i32, 5);
    try assert_eq_i32(get_result.zero_copy_tail_len as i32, 2);
    try assert_true(network_connection_slice_eq(out[0: get_result.response_head_len], &"$70\r\n"[0: 5]));
    try assert_true(network_connection_slice_eq(get_result.zero_copy_body, value));

    engine_free(&engine);
    try assert_eq_i32(used_memory() as i32, 0);
}

export fn test_connection_process_maxmemory() !void {
    reset_memory_stats_for_test();
    const router: CommandRouter = command_router_new();
    var engine: Engine = engine_new();
    var runtime: CommandRuntimeInfo = command_runtime_default();
    runtime.config.maxmemory = 1;
    var out: [byte: 256] = [];

    const set_result: ConnectionProcessResult = try connection_process_input_with_runtime_at(&engine, &runtime, &router, &"*3\r\n$3\r\nSET\r\n$3\r\nkey\r\n$5\r\nvalue\r\n"[0: 33], &out[0], 256, 1000u64);
    try assert_true(network_connection_contains(out[0: set_result.response_len], &"OOM command not allowed"[0: 23]));

    runtime.config.maxmemory = 0;
    const get_result: ConnectionProcessResult = try connection_process_input_with_runtime_at(&engine, &runtime, &router, &"*2\r\n$3\r\nGET\r\n$3\r\nkey\r\n"[0: 22], &out[0], 256, 1000u64);
    try assert_true(network_connection_slice_eq(out[0: get_result.response_len], &"$-1\r\n"[0: 5]));

    engine_free(&engine);
    try assert_eq_i32(used_memory() as i32, 0);
}

export fn test_connection_process_error_paths() !void {
    reset_memory_stats_for_test();
    const router: CommandRouter = command_router_new();
    var engine: Engine = engine_new();
    var out: [byte: 256] = [];

    const unknown: ConnectionProcessResult = try connection_process_input_at(&engine, &router, &"*1\r\n$7\r\nMISSING\r\n"[0: 17], &out[0], 256, 1000u64);
    try assert_true(network_connection_slice_eq(out[0: 1], &"-"[0: 1]));
    try assert_eq_i32(unknown.close_after as i32, 0);

    const bad_proto: ConnectionProcessResult = try connection_process_input_at(&engine, &router, &"?bad\r\n"[0: 6], &out[0], 256, 1000u64);
    try assert_true(network_connection_slice_eq(out[0: bad_proto.response_len], &"-ERR protocol error\r\n"[0: 21]));
    try assert_eq_i32(bad_proto.close_after as i32, 1);

    var saw_incomplete: bool = false;
    _ = connection_process_input_at(&engine, &router, &"$6\r\nfoo"[0: 7], &out[0], 256, 1000u64) catch |err| {
        if err == error.ConnectionIncomplete {
            saw_incomplete = true;
        }
        return;
    };
    try assert_true(saw_incomplete);

    engine_free(&engine);
    try assert_eq_i32(used_memory() as i32, 0);
}

export fn test_connection_process_multi_exec_discard() !void {
    reset_memory_stats_for_test();
    const router: CommandRouter = command_router_new();
    var engine: Engine = engine_new();
    var tx: ConnectionTransaction = connection_transaction_new();
    defer {
        connection_transaction_reset(&tx);
    }
    var out: [byte: 256] = [];

    const multi: ConnectionProcessResult = try connection_process_input_with_transaction_at(&engine, &router, &tx, &"*1\r\n$5\r\nMULTI\r\n"[0: 15], &out[0], 256, 1000u64);
    try assert_true(network_connection_slice_eq(out[0: multi.response_len], &"+OK\r\n"[0: 5]));

    const queued_set: ConnectionProcessResult = try connection_process_input_with_transaction_at(&engine, &router, &tx, &"*3\r\n$3\r\nSET\r\n$3\r\nkey\r\n$5\r\nvalue\r\n"[0: 33], &out[0], 256, 1000u64);
    try assert_true(network_connection_slice_eq(out[0: queued_set.response_len], &"+QUEUED\r\n"[0: 9]));

    const queued_get: ConnectionProcessResult = try connection_process_input_with_transaction_at(&engine, &router, &tx, &"*2\r\n$3\r\nGET\r\n$3\r\nkey\r\n"[0: 22], &out[0], 256, 1000u64);
    try assert_true(network_connection_slice_eq(out[0: queued_get.response_len], &"+QUEUED\r\n"[0: 9]));

    const exec: ConnectionProcessResult = try connection_process_input_with_transaction_at(&engine, &router, &tx, &"*1\r\n$4\r\nEXEC\r\n"[0: 14], &out[0], 256, 1000u64);
    try assert_true(network_connection_slice_eq(out[0: exec.response_len], &"*2\r\n+OK\r\n$5\r\nvalue\r\n"[0: 20]));

    const multi_discard: ConnectionProcessResult = try connection_process_input_with_transaction_at(&engine, &router, &tx, &"*1\r\n$5\r\nMULTI\r\n"[0: 15], &out[0], 256, 1000u64);
    try assert_true(network_connection_slice_eq(out[0: multi_discard.response_len], &"+OK\r\n"[0: 5]));

    const discard_queue: ConnectionProcessResult = try connection_process_input_with_transaction_at(&engine, &router, &tx, &"*3\r\n$3\r\nSET\r\n$5\r\nother\r\n$3\r\nabc\r\n"[0: 33], &out[0], 256, 1000u64);
    try assert_true(network_connection_slice_eq(out[0: discard_queue.response_len], &"+QUEUED\r\n"[0: 9]));

    const discard: ConnectionProcessResult = try connection_process_input_with_transaction_at(&engine, &router, &tx, &"*1\r\n$7\r\nDISCARD\r\n"[0: 17], &out[0], 256, 1000u64);
    try assert_true(network_connection_slice_eq(out[0: discard.response_len], &"+OK\r\n"[0: 5]));

    const get_other: ConnectionProcessResult = try connection_process_input_with_transaction_at(&engine, &router, &tx, &"*2\r\n$3\r\nGET\r\n$5\r\nother\r\n"[0: 24], &out[0], 256, 1000u64);
    try assert_true(network_connection_slice_eq(out[0: get_other.response_len], &"$-1\r\n"[0: 5]));

    const exec_without_multi: ConnectionProcessResult = try connection_process_input_with_transaction_at(&engine, &router, &tx, &"*1\r\n$4\r\nEXEC\r\n"[0: 14], &out[0], 256, 1000u64);
    try assert_true(network_connection_slice_eq(out[0: exec_without_multi.response_len], &"-ERR EXEC without MULTI\r\n"[0: 25]));

    const discard_without_multi: ConnectionProcessResult = try connection_process_input_with_transaction_at(&engine, &router, &tx, &"*1\r\n$7\r\nDISCARD\r\n"[0: 17], &out[0], 256, 1000u64);
    try assert_true(network_connection_slice_eq(out[0: discard_without_multi.response_len], &"-ERR DISCARD without MULTI\r\n"[0: 28]));

    const multi_again: ConnectionProcessResult = try connection_process_input_with_transaction_at(&engine, &router, &tx, &"*1\r\n$5\r\nMULTI\r\n"[0: 15], &out[0], 256, 1000u64);
    try assert_true(network_connection_slice_eq(out[0: multi_again.response_len], &"+OK\r\n"[0: 5]));

    const nested_multi: ConnectionProcessResult = try connection_process_input_with_transaction_at(&engine, &router, &tx, &"*1\r\n$5\r\nMULTI\r\n"[0: 15], &out[0], 256, 1000u64);
    try assert_true(network_connection_slice_eq(out[0: nested_multi.response_len], &"-ERR MULTI calls can not be nested\r\n"[0: 36]));

    const empty_exec: ConnectionProcessResult = try connection_process_input_with_transaction_at(&engine, &router, &tx, &"*1\r\n$4\r\nEXEC\r\n"[0: 14], &out[0], 256, 1000u64);
    try assert_true(network_connection_slice_eq(out[0: empty_exec.response_len], &"*0\r\n"[0: 4]));

    engine_free(&engine);
    try assert_eq_i32(used_memory() as i32, 0);
}

export fn test_connection_process_watch_unwatch() !void {
    reset_memory_stats_for_test();
    const router: CommandRouter = command_router_new();
    var engine: Engine = engine_new();
    var tx: ConnectionTransaction = connection_transaction_new();
    defer {
        connection_transaction_reset(&tx);
    }
    var out: [byte: 256] = [];

    const watch: ConnectionProcessResult = try connection_process_input_with_transaction_at(&engine, &router, &tx, &"*2\r\n$5\r\nWATCH\r\n$7\r\nwatched\r\n"[0: 28], &out[0], 256, 1000u64);
    try assert_true(network_connection_slice_eq(out[0: watch.response_len], &"+OK\r\n"[0: 5]));
    try assert_eq_i32(engine_watch_client_count(&engine) as i32, 1);

    const multi: ConnectionProcessResult = try connection_process_input_with_transaction_at(&engine, &router, &tx, &"*1\r\n$5\r\nMULTI\r\n"[0: 15], &out[0], 256, 1000u64);
    try assert_true(network_connection_slice_eq(out[0: multi.response_len], &"+OK\r\n"[0: 5]));

    const watch_inside_multi: ConnectionProcessResult = try connection_process_input_with_transaction_at(&engine, &router, &tx, &"*2\r\n$5\r\nWATCH\r\n$7\r\nwatched\r\n"[0: 28], &out[0], 256, 1000u64);
    try assert_true(network_connection_slice_eq(out[0: watch_inside_multi.response_len], &"-ERR WATCH inside MULTI is not allowed\r\n"[0: 40]));

    const queued_set: ConnectionProcessResult = try connection_process_input_with_transaction_at(&engine, &router, &tx, &"*3\r\n$3\r\nSET\r\n$7\r\nwatched\r\n$3\r\ntxn\r\n"[0: 37], &out[0], 256, 1000u64);
    try assert_true(network_connection_slice_eq(out[0: queued_set.response_len], &"+QUEUED\r\n"[0: 9]));

    const outside_set: ConnectionProcessResult = try connection_process_input_at(&engine, &router, &"*3\r\n$3\r\nSET\r\n$7\r\nwatched\r\n$7\r\noutside\r\n"[0: 41], &out[0], 256, 1000u64);
    try assert_true(network_connection_slice_eq(out[0: outside_set.response_len], &"+OK\r\n"[0: 5]));

    const exec_abort: ConnectionProcessResult = try connection_process_input_with_transaction_at(&engine, &router, &tx, &"*1\r\n$4\r\nEXEC\r\n"[0: 14], &out[0], 256, 1000u64);
    try assert_true(network_connection_slice_eq(out[0: exec_abort.response_len], &"*-1\r\n"[0: 5]));
    try assert_eq_i32(engine_watch_client_count(&engine) as i32, 0);

    const get_outside: ConnectionProcessResult = try connection_process_input_at(&engine, &router, &"*2\r\n$3\r\nGET\r\n$7\r\nwatched\r\n"[0: 26], &out[0], 256, 1000u64);
    try assert_true(network_connection_slice_eq(out[0: get_outside.response_len], &"$7\r\noutside\r\n"[0: 13]));

    const watch_again: ConnectionProcessResult = try connection_process_input_with_transaction_at(&engine, &router, &tx, &"*2\r\n$5\r\nWATCH\r\n$7\r\nwatched\r\n"[0: 28], &out[0], 256, 1000u64);
    try assert_true(network_connection_slice_eq(out[0: watch_again.response_len], &"+OK\r\n"[0: 5]));
    try assert_eq_i32(engine_watch_client_count(&engine) as i32, 1);

    const unwatch: ConnectionProcessResult = try connection_process_input_with_transaction_at(&engine, &router, &tx, &"*1\r\n$7\r\nUNWATCH\r\n"[0: 17], &out[0], 256, 1000u64);
    try assert_true(network_connection_slice_eq(out[0: unwatch.response_len], &"+OK\r\n"[0: 5]));
    try assert_eq_i32(engine_watch_client_count(&engine) as i32, 0);

    const multi_again: ConnectionProcessResult = try connection_process_input_with_transaction_at(&engine, &router, &tx, &"*1\r\n$5\r\nMULTI\r\n"[0: 15], &out[0], 256, 1000u64);
    try assert_true(network_connection_slice_eq(out[0: multi_again.response_len], &"+OK\r\n"[0: 5]));

    const unwatch_inside_multi: ConnectionProcessResult = try connection_process_input_with_transaction_at(&engine, &router, &tx, &"*1\r\n$7\r\nUNWATCH\r\n"[0: 17], &out[0], 256, 1000u64);
    try assert_true(network_connection_slice_eq(out[0: unwatch_inside_multi.response_len], &"-ERR UNWATCH inside MULTI is not allowed\r\n"[0: 42]));

    const queued_set_again: ConnectionProcessResult = try connection_process_input_with_transaction_at(&engine, &router, &tx, &"*3\r\n$3\r\nSET\r\n$7\r\nwatched\r\n$2\r\nok\r\n"[0: 36], &out[0], 256, 1000u64);
    try assert_true(network_connection_slice_eq(out[0: queued_set_again.response_len], &"+QUEUED\r\n"[0: 9]));

    const outside_set_again: ConnectionProcessResult = try connection_process_input_at(&engine, &router, &"*3\r\n$3\r\nSET\r\n$7\r\nwatched\r\n$5\r\nother\r\n"[0: 39], &out[0], 256, 1000u64);
    try assert_true(network_connection_slice_eq(out[0: outside_set_again.response_len], &"+OK\r\n"[0: 5]));

    const exec_ok: ConnectionProcessResult = try connection_process_input_with_transaction_at(&engine, &router, &tx, &"*1\r\n$4\r\nEXEC\r\n"[0: 14], &out[0], 256, 1000u64);
    try assert_true(network_connection_slice_eq(out[0: exec_ok.response_len], &"*1\r\n+OK\r\n"[0: 9]));
    try assert_eq_i32(engine_watch_client_count(&engine) as i32, 0);

    const get_ok: ConnectionProcessResult = try connection_process_input_at(&engine, &router, &"*2\r\n$3\r\nGET\r\n$7\r\nwatched\r\n"[0: 26], &out[0], 256, 1000u64);
    try assert_true(network_connection_slice_eq(out[0: get_ok.response_len], &"$2\r\nok\r\n"[0: 8]));

    engine_free(&engine);
    try assert_eq_i32(used_memory() as i32, 0);
}

export fn test_connection_process_resp3_hello() !void {
    reset_memory_stats_for_test();
    const router: CommandRouter = command_router_new();
    var engine: Engine = engine_new();
    var tx: ConnectionTransaction = connection_transaction_new();
    defer {
        connection_transaction_reset(&tx);
    }
    var out: [byte: 512] = [];

    const hello3: ConnectionProcessResult = try connection_process_input_with_transaction_at(&engine, &router, &tx, &"*2\r\n$5\r\nHELLO\r\n$1\r\n3\r\n"[0: 22], &out[0], 512, 1000u64);
    try assert_true(network_connection_slice_eq(out[0: hello3.response_len], &"%7\r\n$6\r\nserver\r\n$9\r\nredis-uya\r\n$7\r\nversion\r\n$9\r\n0.1.0-dev\r\n$5\r\nproto\r\n:3\r\n$2\r\nid\r\n:0\r\n$4\r\nmode\r\n$10\r\nstandalone\r\n$4\r\nrole\r\n$6\r\nmaster\r\n$7\r\nmodules\r\n*0\r\n"[0: 152]));

    const missing_resp3: ConnectionProcessResult = try connection_process_input_with_transaction_at(&engine, &router, &tx, &"*2\r\n$3\r\nGET\r\n$7\r\nmissing\r\n"[0: 26], &out[0], 512, 1000u64);
    try assert_true(network_connection_slice_eq(out[0: missing_resp3.response_len], &"_\r\n"[0: 3]));

    const hello2: ConnectionProcessResult = try connection_process_input_with_transaction_at(&engine, &router, &tx, &"*2\r\n$5\r\nHELLO\r\n$1\r\n2\r\n"[0: 22], &out[0], 512, 1000u64);
    try assert_true(network_connection_slice_eq(out[0: hello2.response_len], &"*14\r\n$6\r\nserver\r\n$9\r\nredis-uya\r\n$7\r\nversion\r\n$9\r\n0.1.0-dev\r\n$5\r\nproto\r\n:2\r\n$2\r\nid\r\n:0\r\n$4\r\nmode\r\n$10\r\nstandalone\r\n$4\r\nrole\r\n$6\r\nmaster\r\n$7\r\nmodules\r\n*0\r\n"[0: 153]));

    const missing_resp2: ConnectionProcessResult = try connection_process_input_with_transaction_at(&engine, &router, &tx, &"*2\r\n$3\r\nGET\r\n$7\r\nmissing\r\n"[0: 26], &out[0], 512, 1000u64);
    try assert_true(network_connection_slice_eq(out[0: missing_resp2.response_len], &"$-1\r\n"[0: 5]));

    const bad_hello: ConnectionProcessResult = try connection_process_input_with_transaction_at(&engine, &router, &tx, &"*2\r\n$5\r\nHELLO\r\n$1\r\n4\r\n"[0: 22], &out[0], 512, 1000u64);
    try assert_true(network_connection_slice_eq(out[0: bad_hello.response_len], &"-NOPROTO unsupported protocol version\r\n"[0: 39]));

    engine_free(&engine);
    try assert_eq_i32(used_memory() as i32, 0);
}

export fn test_connection_process_client_commands() !void {
    reset_memory_stats_for_test();
    const router: CommandRouter = command_router_new();
    var engine: Engine = engine_new();
    var tx: ConnectionTransaction = connection_transaction_new();
    tx.client_fd = 42;
    defer {
        connection_transaction_reset(&tx);
    }
    var out: [byte: 512] = [];

    const client_id: ConnectionProcessResult = try connection_process_input_with_transaction_at(&engine, &router, &tx, &"*2\r\n$6\r\nCLIENT\r\n$2\r\nID\r\n"[0: 24], &out[0], 512, 1000u64);
    try assert_true(network_connection_slice_eq(out[0: client_id.response_len], &":42\r\n"[0: 5]));

    const get_empty: ConnectionProcessResult = try connection_process_input_with_transaction_at(&engine, &router, &tx, &"*2\r\n$6\r\nCLIENT\r\n$7\r\nGETNAME\r\n"[0: 29], &out[0], 512, 1000u64);
    try assert_true(network_connection_slice_eq(out[0: get_empty.response_len], &"$-1\r\n"[0: 5]));

    const set_name: ConnectionProcessResult = try connection_process_input_with_transaction_at(&engine, &router, &tx, &"*3\r\n$6\r\nCLIENT\r\n$7\r\nSETNAME\r\n$6\r\nworker\r\n"[0: 41], &out[0], 512, 1000u64);
    try assert_true(network_connection_slice_eq(out[0: set_name.response_len], &"+OK\r\n"[0: 5]));

    const get_name: ConnectionProcessResult = try connection_process_input_with_transaction_at(&engine, &router, &tx, &"*2\r\n$6\r\nCLIENT\r\n$7\r\nGETNAME\r\n"[0: 29], &out[0], 512, 1000u64);
    try assert_true(network_connection_slice_eq(out[0: get_name.response_len], &"$6\r\nworker\r\n"[0: 12]));

    const set_lib_name: ConnectionProcessResult = try connection_process_input_with_transaction_at(&engine, &router, &tx, &"*4\r\n$6\r\nCLIENT\r\n$7\r\nSETINFO\r\n$8\r\nLIB-NAME\r\n$14\r\nredis-uya-test\r\n"[0: 64], &out[0], 512, 1000u64);
    try assert_true(network_connection_slice_eq(out[0: set_lib_name.response_len], &"+OK\r\n"[0: 5]));

    const set_lib_ver: ConnectionProcessResult = try connection_process_input_with_transaction_at(&engine, &router, &tx, &"*4\r\n$6\r\nCLIENT\r\n$7\r\nSETINFO\r\n$7\r\nLIB-VER\r\n$5\r\n0.5.0\r\n"[0: 53], &out[0], 512, 1000u64);
    try assert_true(network_connection_slice_eq(out[0: set_lib_ver.response_len], &"+OK\r\n"[0: 5]));

    const client_info: ConnectionProcessResult = try connection_process_input_with_transaction_at(&engine, &router, &tx, &"*2\r\n$6\r\nCLIENT\r\n$4\r\nINFO\r\n"[0: 26], &out[0], 512, 1000u64);
    try assert_true(network_connection_contains(out[0: client_info.response_len], &"id=42"[0: 5]));
    try assert_true(network_connection_contains(out[0: client_info.response_len], &"name=worker"[0: 11]));
    try assert_true(network_connection_contains(out[0: client_info.response_len], &"lib-name=redis-uya-test"[0: 23]));
    try assert_true(network_connection_contains(out[0: client_info.response_len], &"lib-ver=0.5.0"[0: 13]));

    const hello_setname: ConnectionProcessResult = try connection_process_input_with_transaction_at(&engine, &router, &tx, &"*4\r\n$5\r\nHELLO\r\n$1\r\n3\r\n$7\r\nSETNAME\r\n$12\r\nhello-client\r\n"[0: 54], &out[0], 512, 1000u64);
    try assert_true(out[0] == 37 as byte);

    const get_hello_name: ConnectionProcessResult = try connection_process_input_with_transaction_at(&engine, &router, &tx, &"*2\r\n$6\r\nCLIENT\r\n$7\r\nGETNAME\r\n"[0: 29], &out[0], 512, 1000u64);
    try assert_true(network_connection_slice_eq(out[0: get_hello_name.response_len], &"$12\r\nhello-client\r\n"[0: 19]));

    const client_multi: ConnectionProcessResult = try connection_process_input_with_transaction_at(&engine, &router, &tx, &"*1\r\n$5\r\nMULTI\r\n"[0: 15], &out[0], 512, 1000u64);
    try assert_true(network_connection_slice_eq(out[0: client_multi.response_len], &"+OK\r\n"[0: 5]));

    const client_inside_multi: ConnectionProcessResult = try connection_process_input_with_transaction_at(&engine, &router, &tx, &"*2\r\n$6\r\nCLIENT\r\n$2\r\nID\r\n"[0: 24], &out[0], 512, 1000u64);
    try assert_true(network_connection_slice_eq(out[0: client_inside_multi.response_len], &"-ERR CLIENT command inside MULTI is not allowed\r\n"[0: 49]));

    const discard: ConnectionProcessResult = try connection_process_input_with_transaction_at(&engine, &router, &tx, &"*1\r\n$7\r\nDISCARD\r\n"[0: 17], &out[0], 512, 1000u64);
    try assert_true(network_connection_slice_eq(out[0: discard.response_len], &"+OK\r\n"[0: 5]));

    engine_free(&engine);
    try assert_eq_i32(used_memory() as i32, 0);
}

export fn test_connection_process_pubsub_commands() !void {
    reset_memory_stats_for_test();
    connection_pubsub_reset_for_test();
    const router: CommandRouter = command_router_new();
    var engine: Engine = engine_new();
    var tx: ConnectionTransaction = connection_transaction_new();
    defer {
        connection_transaction_reset(&tx);
        connection_pubsub_reset_for_test();
    }
    var out: [byte: 256] = [];

    const subscribe: ConnectionProcessResult = try connection_process_input_with_transaction_at(&engine, &router, &tx, &"*2\r\n$9\r\nSUBSCRIBE\r\n$5\r\nchan1\r\n"[0: 30], &out[0], 256, 1000u64);
    try assert_true(network_connection_slice_eq(out[0: subscribe.response_len], &"*3\r\n$9\r\nsubscribe\r\n$5\r\nchan1\r\n:1\r\n"[0: 34]));

    const publish: ConnectionProcessResult = try connection_process_input_with_transaction_at(&engine, &router, &tx, &"*3\r\n$7\r\nPUBLISH\r\n$5\r\nchan1\r\n$5\r\nhello\r\n"[0: 39], &out[0], 256, 1000u64);
    try assert_true(network_connection_slice_eq(out[0: publish.response_len], &":0\r\n"[0: 4]));

    const unsubscribe: ConnectionProcessResult = try connection_process_input_with_transaction_at(&engine, &router, &tx, &"*2\r\n$11\r\nUNSUBSCRIBE\r\n$5\r\nchan1\r\n"[0: 33], &out[0], 256, 1000u64);
    try assert_true(network_connection_slice_eq(out[0: unsubscribe.response_len], &"*3\r\n$11\r\nunsubscribe\r\n$5\r\nchan1\r\n:0\r\n"[0: 37]));

    const unsubscribe_all: ConnectionProcessResult = try connection_process_input_with_transaction_at(&engine, &router, &tx, &"*1\r\n$11\r\nUNSUBSCRIBE\r\n"[0: 22], &out[0], 256, 1000u64);
    try assert_true(network_connection_slice_eq(out[0: unsubscribe_all.response_len], &"*3\r\n$11\r\nunsubscribe\r\n$-1\r\n:0\r\n"[0: 31]));

    engine_free(&engine);
    try assert_eq_i32(used_memory() as i32, 0);
}
