use tests.unit.assert.assert_eq_i32;
use tests.unit.assert.assert_true;

use src.command.router.CommandRouter;
use src.command.router.command_router_new;
use src.persistence.aof.aof_replay_file_at;
use src.persistence.rewrite.aof_rewrite_file_at;
use src.storage.engine.Engine;
use src.storage.engine.engine_new;
use src.storage.engine.engine_free;
use src.storage.engine.set_key;
use src.storage.engine.set_key_expire_at;
use src.storage.engine.get_key_expire_at;
use src.storage.engine.lookup_key_at;
use src.storage.object.ListRangeView;
use src.storage.object.RedisObject;
use src.storage.object.ObjectType;
use src.storage.object.create_string_object;
use src.storage.object.create_hash_object;
use src.storage.object.create_list_object;
use src.storage.object.create_set_object;
use src.storage.object.create_zset_object;
use src.storage.object.hash_object_set_field;
use src.storage.object.hash_object_get_field;
use src.storage.object.list_object_push_head;
use src.storage.object.list_object_range;
use src.storage.object.set_object_add_member;
use src.storage.object.set_object_len;
use src.storage.object.set_object_remove_member;
use src.storage.object.zset_object_add_member;
use src.storage.object.zset_object_range_reply;
use src.storage.object.zset_object_get_score;
use src.storage.object.list_object_len;
use src.storage.object.object_free;
use src.memory.allocator.used_memory;
use src.memory.allocator.reset_memory_stats_for_test;
use libc.unlink;

fn rewrite_test_slice_eq(a: &[byte], b: &[byte]) bool {
    if a.len != b.len { return false; }
    var i: usize = 0;
    while i < a.len {
        if a.ptr[i] != b.ptr[i] { return false; }
        i = i + 1;
    }
    return true;
}

export fn test_aof_rewrite_roundtrip_current_types() !void {
    reset_memory_stats_for_test();
    const path: &const byte = "build/test-aof-rewrite.aof";
    _ = unlink(path);

    var engine: Engine = engine_new();

    const str_obj: &RedisObject = try create_string_object(&"value"[0: 5]);
    try set_key(&engine, &"str"[0: 3], str_obj);
    try set_key_expire_at(&engine, &"str"[0: 3], 5000u64);

    const hash_obj: &RedisObject = try create_hash_object();
    _ = try hash_object_set_field(hash_obj, &"field1"[0: 6], &"one"[0: 3]);
    _ = try hash_object_set_field(hash_obj, &"field2"[0: 6], &"two"[0: 3]);
    try set_key(&engine, &"hash"[0: 4], hash_obj);

    const list_obj: &RedisObject = try create_list_object();
    _ = try list_object_push_head(list_obj, &"a"[0: 1]);
    _ = try list_object_push_head(list_obj, &"b"[0: 1]);
    _ = try list_object_push_head(list_obj, &"c"[0: 1]);
    try set_key(&engine, &"list"[0: 4], list_obj);

    const set_obj: &RedisObject = try create_set_object();
    _ = try set_object_add_member(set_obj, &"a"[0: 1]);
    _ = try set_object_add_member(set_obj, &"b"[0: 1]);
    try set_key(&engine, &"set"[0: 3], set_obj);

    const zset_obj: &RedisObject = try create_zset_object();
    _ = try zset_object_add_member(zset_obj, 2, &"b"[0: 1]);
    _ = try zset_object_add_member(zset_obj, 1, &"a"[0: 1]);
    try set_key(&engine, &"zset"[0: 4], zset_obj);

    try aof_rewrite_file_at(path, &engine, 1000u64);
    engine_free(&engine);

    const router: CommandRouter = command_router_new();
    var replay_engine: Engine = engine_new();
    try aof_replay_file_at(path, &replay_engine, &router, 2000u64);

    const str_found: &RedisObject = try lookup_key_at(&replay_engine, &"str"[0: 3], 2000u64);
    try assert_true(rewrite_test_slice_eq(str_found.value.buf[0: str_found.value.len], &"value"[0: 5]));
    try assert_eq_i32((try get_key_expire_at(&replay_engine, &"str"[0: 3])) as i32, 5000);

    const hash_found: &RedisObject = try lookup_key_at(&replay_engine, &"hash"[0: 4], 2000u64);
    try assert_eq_i32(hash_found.obj_type as i32, ObjectType.object_hash as i32);
    const field1: &RedisObject = try hash_object_get_field(hash_found, &"field1"[0: 6]);
    const field2: &RedisObject = try hash_object_get_field(hash_found, &"field2"[0: 6]);
    try assert_true(rewrite_test_slice_eq(field1.value.buf[0: field1.value.len], &"one"[0: 3]));
    try assert_true(rewrite_test_slice_eq(field2.value.buf[0: field2.value.len], &"two"[0: 3]));

    const list_found: &RedisObject = try lookup_key_at(&replay_engine, &"list"[0: 4], 2000u64);
    const view: ListRangeView = try list_object_range(list_found, 0, -1);
    try assert_eq_i32(view.count as i32, 3);
    try assert_true(rewrite_test_slice_eq(view.head.value.value.buf[0: view.head.value.value.len], &"c"[0: 1]));
    try assert_true(rewrite_test_slice_eq(view.head.next.value.value.buf[0: view.head.next.value.value.len], &"b"[0: 1]));
    try assert_true(rewrite_test_slice_eq(view.head.next.next.value.value.buf[0: view.head.next.next.value.value.len], &"a"[0: 1]));

    const set_found: &RedisObject = try lookup_key_at(&replay_engine, &"set"[0: 3], 2000u64);
    try assert_eq_i32((try set_object_len(set_found)) as i32, 2);
    try assert_eq_i32((try set_object_remove_member(set_found, &"a"[0: 1])) as i32, 1);
    try assert_eq_i32((try set_object_remove_member(set_found, &"b"[0: 1])) as i32, 1);

    const zset_found: &RedisObject = try lookup_key_at(&replay_engine, &"zset"[0: 4], 2000u64);
    const zrange: &RedisObject = try zset_object_range_reply(zset_found, 0, -1);
    try assert_eq_i32((try list_object_len(zrange)) as i32, 2);
    try assert_true(rewrite_test_slice_eq(zrange.list_head.value.value.buf[0: zrange.list_head.value.value.len], &"a"[0: 1]));
    try assert_true(rewrite_test_slice_eq(zrange.list_head.next.value.value.buf[0: zrange.list_head.next.value.value.len], &"b"[0: 1]));
    try assert_eq_i32((try zset_object_get_score(zset_found, &"a"[0: 1])) as i32, 1);
    try assert_eq_i32((try zset_object_get_score(zset_found, &"b"[0: 1])) as i32, 2);
    object_free(zrange);

    engine_free(&replay_engine);
    _ = unlink(path);
    try assert_eq_i32(used_memory() as i32, 0);
}
