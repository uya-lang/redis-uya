export error ConnectionIncomplete;
export error ConnectionOutputTooSmall;
export error ConnectionInputTooLarge;
export error ConnectionIoFailed;
export error ConnectionWouldBlock;

export struct ConnectionProcessResult {
    response_len: usize,
    response_head_len: usize,
    zero_copy_body: &[byte],
    zero_copy_tail_len: usize,
    consumed: usize,
    close_after: bool,
    request_replicaof: bool,
    replicaof_promote: bool,
    request_bgsave: bool,
    request_aof_rewrite: bool,
}

export struct ConnectionTransaction {
    active: bool,
    queue: &RedisObject,
    queue_count: usize,
    watched: &RedisObject,
    watch_registered: bool,
    watch_engine: &Engine,
    protocol_version: i32,
    client_fd: i32,
    client_name_len: usize,
    client_name: [byte: 64],
    client_lib_name_len: usize,
    client_lib_name: [byte: 64],
    client_lib_ver_len: usize,
    client_lib_ver: [byte: 64],
    pubsub_count: usize,
}

struct ConnectionSendProgress {
    next_offset: usize,
    blocked: bool,
}

const CONNECTION_PUBSUB_MAX_SUBSCRIPTIONS: usize = 128;
const CONNECTION_PUBSUB_CHANNEL_MAX: usize = 64;
const CONNECTION_CLIENT_NAME_MAX: usize = 64;
const CONNECTION_CLIENT_INFO_MAX: usize = 64;
const CONNECTION_ZERO_COPY_BULK_MIN: usize = 64;

struct ConnectionPubSubSubscription {
    active: bool,
    fd: i32,
    channel_len: usize,
    channel: [byte: CONNECTION_PUBSUB_CHANNEL_MAX],
    protocol_version: i32,
}

var connection_pubsub_subscriptions: [ConnectionPubSubSubscription: CONNECTION_PUBSUB_MAX_SUBSCRIPTIONS] = [];

fn connection_transaction_empty() ConnectionTransaction {
    return ConnectionTransaction{
        active: false,
        queue: null as &RedisObject,
        queue_count: 0,
        watched: null as &RedisObject,
        watch_registered: false,
        watch_engine: null as &Engine,
        protocol_version: 2,
        client_fd: -1,
        client_name_len: 0,
        client_name: [],
        client_lib_name_len: 0,
        client_lib_name: [],
        client_lib_ver_len: 0,
        client_lib_ver: [],
        pubsub_count: 0,
    };
}

export fn connection_transaction_new() ConnectionTransaction {
    return connection_transaction_empty();
}

export fn connection_transaction_reset(tx: &ConnectionTransaction) void {
    if tx == null {
        return;
    }
    if tx.queue != null {
        object_free(tx.queue);
    }
    connection_transaction_clear_watches(tx);
    tx.active = false;
    tx.queue = null as &RedisObject;
    tx.queue_count = 0;
}

fn connection_transaction_clear_queue(tx: &ConnectionTransaction) void {
    if tx == null {
        return;
    }
    if tx.queue != null {
        object_free(tx.queue);
    }
    tx.active = false;
    tx.queue = null as &RedisObject;
    tx.queue_count = 0;
}

fn connection_transaction_clear_watches(tx: &ConnectionTransaction) void {
    if tx == null {
        return;
    }
    if tx.watched != null {
        object_free(tx.watched);
    }
    tx.watched = null as &RedisObject;
    if tx.watch_registered {
        engine_watch_unregister_client(tx.watch_engine);
    }
    tx.watch_registered = false;
    tx.watch_engine = null as &Engine;
}

fn connection_dummy_resp_parse_result() RespParseResult {
    return RespParseResult{
        value: RespValue{
            typ: RespType.resp_simple_string,
            data: connection_reply_empty_slice(),
            integer: 0,
            elements: null as &RespValue,
            element_count: 0,
        },
        consumed: 0,
    };
}

fn connection_dummy_command(router: &CommandRouter) Command {
    const info: CommandInfo = command_router_lookup(router, &"PING"[0: 4]) catch {
        return Command{
            info: CommandInfo{
                cmd_type: CommandType.command_ping,
                name: &"PING"[0: 4],
                arity: -1,
                flags: 0u64,
                first_key: 0,
                last_key: 0,
                key_step: 0,
            },
            argc: 0,
            request: null as &RespValue,
        };
    };
    return Command{
        info: info,
        argc: 0,
        request: null as &RespValue,
    };
}

fn connection_reply_empty_slice() &[byte] {
    return (null as &byte)[0: 0];
}

fn connection_zero_copy_process_result(
    response_head_len: usize,
    zero_copy_body: &[byte],
    zero_copy_tail_len: usize,
    consumed: usize,
    close_after: bool,
    request_replicaof: bool,
    replicaof_promote: bool,
    request_bgsave: bool,
    request_aof_rewrite: bool,
) ConnectionProcessResult {
    return ConnectionProcessResult{
        response_len: response_head_len + zero_copy_body.len + zero_copy_tail_len,
        response_head_len: response_head_len,
        zero_copy_body: zero_copy_body,
        zero_copy_tail_len: zero_copy_tail_len,
        consumed: consumed,
        close_after: close_after,
        request_replicaof: request_replicaof,
        replicaof_promote: replicaof_promote,
        request_bgsave: request_bgsave,
        request_aof_rewrite: request_aof_rewrite,
    };
}

fn connection_make_reply(typ: CommandReplyType, data: &[byte], integer: i64) CommandReply {
    return CommandReply{
        typ: typ,
        data: data,
        integer: integer,
        scan_cursor: 0u64,
        array_head: null,
        array_count: 0,
        owned_object: null,
        request_replicaof: false,
        replicaof_promote: false,
        replicaof_host: [],
        replicaof_port: 0,
        request_bgsave: false,
        request_aof_rewrite: false,
    };
}

fn connection_error_reply(data: &[byte]) CommandReply {
    return connection_make_reply(CommandReplyType.reply_error, data, 0);
}

fn connection_copy_replica_host(dst: &[byte], src: [byte: 64]) void {
    var i: usize = 0;
    while i < dst.len && i < 64 {
        dst.ptr[i] = src[i];
        i = i + 1;
    }
}

fn connection_sds_append_u64(buf: &Sds, value: u64) !void {
    if value == 0u64 {
        try sds_cat(buf, &"0"[0: 1]);
        return;
    }
    var tmp: [byte: 20] = [];
    var count: usize = 0;
    var v: u64 = value;
    while v > 0u64 {
        const digit: u64 = v % 10u64;
        tmp[count] = (48u64 + digit) as byte;
        count = count + 1;
        v = v / 10u64;
    }
    while count > 0 {
        count = count - 1;
        try sds_cat(buf, tmp[count: 1]);
    }
}

fn connection_sds_append_i64(buf: &Sds, value: i64) !void {
    if value < 0 {
        try sds_cat(buf, &"-"[0: 1]);
        try connection_sds_append_u64(buf, (0 - value) as u64);
        return;
    }
    try connection_sds_append_u64(buf, value as u64);
}

fn connection_append_bulk_node_sds(buf: &Sds, node: &ListNode, count: usize) !void {
    var current: &ListNode = node;
    var emitted: usize = 0;
    while current != null && emitted < count {
        const data: &[byte] = current.value.value.buf[0: current.value.value.len];
        try sds_cat(buf, &"$"[0: 1]);
        try connection_sds_append_u64(buf, data.len as u64);
        try sds_cat(buf, &"\r\n"[0: 2]);
        try sds_cat(buf, data);
        try sds_cat(buf, &"\r\n"[0: 2]);
        current = current.next;
        emitted = emitted + 1;
    }
}

fn connection_append_reply_sds(buf: &Sds, reply: &CommandReply, protocol_version: i32) !void {
    if reply.typ == CommandReplyType.reply_simple_string {
        try sds_cat(buf, &"+"[0: 1]);
        try sds_cat(buf, reply.data);
        try sds_cat(buf, &"\r\n"[0: 2]);
        return;
    }
    if reply.typ == CommandReplyType.reply_error {
        try sds_cat(buf, &"-"[0: 1]);
        try sds_cat(buf, reply.data);
        try sds_cat(buf, &"\r\n"[0: 2]);
        return;
    }
    if reply.typ == CommandReplyType.reply_integer {
        try sds_cat(buf, &":"[0: 1]);
        try connection_sds_append_i64(buf, reply.integer);
        try sds_cat(buf, &"\r\n"[0: 2]);
        return;
    }
    if reply.typ == CommandReplyType.reply_bulk_string {
        try sds_cat(buf, &"$"[0: 1]);
        try connection_sds_append_u64(buf, reply.data.len as u64);
        try sds_cat(buf, &"\r\n"[0: 2]);
        try sds_cat(buf, reply.data);
        try sds_cat(buf, &"\r\n"[0: 2]);
        return;
    }
    if reply.typ == CommandReplyType.reply_null_bulk {
        if protocol_version == 3 {
            try sds_cat(buf, &"_\r\n"[0: 3]);
        } else {
            try sds_cat(buf, &"$-1\r\n"[0: 5]);
        }
        return;
    }
    if reply.typ == CommandReplyType.reply_array_bulk {
        try sds_cat(buf, &"*"[0: 1]);
        try connection_sds_append_u64(buf, reply.array_count as u64);
        try sds_cat(buf, &"\r\n"[0: 2]);
        try connection_append_bulk_node_sds(buf, reply.array_head, reply.array_count);
        return;
    }
    if reply.typ == CommandReplyType.reply_scan {
        try sds_cat(buf, &"*2\r\n"[0: 4]);
        try sds_cat(buf, &"$"[0: 1]);
        try connection_sds_append_u64(buf, connection_u64_decimal_len(reply.scan_cursor) as u64);
        try sds_cat(buf, &"\r\n"[0: 2]);
        try connection_sds_append_u64(buf, reply.scan_cursor);
        try sds_cat(buf, &"\r\n"[0: 2]);
        try sds_cat(buf, &"*"[0: 1]);
        try connection_sds_append_u64(buf, reply.array_count as u64);
        try sds_cat(buf, &"\r\n"[0: 2]);
        try connection_append_bulk_node_sds(buf, reply.array_head, reply.array_count);
        return;
    }
    if reply.typ == CommandReplyType.reply_raw_bytes {
        try sds_cat(buf, reply.data);
        return;
    }
}

fn connection_transaction_ensure_queue(tx: &ConnectionTransaction) !&RedisObject {
    if tx.queue != null {
        return tx.queue;
    }
    const queue: &RedisObject = create_list_object() catch {
        return error.AllocOutOfMemory;
    };
    tx.queue = queue;
    return queue;
}

fn connection_transaction_queue_command(tx: &ConnectionTransaction, raw: &[byte]) !void {
    const queue: &RedisObject = try connection_transaction_ensure_queue(tx);
    _ = try list_object_push_tail(queue, raw);
    tx.queue_count = tx.queue_count + 1;
}

fn connection_parse_u64(data: &[byte]) !u64 {
    if data.len == 0 {
        return error.ConnectionIoFailed;
    }
    var value: u64 = 0u64;
    var i: usize = 0;
    while i < data.len {
        const ch: byte = data.ptr[i];
        if ch < 48 as byte || ch > 57 as byte {
            return error.ConnectionIoFailed;
        }
        value = value * 10u64 + ((ch - 48 as byte) as u64);
        i = i + 1;
    }
    return value;
}

fn connection_transaction_ensure_watched(tx: &ConnectionTransaction) !&RedisObject {
    if tx.watched != null {
        return tx.watched;
    }
    const watched: &RedisObject = create_hash_object() catch {
        return error.AllocOutOfMemory;
    };
    tx.watched = watched;
    return watched;
}

fn connection_transaction_watch_key(tx: &ConnectionTransaction, engine: &Engine, key: &[byte]) !void {
    const watched: &RedisObject = try connection_transaction_ensure_watched(tx);
    var version_buf: Sds = sds_empty() catch {
        return error.AllocOutOfMemory;
    };
    defer {
        sds_free(&version_buf);
    }
    try connection_sds_append_u64(&version_buf, engine_watch_version(engine, key));
    _ = try hash_object_set_field(watched, key, version_buf.buf[0: version_buf.len]);
    if !tx.watch_registered {
        engine_watch_register_client(engine);
        tx.watch_registered = true;
        tx.watch_engine = engine;
    }
}

fn connection_transaction_watches_match(tx: &ConnectionTransaction, engine: &Engine) bool {
    if tx == null || tx.watched == null {
        return true;
    }

    var iter: DictIterator = dict_iter_new();
    var entry: &DictEntry = dict_iter_next(&tx.watched.hash_dict, &iter);
    while entry != null {
        const key: &[byte] = entry.key.buf[0: entry.key.len];
        const version_obj_result: !&RedisObject = hash_object_get_field(tx.watched, key);
        const version_obj: &RedisObject = version_obj_result catch {
            return false;
        };
        const watched_version: u64 = connection_parse_u64(version_obj.value.buf[0: version_obj.value.len]) catch {
            return false;
        };
        if engine_watch_version(engine, key) != watched_version {
            return false;
        }
        entry = dict_iter_next(&tx.watched.hash_dict, &iter);
    }
    return true;
}

fn connection_raw_reply_owned(data: &[byte]) CommandReply {
    const obj: &RedisObject = create_string_object(data) catch {
        return connection_error_reply(&"ERR out of memory"[0: 17]);
    };
    var reply: CommandReply = connection_make_reply(CommandReplyType.reply_raw_bytes, obj.value.buf[0: obj.value.len], 0);
    reply.owned_object = obj;
    return reply;
}

fn connection_bulk_reply_owned(data: &[byte]) CommandReply {
    const obj: &RedisObject = create_string_object(data) catch {
        return connection_error_reply(&"ERR out of memory"[0: 17]);
    };
    var reply: CommandReply = connection_make_reply(CommandReplyType.reply_bulk_string, obj.value.buf[0: obj.value.len], 0);
    reply.owned_object = obj;
    return reply;
}

fn connection_array_reply_owned(list: &RedisObject, count: usize) CommandReply {
    var reply: CommandReply = connection_make_reply(CommandReplyType.reply_array_bulk, connection_reply_empty_slice(), 0);
    reply.array_head = list.list_head;
    reply.array_count = count;
    reply.owned_object = list;
    return reply;
}

fn connection_ascii_lower(ch: byte) byte {
    if ch >= 65 as byte && ch <= 90 as byte {
        return ch + 32 as byte;
    }
    return ch;
}

fn connection_keyword_eq(a: &[byte], b: &[byte]) bool {
    if a.len != b.len {
        return false;
    }
    var i: usize = 0;
    while i < a.len {
        if connection_ascii_lower(a.ptr[i]) != connection_ascii_lower(b.ptr[i]) {
            return false;
        }
        i = i + 1;
    }
    return true;
}

fn connection_client_id(tx: &ConnectionTransaction) i64 {
    if tx != null && tx.client_fd >= 0 {
        return tx.client_fd as i64;
    }
    return 0;
}

fn connection_client_name_valid(name: &[byte]) bool {
    var i: usize = 0;
    while i < name.len {
        const ch: byte = name.ptr[i];
        if ch <= 32 as byte || ch == 127 as byte {
            return false;
        }
        i = i + 1;
    }
    return true;
}

fn connection_client_copy_bytes(dst: &[byte], src: &[byte]) !void {
    if src.len > dst.len {
        return error.ConnectionInputTooLarge;
    }
    var i: usize = 0;
    while i < src.len {
        dst.ptr[i] = src.ptr[i];
        i = i + 1;
    }
    while i < dst.len {
        dst.ptr[i] = 0 as byte;
        i = i + 1;
    }
}

fn connection_client_store_name(tx: &ConnectionTransaction, name: &[byte]) !void {
    if name.len > CONNECTION_CLIENT_NAME_MAX || !connection_client_name_valid(name) {
        return error.ConnectionInputTooLarge;
    }
    try connection_client_copy_bytes(tx.client_name[0: CONNECTION_CLIENT_NAME_MAX], name);
    tx.client_name_len = name.len;
}

fn connection_client_store_info(tx: &ConnectionTransaction, target: &[byte], value: &[byte]) !void {
    if value.len > CONNECTION_CLIENT_INFO_MAX {
        return error.ConnectionInputTooLarge;
    }
    if connection_keyword_eq(target, &"LIB-NAME"[0: 8]) {
        try connection_client_copy_bytes(tx.client_lib_name[0: CONNECTION_CLIENT_INFO_MAX], value);
        tx.client_lib_name_len = value.len;
        return;
    }
    if connection_keyword_eq(target, &"LIB-VER"[0: 7]) {
        try connection_client_copy_bytes(tx.client_lib_ver[0: CONNECTION_CLIENT_INFO_MAX], value);
        tx.client_lib_ver_len = value.len;
        return;
    }
    return error.ConnectionInputTooLarge;
}

fn connection_client_help_reply() CommandReply {
    const reply_list: &RedisObject = create_list_object() catch {
        return connection_error_reply(&"ERR out of memory"[0: 17]);
    };
    _ = list_object_push_tail(reply_list, &"CLIENT ID"[0: 9]) catch {
        object_free(reply_list);
        return connection_error_reply(&"ERR out of memory"[0: 17]);
    };
    _ = list_object_push_tail(reply_list, &"CLIENT GETNAME"[0: 14]) catch {
        object_free(reply_list);
        return connection_error_reply(&"ERR out of memory"[0: 17]);
    };
    _ = list_object_push_tail(reply_list, &"CLIENT SETNAME <name>"[0: 21]) catch {
        object_free(reply_list);
        return connection_error_reply(&"ERR out of memory"[0: 17]);
    };
    _ = list_object_push_tail(reply_list, &"CLIENT INFO"[0: 11]) catch {
        object_free(reply_list);
        return connection_error_reply(&"ERR out of memory"[0: 17]);
    };
    _ = list_object_push_tail(reply_list, &"CLIENT LIST"[0: 11]) catch {
        object_free(reply_list);
        return connection_error_reply(&"ERR out of memory"[0: 17]);
    };
    _ = list_object_push_tail(reply_list, &"CLIENT SETINFO LIB-NAME <value>"[0: 31]) catch {
        object_free(reply_list);
        return connection_error_reply(&"ERR out of memory"[0: 17]);
    };
    _ = list_object_push_tail(reply_list, &"CLIENT SETINFO LIB-VER <value>"[0: 30]) catch {
        object_free(reply_list);
        return connection_error_reply(&"ERR out of memory"[0: 17]);
    };
    return connection_array_reply_owned(reply_list, 7);
}

fn connection_client_info_reply(tx: &ConnectionTransaction) CommandReply {
    var raw: Sds = sds_empty() catch {
        return connection_error_reply(&"ERR out of memory"[0: 17]);
    };
    defer {
        sds_free(&raw);
    }

    _ = sds_cat(&raw, &"id="[0: 3]) catch { return connection_error_reply(&"ERR out of memory"[0: 17]); };
    _ = connection_sds_append_i64(&raw, connection_client_id(tx)) catch { return connection_error_reply(&"ERR out of memory"[0: 17]); };
    _ = sds_cat(&raw, &" name="[0: 6]) catch { return connection_error_reply(&"ERR out of memory"[0: 17]); };
    if tx.client_name_len > 0 {
        _ = sds_cat(&raw, tx.client_name[0: tx.client_name_len]) catch { return connection_error_reply(&"ERR out of memory"[0: 17]); };
    }
    _ = sds_cat(&raw, &" resp="[0: 6]) catch { return connection_error_reply(&"ERR out of memory"[0: 17]); };
    _ = connection_sds_append_i64(&raw, tx.protocol_version as i64) catch { return connection_error_reply(&"ERR out of memory"[0: 17]); };
    _ = sds_cat(&raw, &" multi="[0: 7]) catch { return connection_error_reply(&"ERR out of memory"[0: 17]); };
    if tx.active {
        _ = sds_cat(&raw, &"1"[0: 1]) catch { return connection_error_reply(&"ERR out of memory"[0: 17]); };
    } else {
        _ = sds_cat(&raw, &"0"[0: 1]) catch { return connection_error_reply(&"ERR out of memory"[0: 17]); };
    }
    _ = sds_cat(&raw, &" sub="[0: 5]) catch { return connection_error_reply(&"ERR out of memory"[0: 17]); };
    _ = connection_sds_append_u64(&raw, tx.pubsub_count as u64) catch { return connection_error_reply(&"ERR out of memory"[0: 17]); };
    _ = sds_cat(&raw, &" lib-name="[0: 10]) catch { return connection_error_reply(&"ERR out of memory"[0: 17]); };
    if tx.client_lib_name_len > 0 {
        _ = sds_cat(&raw, tx.client_lib_name[0: tx.client_lib_name_len]) catch { return connection_error_reply(&"ERR out of memory"[0: 17]); };
    }
    _ = sds_cat(&raw, &" lib-ver="[0: 9]) catch { return connection_error_reply(&"ERR out of memory"[0: 17]); };
    if tx.client_lib_ver_len > 0 {
        _ = sds_cat(&raw, tx.client_lib_ver[0: tx.client_lib_ver_len]) catch { return connection_error_reply(&"ERR out of memory"[0: 17]); };
    }
    _ = sds_cat(&raw, &"\r\n"[0: 2]) catch { return connection_error_reply(&"ERR out of memory"[0: 17]); };
    return connection_bulk_reply_owned(raw.buf[0: raw.len]);
}

fn connection_handle_client(tx: &ConnectionTransaction, command: &Command) CommandReply {
    if command.argc < 2 {
        return connection_error_reply(&"ERR wrong number of arguments"[0: 29]);
    }
    const subcommand: &[byte] = command_arg_data(command, 1) catch {
        return connection_error_reply(&"ERR invalid request"[0: 19]);
    };

    if connection_keyword_eq(subcommand, &"ID"[0: 2]) {
        if command.argc != 2 {
            return connection_error_reply(&"ERR wrong number of arguments"[0: 29]);
        }
        return connection_make_reply(CommandReplyType.reply_integer, connection_reply_empty_slice(), connection_client_id(tx));
    }
    if connection_keyword_eq(subcommand, &"GETNAME"[0: 7]) {
        if command.argc != 2 {
            return connection_error_reply(&"ERR wrong number of arguments"[0: 29]);
        }
        if tx.client_name_len == 0 {
            return connection_make_reply(CommandReplyType.reply_null_bulk, connection_reply_empty_slice(), 0);
        }
        return connection_make_reply(CommandReplyType.reply_bulk_string, tx.client_name[0: tx.client_name_len], 0);
    }
    if connection_keyword_eq(subcommand, &"SETNAME"[0: 7]) {
        if command.argc != 3 {
            return connection_error_reply(&"ERR wrong number of arguments"[0: 29]);
        }
        const name: &[byte] = command_arg_data(command, 2) catch {
            return connection_error_reply(&"ERR invalid request"[0: 19]);
        };
        _ = connection_client_store_name(tx, name) catch {
            return connection_error_reply(&"ERR invalid client name"[0: 23]);
        };
        return connection_make_reply(CommandReplyType.reply_simple_string, &"OK"[0: 2], 0);
    }
    if connection_keyword_eq(subcommand, &"SETINFO"[0: 7]) {
        if command.argc != 4 {
            return connection_error_reply(&"ERR wrong number of arguments"[0: 29]);
        }
        const target: &[byte] = command_arg_data(command, 2) catch {
            return connection_error_reply(&"ERR invalid request"[0: 19]);
        };
        const value: &[byte] = command_arg_data(command, 3) catch {
            return connection_error_reply(&"ERR invalid request"[0: 19]);
        };
        _ = connection_client_store_info(tx, target, value) catch {
            return connection_error_reply(&"ERR syntax error"[0: 16]);
        };
        return connection_make_reply(CommandReplyType.reply_simple_string, &"OK"[0: 2], 0);
    }
    if connection_keyword_eq(subcommand, &"INFO"[0: 4]) || connection_keyword_eq(subcommand, &"LIST"[0: 4]) {
        if command.argc != 2 {
            return connection_error_reply(&"ERR wrong number of arguments"[0: 29]);
        }
        return connection_client_info_reply(tx);
    }
    if connection_keyword_eq(subcommand, &"HELP"[0: 4]) {
        if command.argc != 2 {
            return connection_error_reply(&"ERR wrong number of arguments"[0: 29]);
        }
        return connection_client_help_reply();
    }

    return connection_error_reply(&"ERR unknown CLIENT subcommand"[0: 29]);
}

export fn connection_pubsub_reset_for_test() void {
    var i: usize = 0;
    while i < CONNECTION_PUBSUB_MAX_SUBSCRIPTIONS {
        connection_pubsub_subscriptions[i].active = false;
        connection_pubsub_subscriptions[i].fd = -1;
        connection_pubsub_subscriptions[i].channel_len = 0;
        connection_pubsub_subscriptions[i].protocol_version = 2;
        i = i + 1;
    }
}

fn connection_pubsub_channel_eq(slot: &ConnectionPubSubSubscription, channel: &[byte]) bool {
    if slot.channel_len != channel.len {
        return false;
    }
    var i: usize = 0;
    while i < channel.len {
        if slot.channel[i] != channel.ptr[i] {
            return false;
        }
        i = i + 1;
    }
    return true;
}

fn connection_pubsub_copy_channel(slot: &ConnectionPubSubSubscription, channel: &[byte]) void {
    slot.channel_len = channel.len;
    var i: usize = 0;
    while i < channel.len && i < CONNECTION_PUBSUB_CHANNEL_MAX {
        slot.channel[i] = channel.ptr[i];
        i = i + 1;
    }
}

fn connection_pubsub_register(fd: i32, protocol_version: i32, channel: &[byte]) !bool {
    if channel.len > CONNECTION_PUBSUB_CHANNEL_MAX {
        return error.ConnectionInputTooLarge;
    }
    if fd < 0 {
        return true;
    }

    var free_index: i32 = -1;
    var i: usize = 0;
    while i < CONNECTION_PUBSUB_MAX_SUBSCRIPTIONS {
        if connection_pubsub_subscriptions[i].active {
            if connection_pubsub_subscriptions[i].fd == fd && connection_pubsub_channel_eq(&connection_pubsub_subscriptions[i], channel) {
                connection_pubsub_subscriptions[i].protocol_version = protocol_version;
                return false;
            }
        } else if free_index < 0 {
            free_index = i as i32;
        }
        i = i + 1;
    }
    if free_index < 0 {
        return error.ConnectionOutputTooSmall;
    }

    const slot: usize = free_index as usize;
    if slot >= CONNECTION_PUBSUB_MAX_SUBSCRIPTIONS {
        return error.ConnectionOutputTooSmall;
    }
    connection_pubsub_subscriptions[slot].active = true;
    connection_pubsub_subscriptions[slot].fd = fd;
    connection_pubsub_subscriptions[slot].protocol_version = protocol_version;
    connection_pubsub_copy_channel(&connection_pubsub_subscriptions[slot], channel);
    return true;
}

fn connection_pubsub_unregister_channel(fd: i32, channel: &[byte]) bool {
    if fd < 0 {
        return true;
    }
    var i: usize = 0;
    while i < CONNECTION_PUBSUB_MAX_SUBSCRIPTIONS {
        if connection_pubsub_subscriptions[i].active && connection_pubsub_subscriptions[i].fd == fd && connection_pubsub_channel_eq(&connection_pubsub_subscriptions[i], channel) {
            connection_pubsub_subscriptions[i].active = false;
            return true;
        }
        i = i + 1;
    }
    return false;
}

export fn connection_pubsub_unregister_fd(fd: i32) void {
    var i: usize = 0;
    while i < CONNECTION_PUBSUB_MAX_SUBSCRIPTIONS {
        if connection_pubsub_subscriptions[i].active && connection_pubsub_subscriptions[i].fd == fd {
            connection_pubsub_subscriptions[i].active = false;
        }
        i = i + 1;
    }
}

fn connection_pubsub_count_channel(channel: &[byte]) usize {
    var count: usize = 0;
    var i: usize = 0;
    while i < CONNECTION_PUBSUB_MAX_SUBSCRIPTIONS {
        if connection_pubsub_subscriptions[i].active && connection_pubsub_channel_eq(&connection_pubsub_subscriptions[i], channel) {
            count = count + 1;
        }
        i = i + 1;
    }
    return count;
}

fn connection_pubsub_append_bulk(buf: &Sds, data: &[byte]) !void {
    try sds_cat(buf, &"$"[0: 1]);
    try connection_sds_append_u64(buf, data.len as u64);
    try sds_cat(buf, &"\r\n"[0: 2]);
    try sds_cat(buf, data);
    try sds_cat(buf, &"\r\n"[0: 2]);
}

fn connection_pubsub_append_event(buf: &Sds, prefix: &[byte], kind: &[byte], channel: &[byte], value: &[byte], count: usize, has_value: bool) !void {
    try sds_cat(buf, prefix);
    try connection_pubsub_append_bulk(buf, kind);
    try connection_pubsub_append_bulk(buf, channel);
    if has_value {
        try connection_pubsub_append_bulk(buf, value);
    } else {
        try sds_cat(buf, &":"[0: 1]);
        try connection_sds_append_u64(buf, count as u64);
        try sds_cat(buf, &"\r\n"[0: 2]);
    }
}

fn connection_pubsub_subscription_reply(kind: &[byte], channel: &[byte], count: usize, protocol_version: i32) CommandReply {
    var raw: Sds = sds_empty() catch {
        return connection_error_reply(&"ERR out of memory"[0: 17]);
    };
    defer {
        sds_free(&raw);
    }
    if protocol_version == 3 {
        _ = connection_pubsub_append_event(&raw, &">3\r\n"[0: 4], kind, channel, connection_reply_empty_slice(), count, false) catch {
            return connection_error_reply(&"ERR out of memory"[0: 17]);
        };
    } else {
        _ = connection_pubsub_append_event(&raw, &"*3\r\n"[0: 4], kind, channel, connection_reply_empty_slice(), count, false) catch {
            return connection_error_reply(&"ERR out of memory"[0: 17]);
        };
    }
    return connection_raw_reply_owned(raw.buf[0: raw.len]);
}

fn connection_pubsub_unsubscribe_all_reply(protocol_version: i32) CommandReply {
    if protocol_version == 3 {
        return connection_make_reply(CommandReplyType.reply_raw_bytes, &">3\r\n$11\r\nunsubscribe\r\n_\r\n:0\r\n"[0: 29], 0);
    }
    return connection_make_reply(CommandReplyType.reply_raw_bytes, &"*3\r\n$11\r\nunsubscribe\r\n$-1\r\n:0\r\n"[0: 31], 0);
}

fn connection_pubsub_message_raw(channel: &[byte], message: &[byte], protocol_version: i32) CommandReply {
    var raw: Sds = sds_empty() catch {
        return connection_error_reply(&"ERR out of memory"[0: 17]);
    };
    defer {
        sds_free(&raw);
    }
    if protocol_version == 3 {
        _ = connection_pubsub_append_event(&raw, &">3\r\n"[0: 4], &"message"[0: 7], channel, message, 0, true) catch {
            return connection_error_reply(&"ERR out of memory"[0: 17]);
        };
    } else {
        _ = connection_pubsub_append_event(&raw, &"*3\r\n"[0: 4], &"message"[0: 7], channel, message, 0, true) catch {
            return connection_error_reply(&"ERR out of memory"[0: 17]);
        };
    }
    return connection_raw_reply_owned(raw.buf[0: raw.len]);
}

fn connection_pubsub_publish(channel: &[byte], message: &[byte]) usize {
    const receivers: usize = connection_pubsub_count_channel(channel);
    var i: usize = 0;
    while i < CONNECTION_PUBSUB_MAX_SUBSCRIPTIONS {
        if connection_pubsub_subscriptions[i].active && connection_pubsub_channel_eq(&connection_pubsub_subscriptions[i], channel) {
            var push: CommandReply = connection_pubsub_message_raw(channel, message, connection_pubsub_subscriptions[i].protocol_version);
            if push.typ == CommandReplyType.reply_raw_bytes {
                _ = connection_send_all_nonblocking(connection_pubsub_subscriptions[i].fd, push.data.ptr, push.data.len) catch {
                    connection_pubsub_subscriptions[i].active = false;
                };
            }
            command_reply_cleanup(&push);
        }
        i = i + 1;
    }
    return receivers;
}

fn connection_should_append_aof(command: &Command, reply: &CommandReply) bool {
    if reply.typ == CommandReplyType.reply_error {
        return false;
    }
    return (command.info.flags & COMMAND_FLAG_WRITE) != 0u64;
}

fn connection_append_byte(out: &byte, out_cap: usize, pos: &usize, ch: byte) !void {
    if *pos >= out_cap {
        return error.ConnectionOutputTooSmall;
    }
    out[*pos] = ch;
    *pos = *pos + 1;
}

fn connection_append_bytes(out: &byte, out_cap: usize, pos: &usize, data: &[byte]) !void {
    var i: usize = 0;
    while i < data.len {
        try connection_append_byte(out, out_cap, pos, data.ptr[i]);
        i = i + 1;
    }
}

fn connection_append_crlf(out: &byte, out_cap: usize, pos: &usize) !void {
    try connection_append_byte(out, out_cap, pos, 13 as byte);
    try connection_append_byte(out, out_cap, pos, 10 as byte);
}

fn connection_append_u64(out: &byte, out_cap: usize, pos: &usize, value: u64) !void {
    if value == 0u64 {
        try connection_append_byte(out, out_cap, pos, 48 as byte);
        return;
    }

    var tmp: [byte: 20] = [];
    var count: usize = 0;
    var v: u64 = value;
    while v > 0u64 {
        const digit: u64 = v % 10u64;
        tmp[count] = (48u64 + digit) as byte;
        count = count + 1;
        v = v / 10u64;
    }

    while count > 0 {
        count = count - 1;
        try connection_append_byte(out, out_cap, pos, tmp[count]);
    }
}

fn connection_append_i64(out: &byte, out_cap: usize, pos: &usize, value: i64) !void {
    if value < 0 {
        try connection_append_byte(out, out_cap, pos, 45 as byte);
        const positive: i64 = 0 - value;
        try connection_append_u64(out, out_cap, pos, positive as u64);
        return;
    }
    try connection_append_u64(out, out_cap, pos, value as u64);
}

fn connection_u64_decimal_len(value: u64) usize {
    if value == 0u64 {
        return 1;
    }

    var digits: usize = 0;
    var v: u64 = value;
    while v > 0u64 {
        digits = digits + 1;
        v = v / 10u64;
    }
    return digits;
}

fn connection_encode_bulk_header(out: &byte, out_cap: usize, body_len: usize) !usize {
    var pos: usize = 0;
    try connection_append_byte(out, out_cap, &pos, 36 as byte);
    try connection_append_u64(out, out_cap, &pos, body_len as u64);
    try connection_append_crlf(out, out_cap, &pos);
    return pos;
}

export fn connection_encode_reply_with_protocol(reply: &CommandReply, out: &byte, out_cap: usize, protocol_version: i32) !usize {
    var pos: usize = 0;

    if reply.typ == CommandReplyType.reply_simple_string {
        try connection_append_byte(out, out_cap, &pos, 43 as byte);
        try connection_append_bytes(out, out_cap, &pos, reply.data);
        try connection_append_crlf(out, out_cap, &pos);
        return pos;
    }
    if reply.typ == CommandReplyType.reply_error {
        try connection_append_byte(out, out_cap, &pos, 45 as byte);
        try connection_append_bytes(out, out_cap, &pos, reply.data);
        try connection_append_crlf(out, out_cap, &pos);
        return pos;
    }
    if reply.typ == CommandReplyType.reply_integer {
        try connection_append_byte(out, out_cap, &pos, 58 as byte);
        try connection_append_i64(out, out_cap, &pos, reply.integer);
        try connection_append_crlf(out, out_cap, &pos);
        return pos;
    }
    if reply.typ == CommandReplyType.reply_bulk_string {
        try connection_append_byte(out, out_cap, &pos, 36 as byte);
        try connection_append_u64(out, out_cap, &pos, reply.data.len as u64);
        try connection_append_crlf(out, out_cap, &pos);
        try connection_append_bytes(out, out_cap, &pos, reply.data);
        try connection_append_crlf(out, out_cap, &pos);
        return pos;
    }
    if reply.typ == CommandReplyType.reply_null_bulk {
        if protocol_version == 3 {
            try connection_append_bytes(out, out_cap, &pos, &"_\r\n"[0: 3]);
        } else {
            try connection_append_bytes(out, out_cap, &pos, &"$-1\r\n"[0: 5]);
        }
        return pos;
    }
    if reply.typ == CommandReplyType.reply_array_bulk {
        try connection_append_byte(out, out_cap, &pos, 42 as byte);
        try connection_append_u64(out, out_cap, &pos, reply.array_count as u64);
        try connection_append_crlf(out, out_cap, &pos);

        var node: &ListNode = reply.array_head;
        var count: usize = 0;
        while node != null && count < reply.array_count {
            const data: &[byte] = node.value.value.buf[0: node.value.value.len];
            try connection_append_byte(out, out_cap, &pos, 36 as byte);
            try connection_append_u64(out, out_cap, &pos, data.len as u64);
            try connection_append_crlf(out, out_cap, &pos);
            try connection_append_bytes(out, out_cap, &pos, data);
            try connection_append_crlf(out, out_cap, &pos);
            node = node.next;
            count = count + 1;
        }
        return pos;
    }
    if reply.typ == CommandReplyType.reply_scan {
        try connection_append_byte(out, out_cap, &pos, 42 as byte);
        try connection_append_u64(out, out_cap, &pos, 2u64);
        try connection_append_crlf(out, out_cap, &pos);

        try connection_append_byte(out, out_cap, &pos, 36 as byte);
        try connection_append_u64(out, out_cap, &pos, connection_u64_decimal_len(reply.scan_cursor) as u64);
        try connection_append_crlf(out, out_cap, &pos);
        try connection_append_u64(out, out_cap, &pos, reply.scan_cursor);
        try connection_append_crlf(out, out_cap, &pos);

        try connection_append_byte(out, out_cap, &pos, 42 as byte);
        try connection_append_u64(out, out_cap, &pos, reply.array_count as u64);
        try connection_append_crlf(out, out_cap, &pos);

        var node_scan: &ListNode = reply.array_head;
        var count_scan: usize = 0;
        while node_scan != null && count_scan < reply.array_count {
            const data_scan: &[byte] = node_scan.value.value.buf[0: node_scan.value.value.len];
            try connection_append_byte(out, out_cap, &pos, 36 as byte);
            try connection_append_u64(out, out_cap, &pos, data_scan.len as u64);
            try connection_append_crlf(out, out_cap, &pos);
            try connection_append_bytes(out, out_cap, &pos, data_scan);
            try connection_append_crlf(out, out_cap, &pos);
            node_scan = node_scan.next;
            count_scan = count_scan + 1;
        }
        return pos;
    }
    if reply.typ == CommandReplyType.reply_raw_bytes {
        try connection_append_bytes(out, out_cap, &pos, reply.data);
        return pos;
    }

    try connection_append_bytes(out, out_cap, &pos, &"-ERR unsupported reply\r\n"[0: 24]);
    return pos;
}

export fn connection_encode_reply(reply: &CommandReply, out: &byte, out_cap: usize) !usize {
    return connection_encode_reply_with_protocol(reply, out, out_cap, 2);
}

fn connection_transaction_execute_at(
    engine: &Engine,
    runtime: &CommandRuntimeInfo,
    router: &CommandRouter,
    aof: &AofWriter,
    rewrite_buf: &Sds,
    backlog: &ReplicationBacklog,
    tx: &ConnectionTransaction,
    now_ms: u64,
    close_after: &bool,
    replicaof_requested: &bool,
    replicaof_promote: &bool,
    replicaof_host: &[byte],
    replicaof_port: &i32,
    bgsave_requested: &bool,
    rewrite_requested: &bool,
    rewrite_failed: &bool,
    protocol_version: i32,
) CommandReply {
    var raw: Sds = sds_empty() catch {
        return connection_error_reply(&"ERR out of memory"[0: 17]);
    };
    defer {
        sds_free(&raw);
    }

    _ = sds_cat(&raw, &"*"[0: 1]) catch { return connection_error_reply(&"ERR out of memory"[0: 17]); };
    _ = connection_sds_append_u64(&raw, tx.queue_count as u64) catch { return connection_error_reply(&"ERR out of memory"[0: 17]); };
    _ = sds_cat(&raw, &"\r\n"[0: 2]) catch { return connection_error_reply(&"ERR out of memory"[0: 17]); };

    var node: &ListNode = null as &ListNode;
    if tx.queue != null {
        node = tx.queue.list_head;
    }

    var processed: usize = 0;
    while node != null && processed < tx.queue_count {
        const raw_cmd: &[byte] = node.value.value.buf[0: node.value.value.len];
        const parsed_result: !RespParseResult = parse_resp2(raw_cmd);
        var parsed_ok: bool = true;
        const parsed: RespParseResult = parsed_result catch |err| {
            var err_reply: CommandReply = connection_error_reply(&"ERR transaction replay failed"[0: 29]);
            _ = connection_append_reply_sds(&raw, &err_reply, protocol_version) catch { return connection_error_reply(&"ERR out of memory"[0: 17]); };
            parsed_ok = false;
            node = node.next;
            processed = processed + 1;
            connection_dummy_resp_parse_result();
        };
        if !parsed_ok {
            continue;
        }

        const command_result: !Command = command_from_resp(router, &parsed.value);
        var command_ok: bool = true;
        const command: Command = command_result catch |err| {
            var err_reply_2: CommandReply = connection_error_reply(&"ERR transaction replay failed"[0: 29]);
            _ = connection_append_reply_sds(&raw, &err_reply_2, protocol_version) catch { resp_value_free(&parsed.value); return connection_error_reply(&"ERR out of memory"[0: 17]); };
            resp_value_free(&parsed.value);
            command_ok = false;
            node = node.next;
            processed = processed + 1;
            connection_dummy_command(router);
        };
        if !command_ok {
            continue;
        }

        var reply: CommandReply = command_execute_with_runtime_at(engine, runtime, &command, now_ms);
        if aof != null && connection_should_append_aof(&command, &reply) {
            _ = aof_append_command_at(aof, &command, raw_cmd, now_ms) catch {
                command_reply_cleanup(&reply);
                reply = connection_error_reply(&"ERR AOF append failed"[0: 21]);
            };
            if rewrite_buf != null && runtime.aof_rewrite_in_progress && reply.typ != CommandReplyType.reply_error {
                _ = aof_append_command_to_sds_at(rewrite_buf, &command, raw_cmd, now_ms) catch {
                    if rewrite_failed != null {
                        *rewrite_failed = true;
                    }
                };
            }
            if backlog != null && runtime.replication_role == ReplicationRole.role_master && reply.typ != CommandReplyType.reply_error {
                _ = replication_backlog_append_command_at(backlog, &command, raw_cmd, now_ms) catch {};
            }
        }

        if reply.request_replicaof {
            *replicaof_requested = true;
            *replicaof_promote = reply.replicaof_promote;
            *replicaof_port = reply.replicaof_port;
            connection_copy_replica_host(replicaof_host, reply.replicaof_host);
        }
        if reply.request_bgsave {
            *bgsave_requested = true;
        }
        if reply.request_aof_rewrite {
            *rewrite_requested = true;
        }
        if command.info.cmd_type == CommandType.command_quit {
            *close_after = true;
        }

        _ = connection_append_reply_sds(&raw, &reply, protocol_version) catch {
            command_reply_cleanup(&reply);
            resp_value_free(&parsed.value);
            return connection_error_reply(&"ERR out of memory"[0: 17]);
        };
        command_reply_cleanup(&reply);
        resp_value_free(&parsed.value);
        node = node.next;
        processed = processed + 1;
    }

    return connection_raw_reply_owned(raw.buf[0: raw.len]);
}

fn connection_build_fullresync_reply(engine: &Engine, line: &[byte], now_ms: u64) CommandReply {
    const snapshot: &RedisObject = rdb_dump_object_at(engine, now_ms) catch |err| {
        if err == error.AllocOutOfMemory {
            return connection_error_reply(&"ERR out of memory"[0: 17]);
        }
        return connection_error_reply(&"ERR full sync snapshot failed"[0: 27]);
    };
    defer {
        object_free(snapshot);
    }

    var raw: Sds = sds_empty() catch {
        return connection_error_reply(&"ERR out of memory"[0: 17]);
    };
    defer {
        sds_free(&raw);
    }

    _ = sds_cat(&raw, &"+"[0: 1]) catch { return connection_error_reply(&"ERR out of memory"[0: 17]); };
    _ = sds_cat(&raw, line) catch { return connection_error_reply(&"ERR out of memory"[0: 17]); };
    _ = sds_cat(&raw, &"\r\n$"[0: 3]) catch { return connection_error_reply(&"ERR out of memory"[0: 17]); };
    _ = connection_sds_append_u64(&raw, snapshot.value.len as u64) catch { return connection_error_reply(&"ERR out of memory"[0: 17]); };
    _ = sds_cat(&raw, &"\r\n"[0: 2]) catch { return connection_error_reply(&"ERR out of memory"[0: 17]); };
    _ = sds_cat(&raw, snapshot.value.buf[0: snapshot.value.len]) catch { return connection_error_reply(&"ERR out of memory"[0: 17]); };
    _ = sds_cat(&raw, &"\r\n"[0: 2]) catch { return connection_error_reply(&"ERR out of memory"[0: 17]); };
    return connection_raw_reply_owned(raw.buf[0: raw.len]);
}

fn connection_build_continue_reply(backlog: &ReplicationBacklog, offset: u64) CommandReply {
    var raw: Sds = sds_empty() catch {
        return connection_error_reply(&"ERR out of memory"[0: 17]);
    };
    defer {
        sds_free(&raw);
    }

    _ = sds_cat(&raw, &"+CONTINUE "[0: 10]) catch { return connection_error_reply(&"ERR out of memory"[0: 17]); };
    _ = connection_sds_append_u64(&raw, backlog.master_offset) catch { return connection_error_reply(&"ERR out of memory"[0: 17]); };
    _ = sds_cat(&raw, &"\r\n$"[0: 3]) catch { return connection_error_reply(&"ERR out of memory"[0: 17]); };
    const delta: &[byte] = replication_backlog_slice_from(backlog, offset);
    _ = connection_sds_append_u64(&raw, delta.len as u64) catch { return connection_error_reply(&"ERR out of memory"[0: 17]); };
    _ = sds_cat(&raw, &"\r\n"[0: 2]) catch { return connection_error_reply(&"ERR out of memory"[0: 17]); };
    _ = sds_cat(&raw, delta) catch { return connection_error_reply(&"ERR out of memory"[0: 17]); };
    _ = sds_cat(&raw, &"\r\n"[0: 2]) catch { return connection_error_reply(&"ERR out of memory"[0: 17]); };
    return connection_raw_reply_owned(raw.buf[0: raw.len]);
}

fn connection_hello_reply(protocol_version: i32) CommandReply {
    if protocol_version == 3 {
        return connection_make_reply(
            CommandReplyType.reply_raw_bytes,
            &"%7\r\n$6\r\nserver\r\n$9\r\nredis-uya\r\n$7\r\nversion\r\n$9\r\n0.1.0-dev\r\n$5\r\nproto\r\n:3\r\n$2\r\nid\r\n:0\r\n$4\r\nmode\r\n$10\r\nstandalone\r\n$4\r\nrole\r\n$6\r\nmaster\r\n$7\r\nmodules\r\n*0\r\n"[0: 152],
            0,
        );
    }
    return connection_make_reply(
        CommandReplyType.reply_raw_bytes,
        &"*14\r\n$6\r\nserver\r\n$9\r\nredis-uya\r\n$7\r\nversion\r\n$9\r\n0.1.0-dev\r\n$5\r\nproto\r\n:2\r\n$2\r\nid\r\n:0\r\n$4\r\nmode\r\n$10\r\nstandalone\r\n$4\r\nrole\r\n$6\r\nmaster\r\n$7\r\nmodules\r\n*0\r\n"[0: 153],
        0,
    );
}

fn connection_handle_hello(tx: &ConnectionTransaction, command: &Command) CommandReply {
    if command.argc == 1 {
        return connection_hello_reply(tx.protocol_version);
    }
    if command.argc != 2 && command.argc != 4 {
        return connection_error_reply(&"ERR syntax error"[0: 16]);
    }
    const version_arg: &[byte] = command_arg_data(command, 1) catch {
        return connection_error_reply(&"ERR invalid protocol version"[0: 28]);
    };
    const version: u64 = connection_parse_u64(version_arg) catch {
        return connection_error_reply(&"ERR invalid protocol version"[0: 28]);
    };
    if version != 2u64 && version != 3u64 {
        return connection_error_reply(&"NOPROTO unsupported protocol version"[0: 36]);
    }
    tx.protocol_version = version as i32;
    if command.argc == 4 {
        const option: &[byte] = command_arg_data(command, 2) catch {
            return connection_error_reply(&"ERR syntax error"[0: 16]);
        };
        if !connection_keyword_eq(option, &"SETNAME"[0: 7]) {
            return connection_error_reply(&"ERR syntax error"[0: 16]);
        }
        const name: &[byte] = command_arg_data(command, 3) catch {
            return connection_error_reply(&"ERR syntax error"[0: 16]);
        };
        _ = connection_client_store_name(tx, name) catch {
            return connection_error_reply(&"ERR invalid client name"[0: 23]);
        };
    }
    return connection_hello_reply(tx.protocol_version);
}

fn connection_handle_subscribe(tx: &ConnectionTransaction, command: &Command) CommandReply {
    var raw: Sds = sds_empty() catch {
        return connection_error_reply(&"ERR out of memory"[0: 17]);
    };
    defer {
        sds_free(&raw);
    }

    var index: usize = 1;
    while index < command.argc {
        const channel: &[byte] = command_arg_data(command, index) catch {
            return connection_error_reply(&"ERR invalid request"[0: 19]);
        };
        const added: bool = connection_pubsub_register(tx.client_fd, tx.protocol_version, channel) catch {
            return connection_error_reply(&"ERR pubsub registration failed"[0: 30]);
        };
        if added {
            tx.pubsub_count = tx.pubsub_count + 1;
        }
        var reply: CommandReply = connection_pubsub_subscription_reply(&"subscribe"[0: 9], channel, tx.pubsub_count, tx.protocol_version);
        if reply.typ == CommandReplyType.reply_error {
            command_reply_cleanup(&reply);
            return connection_error_reply(&"ERR out of memory"[0: 17]);
        }
        _ = sds_cat(&raw, reply.data) catch {
            command_reply_cleanup(&reply);
            return connection_error_reply(&"ERR out of memory"[0: 17]);
        };
        command_reply_cleanup(&reply);
        index = index + 1;
    }
    return connection_raw_reply_owned(raw.buf[0: raw.len]);
}

fn connection_handle_unsubscribe(tx: &ConnectionTransaction, command: &Command) CommandReply {
    if command.argc == 1 {
        tx.pubsub_count = 0;
        connection_pubsub_unregister_fd(tx.client_fd);
        return connection_pubsub_unsubscribe_all_reply(tx.protocol_version);
    }

    var raw: Sds = sds_empty() catch {
        return connection_error_reply(&"ERR out of memory"[0: 17]);
    };
    defer {
        sds_free(&raw);
    }

    var index: usize = 1;
    while index < command.argc {
        const channel: &[byte] = command_arg_data(command, index) catch {
            return connection_error_reply(&"ERR invalid request"[0: 19]);
        };
        const removed: bool = connection_pubsub_unregister_channel(tx.client_fd, channel);
        if removed && tx.pubsub_count > 0 {
            tx.pubsub_count = tx.pubsub_count - 1;
        }
        var reply: CommandReply = connection_pubsub_subscription_reply(&"unsubscribe"[0: 11], channel, tx.pubsub_count, tx.protocol_version);
        if reply.typ == CommandReplyType.reply_error {
            command_reply_cleanup(&reply);
            return connection_error_reply(&"ERR out of memory"[0: 17]);
        }
        _ = sds_cat(&raw, reply.data) catch {
            command_reply_cleanup(&reply);
            return connection_error_reply(&"ERR out of memory"[0: 17]);
        };
        command_reply_cleanup(&reply);
        index = index + 1;
    }
    return connection_raw_reply_owned(raw.buf[0: raw.len]);
}

fn connection_handle_publish(command: &Command) CommandReply {
    const channel: &[byte] = command_arg_data(command, 1) catch {
        return connection_error_reply(&"ERR invalid request"[0: 19]);
    };
    const message: &[byte] = command_arg_data(command, 2) catch {
        return connection_error_reply(&"ERR invalid request"[0: 19]);
    };
    const receivers: usize = connection_pubsub_publish(channel, message);
    return connection_make_reply(CommandReplyType.reply_integer, connection_reply_empty_slice(), receivers as i64);
}

fn connection_parse_input_for_protocol(tx: &ConnectionTransaction, input: &[byte]) !RespParseResult {
    if tx != null && tx.protocol_version == 3 {
        return parse_resp3(input);
    }
    return parse_resp2(input);
}

