export fn test_command_router_arity_validation() !void {
    const router: CommandRouter = command_router_new();
    const hello: CommandInfo = try command_router_lookup(&router, &"HELLO"[0: 5]);
    const subscribe: CommandInfo = try command_router_lookup(&router, &"SUBSCRIBE"[0: 9]);
    const unsubscribe: CommandInfo = try command_router_lookup(&router, &"UNSUBSCRIBE"[0: 11]);
    const publish: CommandInfo = try command_router_lookup(&router, &"PUBLISH"[0: 7]);
    const multi: CommandInfo = try command_router_lookup(&router, &"MULTI"[0: 5]);
    const exec: CommandInfo = try command_router_lookup(&router, &"EXEC"[0: 4]);
    const discard: CommandInfo = try command_router_lookup(&router, &"DISCARD"[0: 7]);
    const watch: CommandInfo = try command_router_lookup(&router, &"WATCH"[0: 5]);
    const unwatch: CommandInfo = try command_router_lookup(&router, &"UNWATCH"[0: 7]);
    const get: CommandInfo = try command_router_lookup(&router, &"GET"[0: 3]);
    const incr: CommandInfo = try command_router_lookup(&router, &"INCR"[0: 4]);
    const decr: CommandInfo = try command_router_lookup(&router, &"DECR"[0: 4]);
    const incrby: CommandInfo = try command_router_lookup(&router, &"INCRBY"[0: 6]);
    const getset: CommandInfo = try command_router_lookup(&router, &"GETSET"[0: 6]);
    const setnx: CommandInfo = try command_router_lookup(&router, &"SETNX"[0: 5]);
    const setex: CommandInfo = try command_router_lookup(&router, &"SETEX"[0: 5]);
    const decrby: CommandInfo = try command_router_lookup(&router, &"DECRBY"[0: 6]);
    const append: CommandInfo = try command_router_lookup(&router, &"APPEND"[0: 6]);
    const strlen: CommandInfo = try command_router_lookup(&router, &"STRLEN"[0: 6]);
    const getdel: CommandInfo = try command_router_lookup(&router, &"GETDEL"[0: 6]);
    const echo: CommandInfo = try command_router_lookup(&router, &"ECHO"[0: 4]);
    const type_info: CommandInfo = try command_router_lookup(&router, &"TYPE"[0: 4]);
    const lpop: CommandInfo = try command_router_lookup(&router, &"LPOP"[0: 4]);
    const lpush: CommandInfo = try command_router_lookup(&router, &"LPUSH"[0: 5]);
    const lrange: CommandInfo = try command_router_lookup(&router, &"LRANGE"[0: 6]);
    const sadd: CommandInfo = try command_router_lookup(&router, &"SADD"[0: 4]);
    const smembers: CommandInfo = try command_router_lookup(&router, &"SMEMBERS"[0: 8]);
    const srem: CommandInfo = try command_router_lookup(&router, &"SREM"[0: 4]);
    const zadd: CommandInfo = try command_router_lookup(&router, &"ZADD"[0: 4]);
    const zrange: CommandInfo = try command_router_lookup(&router, &"ZRANGE"[0: 6]);
    const zrem: CommandInfo = try command_router_lookup(&router, &"ZREM"[0: 4]);
    const scan: CommandInfo = try command_router_lookup(&router, &"SCAN"[0: 4]);
    const save: CommandInfo = try command_router_lookup(&router, &"SAVE"[0: 4]);
    const bgsave: CommandInfo = try command_router_lookup(&router, &"BGSAVE"[0: 6]);
    const bgrewriteaof: CommandInfo = try command_router_lookup(&router, &"BGREWRITEAOF"[0: 12]);
    const replicaof: CommandInfo = try command_router_lookup(&router, &"REPLICAOF"[0: 9]);
    const psync: CommandInfo = try command_router_lookup(&router, &"PSYNC"[0: 5]);
    const config: CommandInfo = try command_router_lookup(&router, &"CONFIG"[0: 6]);
    const client: CommandInfo = try command_router_lookup(&router, &"CLIENT"[0: 6]);
    const cluster: CommandInfo = try command_router_lookup(&router, &"CLUSTER"[0: 7]);
    const hget: CommandInfo = try command_router_lookup(&router, &"HGET"[0: 4]);
    const hset: CommandInfo = try command_router_lookup(&router, &"HSET"[0: 4]);
    const set: CommandInfo = try command_router_lookup(&router, &"SET"[0: 3]);
    const del: CommandInfo = try command_router_lookup(&router, &"DEL"[0: 3]);
    const dbsize: CommandInfo = try command_router_lookup(&router, &"DBSIZE"[0: 6]);
    const pexpire: CommandInfo = try command_router_lookup(&router, &"PEXPIRE"[0: 7]);
    const persist: CommandInfo = try command_router_lookup(&router, &"PERSIST"[0: 7]);
    const pttl: CommandInfo = try command_router_lookup(&router, &"PTTL"[0: 4]);

    try command_validate_arity(&hello, 1);
    try command_validate_arity(&hello, 2);
    try command_validate_arity(&subscribe, 2);
    try command_validate_arity(&subscribe, 3);
    try command_validate_arity(&unsubscribe, 1);
    try command_validate_arity(&unsubscribe, 2);
    try command_validate_arity(&publish, 3);
    try command_validate_arity(&multi, 1);
    try command_validate_arity(&exec, 1);
    try command_validate_arity(&discard, 1);
    try command_validate_arity(&watch, 2);
    try command_validate_arity(&watch, 4);
    try command_validate_arity(&unwatch, 1);
    try command_validate_arity(&get, 2);
    try command_validate_arity(&incr, 2);
    try command_validate_arity(&decr, 2);
    try command_validate_arity(&incrby, 3);
    try command_validate_arity(&getset, 3);
    try command_validate_arity(&setnx, 3);
    try command_validate_arity(&setex, 4);
    try command_validate_arity(&decrby, 3);
    try command_validate_arity(&append, 3);
    try command_validate_arity(&strlen, 2);
    try command_validate_arity(&getdel, 2);
    try command_validate_arity(&echo, 2);
    try command_validate_arity(&type_info, 2);
    try command_validate_arity(&lpop, 2);
    try command_validate_arity(&lpush, 3);
    try command_validate_arity(&lpush, 5);
    try command_validate_arity(&lrange, 4);
    try command_validate_arity(&sadd, 3);
    try command_validate_arity(&sadd, 6);
    try command_validate_arity(&smembers, 2);
    try command_validate_arity(&srem, 3);
    try command_validate_arity(&zadd, 4);
    try command_validate_arity(&zadd, 6);
    try command_validate_arity(&zrange, 4);
    try command_validate_arity(&zrem, 3);
    try command_validate_arity(&scan, 2);
    try command_validate_arity(&scan, 4);
    try command_validate_arity(&save, 1);
    try command_validate_arity(&bgsave, 1);
    try command_validate_arity(&bgrewriteaof, 1);
    try command_validate_arity(&replicaof, 3);
    try command_validate_arity(&psync, 3);
    try command_validate_arity(&config, 2);
    try command_validate_arity(&config, 3);
    try command_validate_arity(&client, 2);
    try command_validate_arity(&client, 4);
    try command_validate_arity(&cluster, 2);
    try command_validate_arity(&cluster, 3);
    try command_validate_arity(&hget, 3);
    try command_validate_arity(&hset, 4);
    try command_validate_arity(&set, 3);
    try command_validate_arity(&set, 5);
    try command_validate_arity(&del, 2);
    try command_validate_arity(&del, 4);
    try command_validate_arity(&dbsize, 1);
    try command_validate_arity(&pexpire, 3);
    try command_validate_arity(&persist, 2);
    try command_validate_arity(&pttl, 2);

    var saw_get_wrong: bool = false;
    _ = command_validate_arity(&get, 1) catch |err| {
        if err == error.CommandWrongArity {
            saw_get_wrong = true;
        }
        return;
    };
    try assert_true(saw_get_wrong);

    var saw_set_wrong: bool = false;
    _ = command_validate_arity(&set, 2) catch |err| {
        if err == error.CommandWrongArity {
            saw_set_wrong = true;
        }
        return;
    };
    try assert_true(saw_set_wrong);

    var saw_multi_wrong: bool = false;
    _ = command_validate_arity(&multi, 2) catch |err| {
        if err == error.CommandWrongArity {
            saw_multi_wrong = true;
        }
        return;
    };
    try assert_true(saw_multi_wrong);

    var saw_unwatch_wrong: bool = false;
    _ = command_validate_arity(&unwatch, 2) catch |err| {
        if err == error.CommandWrongArity {
            saw_unwatch_wrong = true;
        }
        return;
    };
    try assert_true(saw_unwatch_wrong);
}

export fn test_command_router_unknown_command() !void {
    const router: CommandRouter = command_router_new();
    var saw_unknown: bool = false;
    _ = command_router_lookup(&router, &"MISSING"[0: 7]) catch |err| {
        if err == error.CommandUnknown {
            saw_unknown = true;
        }
        return;
    };
    try assert_true(saw_unknown);
}

export fn test_command_from_resp_array() !void {
    reset_memory_stats_for_test();
    const router: CommandRouter = command_router_new();
    var parsed: RespParseResult = try parse_resp2(&"*4\r\n$6\r\nZRANGE\r\n$4\r\nzset\r\n$1\r\n0\r\n$2\r\n-1\r\n"[0: 41]);
    const command: Command = try command_from_resp(&router, &parsed.value);

    try assert_eq_i32(command.info.cmd_type as i32, CommandType.command_zrange as i32);
    try assert_eq_i32(command.argc as i32, 4);
    try assert_true(command_router_slice_eq(try command_arg_data(&command, 0), &"ZRANGE"[0: 6]));
    try assert_true(command_router_slice_eq(try command_arg_data(&command, 1), &"zset"[0: 4]));
    try assert_true(command_router_slice_eq(try command_arg_data(&command, 2), &"0"[0: 1]));
    try assert_true(command_router_slice_eq(try command_arg_data(&command, 3), &"-1"[0: 2]));

    resp_value_free(&parsed.value);
    try assert_eq_i32(used_memory() as i32, 0);
}

export fn test_command_from_resp_error_paths() !void {
    reset_memory_stats_for_test();
    const router: CommandRouter = command_router_new();

    var inline_ping: RespParseResult = try parse_resp2(&"+PING\r\n"[0: 7]);
    var saw_invalid_request: bool = false;
    _ = command_from_resp(&router, &inline_ping.value) catch |err| {
        if err == error.CommandInvalidRequest {
            saw_invalid_request = true;
        }
        return;
    };
    try assert_true(saw_invalid_request);

    var unknown: RespParseResult = try parse_resp2(&"*1\r\n$7\r\nMISSING\r\n"[0: 17]);
    var saw_unknown: bool = false;
    _ = command_from_resp(&router, &unknown.value) catch |err| {
        if err == error.CommandUnknown {
            saw_unknown = true;
        }
        return;
    };
    try assert_true(saw_unknown);
    resp_value_free(&unknown.value);

    var wrong_arity: RespParseResult = try parse_resp2(&"*1\r\n$3\r\nGET\r\n"[0: 13]);
    var saw_wrong_arity: bool = false;
    _ = command_from_resp(&router, &wrong_arity.value) catch |err| {
        if err == error.CommandWrongArity {
            saw_wrong_arity = true;
        }
        return;
    };
    try assert_true(saw_wrong_arity);
    resp_value_free(&wrong_arity.value);
    try assert_eq_i32(used_memory() as i32, 0);
}
