    const hget_missing_reply: CommandReply = command_execute_at(&engine, &hget_missing_command, 1000u64);
    try assert_eq_i32(hget_missing_reply.typ as i32, CommandReplyType.reply_null_bulk as i32);
    resp_value_free(&hget_missing_parsed.value);

    engine_free(&engine);
    try assert_eq_i32(used_memory() as i32, 0);
}

export fn test_command_lpush_lpop_lrange() !void {
    reset_memory_stats_for_test();
    const router: CommandRouter = command_router_new();
    var engine: Engine = engine_new();
    var out: [byte: 256] = [];

    var lpush_parsed: RespParseResult = try parse_resp2(&"*5\r\n$5\r\nLPUSH\r\n$4\r\nlist\r\n$1\r\na\r\n$1\r\nb\r\n$1\r\nc\r\n"[0: 47]);
    const lpush_command: Command = try command_executor_test_command(&router, &lpush_parsed);
    const lpush_reply: CommandReply = command_execute_at(&engine, &lpush_command, 1000u64);
    try assert_eq_i32(lpush_reply.typ as i32, CommandReplyType.reply_integer as i32);
    try assert_eq_i32(lpush_reply.integer as i32, 3);
    resp_value_free(&lpush_parsed.value);

    var lrange_parsed: RespParseResult = try parse_resp2(&"*4\r\n$6\r\nLRANGE\r\n$4\r\nlist\r\n$1\r\n0\r\n$2\r\n-1\r\n"[0: 41]);
    const lrange_command: Command = try command_executor_test_command(&router, &lrange_parsed);
    const lrange_reply: CommandReply = command_execute_at(&engine, &lrange_command, 1000u64);
    try assert_eq_i32(lrange_reply.typ as i32, CommandReplyType.reply_array_bulk as i32);
    const lrange_len: usize = try connection_encode_reply(&lrange_reply, &out[0], 256);
    try assert_true(command_executor_test_slice_eq(out[0: lrange_len], &"*3\r\n$1\r\nc\r\n$1\r\nb\r\n$1\r\na\r\n"[0: 25]));
    command_reply_cleanup(&lrange_reply);
    resp_value_free(&lrange_parsed.value);

    var lpop_parsed: RespParseResult = try parse_resp2(&"*2\r\n$4\r\nLPOP\r\n$4\r\nlist\r\n"[0: 24]);
    const lpop_command: Command = try command_executor_test_command(&router, &lpop_parsed);
    const lpop_reply: CommandReply = command_execute_at(&engine, &lpop_command, 1000u64);
    try assert_eq_i32(lpop_reply.typ as i32, CommandReplyType.reply_bulk_string as i32);
    try assert_true(command_executor_test_slice_eq(lpop_reply.data, &"c"[0: 1]));
    command_reply_cleanup(&lpop_reply);
    resp_value_free(&lpop_parsed.value);

    var lrange_tail_parsed: RespParseResult = try parse_resp2(&"*4\r\n$6\r\nLRANGE\r\n$4\r\nlist\r\n$1\r\n0\r\n$1\r\n0\r\n"[0: 40]);
    const lrange_tail_command: Command = try command_executor_test_command(&router, &lrange_tail_parsed);
    const lrange_tail_reply: CommandReply = command_execute_at(&engine, &lrange_tail_command, 1000u64);
    const lrange_tail_len: usize = try connection_encode_reply(&lrange_tail_reply, &out[0], 256);
    try assert_true(command_executor_test_slice_eq(out[0: lrange_tail_len], &"*1\r\n$1\r\nb\r\n"[0: 11]));
    command_reply_cleanup(&lrange_tail_reply);
    resp_value_free(&lrange_tail_parsed.value);

    engine_free(&engine);
    try assert_eq_i32(used_memory() as i32, 0);
}

export fn test_command_sadd_srem_smembers() !void {
    reset_memory_stats_for_test();
    const router: CommandRouter = command_router_new();
    var engine: Engine = engine_new();
    var out: [byte: 256] = [];

    var sadd_parsed: RespParseResult = try parse_resp2(&"*5\r\n$4\r\nSADD\r\n$3\r\nset\r\n$1\r\na\r\n$1\r\nb\r\n$1\r\na\r\n"[0: 44]);
    const sadd_command: Command = try command_executor_test_command(&router, &sadd_parsed);
    const sadd_reply: CommandReply = command_execute_at(&engine, &sadd_command, 1000u64);
    try assert_eq_i32(sadd_reply.typ as i32, CommandReplyType.reply_integer as i32);
    try assert_eq_i32(sadd_reply.integer as i32, 2);
    resp_value_free(&sadd_parsed.value);

    var smembers_parsed: RespParseResult = try parse_resp2(&"*2\r\n$8\r\nSMEMBERS\r\n$3\r\nset\r\n"[0: 27]);
    const smembers_command: Command = try command_executor_test_command(&router, &smembers_parsed);
    const smembers_reply: CommandReply = command_execute_at(&engine, &smembers_command, 1000u64);
    try assert_eq_i32(smembers_reply.typ as i32, CommandReplyType.reply_array_bulk as i32);
    const smembers_len: usize = try connection_encode_reply(&smembers_reply, &out[0], 256);
    try assert_true(
        command_executor_test_slice_eq(out[0: smembers_len], &"*2\r\n$1\r\na\r\n$1\r\nb\r\n"[0: 18]) ||
        command_executor_test_slice_eq(out[0: smembers_len], &"*2\r\n$1\r\nb\r\n$1\r\na\r\n"[0: 18])
    );
    command_reply_cleanup(&smembers_reply);
    resp_value_free(&smembers_parsed.value);

    var srem_parsed: RespParseResult = try parse_resp2(&"*3\r\n$4\r\nSREM\r\n$3\r\nset\r\n$1\r\na\r\n"[0: 30]);
    const srem_command: Command = try command_executor_test_command(&router, &srem_parsed);
    const srem_reply: CommandReply = command_execute_at(&engine, &srem_command, 1000u64);
    try assert_eq_i32(srem_reply.typ as i32, CommandReplyType.reply_integer as i32);
    try assert_eq_i32(srem_reply.integer as i32, 1);
    resp_value_free(&srem_parsed.value);

    var smembers_tail_parsed: RespParseResult = try parse_resp2(&"*2\r\n$8\r\nSMEMBERS\r\n$3\r\nset\r\n"[0: 27]);
    const smembers_tail_command: Command = try command_executor_test_command(&router, &smembers_tail_parsed);
    const smembers_tail_reply: CommandReply = command_execute_at(&engine, &smembers_tail_command, 1000u64);
    const smembers_tail_len: usize = try connection_encode_reply(&smembers_tail_reply, &out[0], 256);
    try assert_true(command_executor_test_slice_eq(out[0: smembers_tail_len], &"*1\r\n$1\r\nb\r\n"[0: 11]));
    command_reply_cleanup(&smembers_tail_reply);
    resp_value_free(&smembers_tail_parsed.value);

    engine_free(&engine);
    try assert_eq_i32(used_memory() as i32, 0);
}

