use tests.unit.assert.assert_eq_i32;
use tests.unit.assert.assert_true;

use src.memory.allocator.redis_malloc;
use src.memory.allocator.redis_free;
use src.memory.allocator.redis_realloc;
use src.memory.allocator.used_memory;
use src.memory.allocator.used_memory_peak;
use src.memory.allocator.total_allocated_memory;
use src.memory.allocator.total_freed_memory;
use src.memory.allocator.allocator_total_allocations;
use src.memory.allocator.allocator_active_allocations;
use src.memory.allocator.allocator_slab_cached_blocks;
use src.memory.allocator.allocator_slab_cached_bytes;
use src.memory.allocator.allocator_slab_reuse_count;
use src.memory.allocator.reset_memory_stats_for_test;

export fn test_allocator_alloc_free() !void {
    reset_memory_stats_for_test();
    const ptr: &byte = try redis_malloc(64);
    try assert_true(ptr != null);
    ptr[0] = 42;
    ptr[63] = 24;
    try assert_eq_i32(ptr[0] as i32, 42);
    try assert_eq_i32(ptr[63] as i32, 24);
    try assert_eq_i32(used_memory() as i32, 64);
    try assert_eq_i32(used_memory_peak() as i32, 64);
    try assert_eq_i32(total_allocated_memory() as i32, 64);
    try assert_eq_i32(total_freed_memory() as i32, 0);
    try assert_eq_i32(allocator_total_allocations() as i32, 1);
    try assert_eq_i32(allocator_active_allocations() as i32, 1);
    redis_free(ptr);
    try assert_eq_i32(used_memory() as i32, 0);
    try assert_eq_i32(used_memory_peak() as i32, 64);
    try assert_eq_i32(total_allocated_memory() as i32, 64);
    try assert_eq_i32(total_freed_memory() as i32, 64);
    try assert_eq_i32(allocator_active_allocations() as i32, 0);
}

export fn test_allocator_realloc() !void {
    reset_memory_stats_for_test();
    var ptr: &byte = try redis_malloc(16);
    ptr[0] = 7;
    ptr = try redis_realloc(ptr, 128);
    try assert_true(ptr != null);
    try assert_eq_i32(ptr[0] as i32, 7);
    try assert_eq_i32(used_memory() as i32, 128);
    try assert_eq_i32(used_memory_peak() as i32, 128);
    try assert_eq_i32(total_allocated_memory() as i32, 128);
    ptr = try redis_realloc(ptr, 32);
    try assert_eq_i32(ptr[0] as i32, 7);
    try assert_eq_i32(used_memory() as i32, 32);
    try assert_eq_i32(total_freed_memory() as i32, 96);
    redis_free(ptr);
    try assert_eq_i32(used_memory() as i32, 0);
    try assert_eq_i32(used_memory_peak() as i32, 128);
    try assert_eq_i32(total_allocated_memory() as i32, 128);
    try assert_eq_i32(total_freed_memory() as i32, 128);
    try assert_eq_i32(allocator_total_allocations() as i32, 1);
    try assert_eq_i32(allocator_active_allocations() as i32, 0);
}

export fn test_allocator_many_allocations() !void {
    reset_memory_stats_for_test();
    var ptrs: [&byte: 32] = [];
    var i: usize = 0;
    while i < 32 {
        ptrs[i] = try redis_malloc(8);
        ptrs[i][0] = i as byte;
        i = i + 1;
    }
    try assert_eq_i32(used_memory() as i32, 256);
    try assert_eq_i32(used_memory_peak() as i32, 256);
    try assert_eq_i32(total_allocated_memory() as i32, 256);
    try assert_eq_i32(allocator_total_allocations() as i32, 32);
    try assert_eq_i32(allocator_active_allocations() as i32, 32);
    i = 0;
    while i < 32 {
        try assert_eq_i32(ptrs[i][0] as i32, i as i32);
        redis_free(ptrs[i]);
        i = i + 1;
    }
    try assert_eq_i32(used_memory() as i32, 0);
    try assert_eq_i32(used_memory_peak() as i32, 256);
    try assert_eq_i32(total_freed_memory() as i32, 256);
    try assert_eq_i32(allocator_active_allocations() as i32, 0);
}

export fn test_allocator_slab_reuse() !void {
    reset_memory_stats_for_test();
    var ptr: &byte = try redis_malloc(24);
    ptr[0] = 55;
    redis_free(ptr);
    try assert_eq_i32(used_memory() as i32, 0);
    try assert_eq_i32(allocator_active_allocations() as i32, 0);
    try assert_eq_i32(allocator_slab_cached_blocks() as i32, 1);
    try assert_eq_i32(allocator_slab_cached_bytes() as i32, 32);
    try assert_eq_i32(allocator_slab_reuse_count() as i32, 0);

    var reused: &byte = try redis_malloc(24);
    try assert_true(reused != null);
    reused[0] = 77;
    try assert_eq_i32(reused[0] as i32, 77);
    try assert_eq_i32(allocator_slab_reuse_count() as i32, 1);
    try assert_eq_i32(allocator_slab_cached_blocks() as i32, 0);
    try assert_eq_i32(allocator_slab_cached_bytes() as i32, 0);
    redis_free(reused);
    try assert_eq_i32(used_memory() as i32, 0);

    reset_memory_stats_for_test();
    const large: &byte = try redis_malloc(2048);
    redis_free(large);
    try assert_eq_i32(allocator_slab_cached_blocks() as i32, 0);
    try assert_eq_i32(allocator_slab_cached_bytes() as i32, 0);
    try assert_eq_i32(allocator_slab_reuse_count() as i32, 0);
    try assert_eq_i32(used_memory() as i32, 0);
}
