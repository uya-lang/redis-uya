export fn test_command_scan() !void {
    reset_memory_stats_for_test();
    const router: CommandRouter = command_router_new();
    var engine: Engine = engine_new();
    var out: [byte: 256] = [];

    var set_b_parsed: RespParseResult = try parse_resp2(&"*3\r\n$3\r\nSET\r\n$1\r\nb\r\n$1\r\n1\r\n"[0: 29]);
    const set_b_command: Command = try command_executor_test_command(&router, &set_b_parsed);
    _ = command_execute_at(&engine, &set_b_command, 1000u64);
    resp_value_free(&set_b_parsed.value);

    var set_a_parsed: RespParseResult = try parse_resp2(&"*3\r\n$3\r\nSET\r\n$1\r\na\r\n$1\r\n2\r\n"[0: 29]);
    const set_a_command: Command = try command_executor_test_command(&router, &set_a_parsed);
    _ = command_execute_at(&engine, &set_a_command, 1000u64);
    resp_value_free(&set_a_parsed.value);

    var set_c_parsed: RespParseResult = try parse_resp2(&"*3\r\n$3\r\nSET\r\n$1\r\nc\r\n$1\r\n3\r\n"[0: 29]);
    const set_c_command: Command = try command_executor_test_command(&router, &set_c_parsed);
    _ = command_execute_at(&engine, &set_c_command, 1000u64);
    resp_value_free(&set_c_parsed.value);

    var scan_parsed: RespParseResult = try parse_resp2(&"*4\r\n$4\r\nSCAN\r\n$1\r\n0\r\n$5\r\nCOUNT\r\n$1\r\n2\r\n"[0: 39]);
    const scan_command: Command = try command_executor_test_command(&router, &scan_parsed);
    var scan_reply: CommandReply = command_execute_at(&engine, &scan_command, 1000u64);
    try assert_eq_i32(scan_reply.typ as i32, CommandReplyType.reply_scan as i32);
    const scan_len: usize = try connection_encode_reply(&scan_reply, &out[0], 256);
    try assert_true(command_executor_test_slice_eq(out[0: scan_len], &"*2\r\n$1\r\n2\r\n*2\r\n$1\r\na\r\n$1\r\nb\r\n"[0: 29]));
    command_reply_cleanup(&scan_reply);
    resp_value_free(&scan_parsed.value);

    var scan_tail_parsed: RespParseResult = try parse_resp2(&"*4\r\n$4\r\nSCAN\r\n$1\r\n2\r\n$5\r\nCOUNT\r\n$1\r\n2\r\n"[0: 39]);
    const scan_tail_command: Command = try command_executor_test_command(&router, &scan_tail_parsed);
    var scan_tail_reply: CommandReply = command_execute_at(&engine, &scan_tail_command, 1000u64);
    const scan_tail_len: usize = try connection_encode_reply(&scan_tail_reply, &out[0], 256);
    try assert_true(command_executor_test_slice_eq(out[0: scan_tail_len], &"*2\r\n$1\r\n0\r\n*1\r\n$1\r\nc\r\n"[0: 22]));
    command_reply_cleanup(&scan_tail_reply);
    resp_value_free(&scan_tail_parsed.value);

    var scan_empty_parsed: RespParseResult = try parse_resp2(&"*2\r\n$4\r\nSCAN\r\n$1\r\n9\r\n"[0: 21]);
    const scan_empty_command: Command = try command_executor_test_command(&router, &scan_empty_parsed);
    var scan_empty_reply: CommandReply = command_execute_at(&engine, &scan_empty_command, 1000u64);
    const scan_empty_len: usize = try connection_encode_reply(&scan_empty_reply, &out[0], 256);
    try assert_true(command_executor_test_slice_eq(out[0: scan_empty_len], &"*2\r\n$1\r\n0\r\n*0\r\n"[0: 15]));
    command_reply_cleanup(&scan_empty_reply);
    resp_value_free(&scan_empty_parsed.value);

    engine_free(&engine);
    try assert_eq_i32(used_memory() as i32, 0);
}

export fn test_command_expire_and_ttl() !void {
    reset_memory_stats_for_test();
    const router: CommandRouter = command_router_new();
    var engine: Engine = engine_new();

    var set_parsed: RespParseResult = try parse_resp2(&"*3\r\n$3\r\nSET\r\n$3\r\nkey\r\n$5\r\nvalue\r\n"[0: 33]);
    const set_command: Command = try command_executor_test_command(&router, &set_parsed);
    _ = command_execute_at(&engine, &set_command, 1000u64);
    resp_value_free(&set_parsed.value);

    var expire_parsed: RespParseResult = try parse_resp2(&"*3\r\n$6\r\nEXPIRE\r\n$3\r\nkey\r\n$1\r\n2\r\n"[0: 32]);
    const expire_command: Command = try command_executor_test_command(&router, &expire_parsed);
    const expire_reply: CommandReply = command_execute_at(&engine, &expire_command, 1000u64);
    try assert_eq_i32(expire_reply.typ as i32, CommandReplyType.reply_integer as i32);
    try assert_eq_i32(expire_reply.integer as i32, 1);
    resp_value_free(&expire_parsed.value);

    var ttl_parsed: RespParseResult = try parse_resp2(&"*2\r\n$3\r\nTTL\r\n$3\r\nkey\r\n"[0: 22]);
    const ttl_command: Command = try command_executor_test_command(&router, &ttl_parsed);
    const ttl_reply: CommandReply = command_execute_at(&engine, &ttl_command, 1000u64);
    try assert_eq_i32(ttl_reply.typ as i32, CommandReplyType.reply_integer as i32);
    try assert_eq_i32(ttl_reply.integer as i32, 2);
    resp_value_free(&ttl_parsed.value);

    var expired_get_parsed: RespParseResult = try parse_resp2(&"*2\r\n$3\r\nGET\r\n$3\r\nkey\r\n"[0: 22]);
    const expired_get_command: Command = try command_executor_test_command(&router, &expired_get_parsed);
    const expired_get_reply: CommandReply = command_execute_at(&engine, &expired_get_command, 4000u64);
    try assert_eq_i32(expired_get_reply.typ as i32, CommandReplyType.reply_null_bulk as i32);
    resp_value_free(&expired_get_parsed.value);

    var missing_ttl_parsed: RespParseResult = try parse_resp2(&"*2\r\n$3\r\nTTL\r\n$3\r\nkey\r\n"[0: 22]);
    const missing_ttl_command: Command = try command_executor_test_command(&router, &missing_ttl_parsed);
    const missing_ttl_reply: CommandReply = command_execute_at(&engine, &missing_ttl_command, 4000u64);
    try assert_eq_i32(missing_ttl_reply.typ as i32, CommandReplyType.reply_integer as i32);
    try assert_eq_i32(missing_ttl_reply.integer as i32, -2);
    resp_value_free(&missing_ttl_parsed.value);

    var set_abs_parsed: RespParseResult = try parse_resp2(&"*3\r\n$3\r\nSET\r\n$3\r\nabs\r\n$5\r\nvalue\r\n"[0: 33]);
    const set_abs_command: Command = try command_executor_test_command(&router, &set_abs_parsed);
    _ = command_execute_at(&engine, &set_abs_command, 5000u64);
    resp_value_free(&set_abs_parsed.value);

    var pexpireat_parsed: RespParseResult = try parse_resp2(&"*3\r\n$9\r\nPEXPIREAT\r\n$3\r\nabs\r\n$4\r\n9000\r\n"[0: 38]);
    const pexpireat_command: Command = try command_executor_test_command(&router, &pexpireat_parsed);
    const pexpireat_reply: CommandReply = command_execute_at(&engine, &pexpireat_command, 5000u64);
    try assert_eq_i32(pexpireat_reply.typ as i32, CommandReplyType.reply_integer as i32);
    try assert_eq_i32(pexpireat_reply.integer as i32, 1);
    resp_value_free(&pexpireat_parsed.value);

    var abs_ttl_parsed: RespParseResult = try parse_resp2(&"*2\r\n$3\r\nTTL\r\n$3\r\nabs\r\n"[0: 22]);
    const abs_ttl_command: Command = try command_executor_test_command(&router, &abs_ttl_parsed);
    const abs_ttl_reply: CommandReply = command_execute_at(&engine, &abs_ttl_command, 5000u64);
    try assert_eq_i32(abs_ttl_reply.typ as i32, CommandReplyType.reply_integer as i32);
    try assert_eq_i32(abs_ttl_reply.integer as i32, 4);
    resp_value_free(&abs_ttl_parsed.value);

    engine_free(&engine);
    try assert_eq_i32(used_memory() as i32, 0);
}

export fn test_command_error_paths() !void {
    reset_memory_stats_for_test();
    const router: CommandRouter = command_router_new();
    var engine: Engine = engine_new();

    var bad_ping_parsed: RespParseResult = try parse_resp2(&"*3\r\n$4\r\nPING\r\n$1\r\na\r\n$1\r\nb\r\n"[0: 30]);
    const bad_ping_command: Command = try command_executor_test_command(&router, &bad_ping_parsed);
    const bad_ping_reply: CommandReply = command_execute_at(&engine, &bad_ping_command, 1000u64);
    try assert_eq_i32(bad_ping_reply.typ as i32, CommandReplyType.reply_error as i32);
    resp_value_free(&bad_ping_parsed.value);

    var set_option_parsed: RespParseResult = try parse_resp2(&"*4\r\n$3\r\nSET\r\n$3\r\nkey\r\n$5\r\nvalue\r\n$2\r\nNX\r\n"[0: 43]);
    const set_option_command: Command = try command_executor_test_command(&router, &set_option_parsed);
    const set_option_reply: CommandReply = command_execute_at(&engine, &set_option_command, 1000u64);
    try assert_eq_i32(set_option_reply.typ as i32, CommandReplyType.reply_error as i32);
    resp_value_free(&set_option_parsed.value);

    var expire_bad_parsed: RespParseResult = try parse_resp2(&"*3\r\n$6\r\nEXPIRE\r\n$3\r\nkey\r\n$3\r\nbad\r\n"[0: 36]);
    const expire_bad_command: Command = try command_executor_test_command(&router, &expire_bad_parsed);
    const expire_bad_reply: CommandReply = command_execute_at(&engine, &expire_bad_command, 1000u64);
    try assert_eq_i32(expire_bad_reply.typ as i32, CommandReplyType.reply_error as i32);
    resp_value_free(&expire_bad_parsed.value);

    var set_parsed: RespParseResult = try parse_resp2(&"*3\r\n$3\r\nSET\r\n$3\r\nkey\r\n$5\r\nvalue\r\n"[0: 33]);
    const set_command: Command = try command_executor_test_command(&router, &set_parsed);
    _ = command_execute_at(&engine, &set_command, 1000u64);
    resp_value_free(&set_parsed.value);

    var hget_wrongtype_parsed: RespParseResult = try parse_resp2(&"*3\r\n$4\r\nHGET\r\n$3\r\nkey\r\n$5\r\nfield\r\n"[0: 34]);
    const hget_wrongtype_command: Command = try command_executor_test_command(&router, &hget_wrongtype_parsed);
    const hget_wrongtype_reply: CommandReply = command_execute_at(&engine, &hget_wrongtype_command, 1000u64);
    try assert_eq_i32(hget_wrongtype_reply.typ as i32, CommandReplyType.reply_error as i32);
    resp_value_free(&hget_wrongtype_parsed.value);

    var lpush_wrongtype_parsed: RespParseResult = try parse_resp2(&"*3\r\n$5\r\nLPUSH\r\n$3\r\nkey\r\n$1\r\na\r\n"[0: 31]);
    const lpush_wrongtype_command: Command = try command_executor_test_command(&router, &lpush_wrongtype_parsed);
    const lpush_wrongtype_reply: CommandReply = command_execute_at(&engine, &lpush_wrongtype_command, 1000u64);
    try assert_eq_i32(lpush_wrongtype_reply.typ as i32, CommandReplyType.reply_error as i32);
    resp_value_free(&lpush_wrongtype_parsed.value);

    var sadd_wrongtype_parsed: RespParseResult = try parse_resp2(&"*3\r\n$4\r\nSADD\r\n$3\r\nkey\r\n$1\r\na\r\n"[0: 30]);
    const sadd_wrongtype_command: Command = try command_executor_test_command(&router, &sadd_wrongtype_parsed);
    const sadd_wrongtype_reply: CommandReply = command_execute_at(&engine, &sadd_wrongtype_command, 1000u64);
    try assert_eq_i32(sadd_wrongtype_reply.typ as i32, CommandReplyType.reply_error as i32);
    resp_value_free(&sadd_wrongtype_parsed.value);

    var zadd_wrongtype_parsed: RespParseResult = try parse_resp2(&"*4\r\n$4\r\nZADD\r\n$3\r\nkey\r\n$1\r\n1\r\n$1\r\na\r\n"[0: 37]);
    const zadd_wrongtype_command: Command = try command_executor_test_command(&router, &zadd_wrongtype_parsed);
    const zadd_wrongtype_reply: CommandReply = command_execute_at(&engine, &zadd_wrongtype_command, 1000u64);
    try assert_eq_i32(zadd_wrongtype_reply.typ as i32, CommandReplyType.reply_error as i32);
    resp_value_free(&zadd_wrongtype_parsed.value);

    var hset_hash_parsed: RespParseResult = try parse_resp2(&"*4\r\n$4\r\nHSET\r\n$4\r\nhash\r\n$5\r\nfield\r\n$5\r\nvalue\r\n"[0: 46]);
    const hset_hash_command: Command = try command_executor_test_command(&router, &hset_hash_parsed);
    _ = command_execute_at(&engine, &hset_hash_command, 1000u64);
    resp_value_free(&hset_hash_parsed.value);

    var save_parsed: RespParseResult = try parse_resp2(&"*1\r\n$4\r\nSAVE\r\n"[0: 14]);
    const save_command: Command = try command_executor_test_command(&router, &save_parsed);
    const save_reply: CommandReply = command_execute_at(&engine, &save_command, 1000u64);
    try assert_eq_i32(save_reply.typ as i32, CommandReplyType.reply_simple_string as i32);
    resp_value_free(&save_parsed.value);

    var scan_bad_option_parsed: RespParseResult = try parse_resp2(&"*4\r\n$4\r\nSCAN\r\n$1\r\n0\r\n$5\r\nMATCH\r\n$1\r\n*\r\n"[0: 39]);
    const scan_bad_option_command: Command = try command_executor_test_command(&router, &scan_bad_option_parsed);
    const scan_bad_option_reply: CommandReply = command_execute_at(&engine, &scan_bad_option_command, 1000u64);
    try assert_eq_i32(scan_bad_option_reply.typ as i32, CommandReplyType.reply_error as i32);
    resp_value_free(&scan_bad_option_parsed.value);

    engine_free(&engine);
    try assert_eq_i32(used_memory() as i32, 0);
}
