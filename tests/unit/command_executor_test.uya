    resp_value_free(&hget_parsed.value);

    var hset_update_parsed: RespParseResult = try parse_resp2(&"*4\r\n$4\r\nHSET\r\n$4\r\nhash\r\n$5\r\nfield\r\n$4\r\nnext\r\n"[0: 45]);
